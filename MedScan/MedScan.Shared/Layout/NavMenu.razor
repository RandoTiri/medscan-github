@implements IDisposable
@inject NavigationManager Navigation
@inject MedScan.Shared.Services.IAuthService AuthService
@inject MedScan.Shared.Services.IScannerFlowService ScannerFlowService

@if (AuthService.IsLoggedIn)
{
    <nav class="bottom-nav">
        <div class="nav-item @(currentUrl == "" ? "active" : "")" @onclick='() => NavigateTo("/")'>
            <span class="nav-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            </span>
            <span class="nav-label">Avaleht</span>
        </div>
        <div class="nav-item @(currentUrl == "home-pharmacy" ? "active" : "")" @onclick='() => NavigateTo("/home-pharmacy")'>
            <span class="nav-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"></path><path d="m8.5 8.5 7 7"></path></svg>
            </span>
            <span class="nav-label">Ravimid</span>
        </div>
        <div class="nav-item-center" @onclick="StartScannerAsync">
            <div class="center-button">
                <span class="center-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7V4h3"></path><path d="M4 17v3h3"></path><path d="M20 7V4h-3"></path><path d="M20 17v3h-3"></path><line x1="8" y1="12" x2="16" y2="12"></line></svg>
                </span>
            </div>
        </div>
        <div class="nav-item @(currentUrl == "profile" ? "active" : "")" @onclick='() => NavigateTo("/profile")'>
            <span class="nav-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </span>
            <span class="nav-label">Profiilid</span>
        </div>
        <div class="nav-item @(currentUrl == "settings" ? "active" : "")" @onclick='() => NavigateTo("/settings")'>
            <span class="nav-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
            </span>
            <span class="nav-label">Seaded</span>
        </div>
    </nav>
}

@code {
    private string currentUrl = "";

    protected override void OnInitialized()
    {
        currentUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        Navigation.LocationChanged += OnLocationChanged;
        AuthService.OnChange += StateHasChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        currentUrl = Navigation.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    private string GetNavItemClass(string path)
    {
        var normalizedCurrent = "/" + (currentUrl?.Split('?')[0].Trim('/') ?? "");
        var normalizedPath = "/" + path.Trim('/');

        bool isActive = normalizedCurrent.Equals(normalizedPath, StringComparison.OrdinalIgnoreCase);

        return isActive ? "nav-item active" : "nav-item";
    }

    private void NavigateTo(string url)
    {
        Navigation.NavigateTo(url);
    }

    private async Task StartScannerAsync()
    {
        var scanResult = await ScannerFlowService.ScanAsync();

        if (scanResult.Status == MedScan.Shared.Models.BarcodeScanStatus.Success && !string.IsNullOrWhiteSpace(scanResult.Barcode))
        {
            var route = $"/home-pharmacy/save-medication/{Uri.EscapeDataString(scanResult.Barcode)}";
            if (scanResult.ExpirationDate is DateOnly expirationDate)
            {
                route += $"?exp={Uri.EscapeDataString(expirationDate.ToString("yyyy-MM-dd"))}";
            }
            if (!string.IsNullOrWhiteSpace(scanResult.BatchNumber))
            {
                route += route.Contains('?')
                    ? $"&lot={Uri.EscapeDataString(scanResult.BatchNumber)}"
                    : $"?lot={Uri.EscapeDataString(scanResult.BatchNumber)}";
            }

            Navigation.NavigateTo(route);
        }
        else if (scanResult.Status == MedScan.Shared.Models.BarcodeScanStatus.ManualSearch)
        {
            Navigation.NavigateTo("/home-pharmacy/search");
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        AuthService.OnChange -= StateHasChanged;
    }
}
