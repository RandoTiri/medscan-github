@inherits LayoutComponentBase
@implements IDisposable
@inject IThemeService ThemeService
@inject IInAppDoseAlertService InAppDoseAlertService
@inject IMedicationService MedicationService

<div class="page">
    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
    <NavMenu />

    @if (InAppDoseAlertService.Current is not null) {
        <div class="alert-backdrop"></div>
        <section class="dose-alert-modal" role="dialog" aria-modal="true" aria-label="Ravimi meeldetuletus">
            <h2>@InAppDoseAlertService.Current.ScheduledTime.ToString("HH:mm")</h2>
            <p class="dose-alert-med">@InAppDoseAlertService.Current.MedicationName</p>
            <p class="dose-alert-profile">@InAppDoseAlertService.Current.ProfileName</p>
            @if (!string.IsNullOrWhiteSpace(InAppDoseAlertService.Current.Note)) {
                <p class="dose-alert-note">@InAppDoseAlertService.Current.Note</p>
            }
            <div class="dose-alert-actions">
                <button type="button" class="dose-alert-done" disabled="@_isUpdatingFromPopup" @onclick="MarkDoneFromAlertAsync">Võetud</button>
                <button type="button" class="dose-alert-dismiss" disabled="@_isUpdatingFromPopup" @onclick="DismissAlert">Sulge</button>
            </div>
        </section>
    }

    @if (_isExpiredWarningOpen && _expiredWarningDate is DateOnly warningDate) {
        <div class="alert-backdrop"></div>
        <section class="expired-warning-modal" role="dialog" aria-modal="true" aria-label="Aegunud ravimi hoiatus">
            <h3>Tahelepanu!</h3>
            <p>See ravim aegus @warningDate.ToString("dd.MM.yyyy").</p>
            <p>Selle ravimi manustamine on rangelt mittesoovituslik.</p>
            <p>Palun tagasta aegunud ravim apteeki.</p>
            <div class="expired-warning-actions">
                <button type="button" class="expired-warning-confirm" disabled="@_isUpdatingFromPopup" @onclick="TakeExpiredAnywayAsync">Võtan ikkagi</button>
                <button type="button" class="expired-warning-decline" disabled="@_isUpdatingFromPopup" @onclick="DeclineExpiredDoseAsync">Ei võta</button>
            </div>
        </section>
    }
</div>

@code {
    private bool _isUpdatingFromPopup;
    private bool _isExpiredWarningOpen;
    private DateOnly? _expiredWarningDate;

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (!firstRender) {
            return;
        }

        ThemeService.OnChanged += HandleThemeChanged;
        InAppDoseAlertService.Changed += HandleAlertChanged;
        await ThemeService.InitializeAsync();
    }

    private void HandleThemeChanged() {
        InvokeAsync(StateHasChanged);
    }

    private void HandleAlertChanged() {
        InvokeAsync(StateHasChanged);
    }

    private void DismissAlert() {
        InAppDoseAlertService.DismissCurrent();
    }

    private void CloseExpiredWarning() {
        _isExpiredWarningOpen = false;
        _expiredWarningDate = null;
    }

    private async Task TakeExpiredAnywayAsync() {
        await UpdateCurrentAlertStatusAsync(MedScan.Shared.Models.Enums.DoseStatusEnum.Done);
    }

    private async Task DeclineExpiredDoseAsync() {
        await UpdateCurrentAlertStatusAsync(MedScan.Shared.Models.Enums.DoseStatusEnum.Missed);
    }

    private async Task UpdateCurrentAlertStatusAsync(MedScan.Shared.Models.Enums.DoseStatusEnum status) {
        if (_isUpdatingFromPopup || InAppDoseAlertService.Current is null) {
            return;
        }

        _isUpdatingFromPopup = true;
        try {
            await MedicationService.UpdateStatusAsync(InAppDoseAlertService.Current.UserMedicationId,new MedScan.Shared.DTOs.Medication.UpdateMedicationStatusDto {
                ScheduledTime = InAppDoseAlertService.Current.ScheduledTime,
                Status = status
            });

            InAppDoseAlertService.DismissCurrent();
            CloseExpiredWarning();
        } catch {
            // Popup action is best effort.
        } finally {
            _isUpdatingFromPopup = false;
        }
    }

    private async Task MarkDoneFromAlertAsync() {
        if (_isUpdatingFromPopup || InAppDoseAlertService.Current is null) {
            return;
        }

        _isUpdatingFromPopup = true;
        var shouldDismissAlert = true;
        try {
            var medication = await MedicationService.GetByIdAsync(InAppDoseAlertService.Current.UserMedicationId);
            if (medication?.ExpiresOn is DateOnly expiryDate && AppDate.IsExpired(expiryDate)) {
                _expiredWarningDate = expiryDate;
                _isExpiredWarningOpen = true;
                shouldDismissAlert = false;
                return;
            }

            await MedicationService.UpdateStatusAsync(InAppDoseAlertService.Current.UserMedicationId,new MedScan.Shared.DTOs.Medication.UpdateMedicationStatusDto {
                ScheduledTime = InAppDoseAlertService.Current.ScheduledTime,
                Status = MedScan.Shared.Models.Enums.DoseStatusEnum.Done
            });
        } catch {
            // Popup action is best effort.
        } finally {
            _isUpdatingFromPopup = false;
            if (shouldDismissAlert) {
                InAppDoseAlertService.DismissCurrent();
            }
        }
    }

    public void Dispose() {
        ThemeService.OnChanged -= HandleThemeChanged;
        InAppDoseAlertService.Changed -= HandleAlertChanged;
    }
}