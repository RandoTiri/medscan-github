@page "/register"
@layout MedScan.Shared.Layout.AuthLayout
@using MedScan.Shared.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Registreeru</PageTitle>



<div class="login-container">
    @if (RegistrationSuccessful)
    {
        <div class="success-container">
            <div class="success-icon">
                <svg viewBox="0 0 24 24" width="80" height="80" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
            </div>
            <div class="success-message">Olete edukalt kasutaja loonud!</div>
            <button class="btn-primary" @onclick="GoToLogin">Logi sisse</button>
        </div>
    }
    else
    {
        <div class="header-section">
            <div class="logo-container">
                <svg viewBox="0 0 24 24" width="40" height="40" stroke="white" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"></path>
                    <path d="m8.5 8.5 7 7"></path>
                </svg>
            </div>
            <h1 class="brand-name">Loo kasutaja</h1>
            <p class="brand-subtitle">Loo endale MedScan konto.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="auth-error">@ErrorMessage</div>
        }

        <div class="form-section">
            <div class="auth-input-group">
                <label for="fullname">Nimi</label>
                <div class="input-wrapper">
                    <div class="input-icon">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </div>
                    <input id="fullname" type="text" placeholder="Sinu Nimi" @bind="FullName" disabled="@IsBusy" />
                </div>
            </div>

            <div class="auth-input-group">
                <label for="email">E-mail</label>
                <div class="input-wrapper">
                    <div class="input-icon">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                    </div>
                    <input id="email" type="email" placeholder="sinuemail@gmail.com" @bind="Email" disabled="@IsBusy" />
                </div>
            </div>

            <div class="auth-input-group">
                <label for="password">Parool</label>
                <div class="input-wrapper">
                    <div class="input-icon">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </div>
                    <input id="password" type="@PasswordInputType" placeholder="••••••••" @bind="Password" disabled="@IsBusy" />
                    <div class="input-action" @onclick="TogglePasswordVisibility">
                        @if (ShowPassword)
                        {
                            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        }
                    </div>
                </div>
            </div>

            <div class="auth-input-group">
                <label for="gender">Sugu</label>
                <div class="input-wrapper">
                    <div class="input-icon">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="7" r="4"></circle>
                            <path d="M5.5 21a6.5 6.5 0 0 1 13 0"></path>
                        </svg>
                    </div>
                    <select id="gender" @bind="Gender" disabled="@IsBusy" class="@(string.IsNullOrEmpty(Gender) ? "empty-select" : "")">
                        <option value="">Vali sugu</option>
                        <option value="Naine">Naine</option>
                        <option value="Mees">Mees</option>
                        <option value="Ei soovi avaldada">Ei soovi avaldada</option>
                    </select>
                </div>
            </div>

            <div class="auth-input-group">
                <label for="birthdate">Sünnikuupäev</label>
                <div class="birth-grid">
                    <select class="birth-select @(string.IsNullOrEmpty(_birthDay) ? "empty-select" : "")" @bind="_birthDay" disabled="@IsBusy">
                        <option value="">Päev</option>
                        @for (var day = 1; day <= 31; day++)
                        {
                            <option value="@day">@day</option>
                        }
                    </select>
                    <select class="birth-select @(string.IsNullOrEmpty(_birthMonth) ? "empty-select" : "")" @bind="_birthMonth" disabled="@IsBusy">
                        <option value="">Kuu</option>
                        @for (var month = 1; month <= 12; month++)
                        {
                            <option value="@month">@month</option>
                        }
                    </select>
                    <select class="birth-select @(string.IsNullOrEmpty(_birthYear) ? "empty-select" : "")" @bind="_birthYear" disabled="@IsBusy">
                        <option value="">Aasta</option>
                        @for (var year = DateTime.Today.Year; year >= 1900; year--)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>
                </div>
            </div>
            
            <div class="empty-space"></div>

            <button class="btn-primary" @onclick="HandleRegister" disabled="@IsBusy">
                @(IsBusy ? "Loob kasutajat..." : "Registreeru")
            </button>

            <div class="divider">
                <span>Juba on konto?</span>
            </div>

            <button class="btn-secondary" @onclick="GoToLogin" disabled="@IsBusy">
                Tagasi sisselogimislehele
            </button>
        </div>
    }
</div>

@code {
    private string FullName = string.Empty;
    private string Email = string.Empty;
    private string Password = string.Empty;
    private string Gender = string.Empty;
    private string _birthDay = string.Empty;
    private string _birthMonth = string.Empty;
    private string _birthYear = string.Empty;
    private string ErrorMessage = string.Empty;
    private bool IsBusy;
    private bool ShowPassword = false;
    private string PasswordInputType => ShowPassword ? "text" : "password";
    private bool RegistrationSuccessful = false;

    protected override async Task OnInitializedAsync() {
        await AuthService.InitializeAsync();

        if (AuthService.IsLoggedIn) {
            Navigation.NavigateTo("/");
        }
    }

    private async Task HandleRegister() {
        if (IsBusy) return;

        IsBusy = true;
        ErrorMessage = string.Empty;
        RegistrationSuccessful = false;

        try {
            var normalizedEmail = Email.Trim();

            if (!HasValidEmailSuffix(normalizedEmail)) {
                ErrorMessage = "Invalid email.";
                return;
            }

            if (!TryBuildBirthDate(out var birthDate))
            {
                ErrorMessage = "Sisesta korrektne sunnikuupaev.";
                return;
            }

            var result = await AuthService.RegisterAsync(FullName, normalizedEmail, Password, Gender, birthDate);

            if (result.Success) {
                RegistrationSuccessful = true;
                return;
            }

            ErrorMessage = result.ErrorMessage;
        }
        catch (Exception ex) {
            ErrorMessage = ex.ToString();
        }
        finally {
            IsBusy = false;
        }
    }

    private void GoToLogin() {
        Navigation.NavigateTo("/login");
    }

    private void TogglePasswordVisibility() {
        ShowPassword = !ShowPassword;
    }

    private static bool HasValidEmailSuffix(string email) {
        if (string.IsNullOrWhiteSpace(email) || !email.Contains('@')) return false;

        if (email.Length >= 3 && email[^3] == '.' && 
            char.IsLetter(email[^2]) && 
            char.IsLetter(email[^1])) return true;

        if (email.Length >= 4 && email[^4] == '.' && 
            char.IsLetter(email[^3]) && 
            char.IsLetter(email[^2]) && 
            char.IsLetter(email[^1])) return true;

        return false;
    }

    private bool TryBuildBirthDate(out DateOnly birthDate)
    {
        birthDate = default;

        var hasAny = !string.IsNullOrWhiteSpace(_birthDay) ||
                     !string.IsNullOrWhiteSpace(_birthMonth) ||
                     !string.IsNullOrWhiteSpace(_birthYear);
        var hasAll = !string.IsNullOrWhiteSpace(_birthDay) &&
                     !string.IsNullOrWhiteSpace(_birthMonth) &&
                     !string.IsNullOrWhiteSpace(_birthYear);

        if (!hasAny || !hasAll)
        {
            return false;
        }

        if (!int.TryParse(_birthYear, out var year) ||
            !int.TryParse(_birthMonth, out var month) ||
            !int.TryParse(_birthDay, out var day))
        {
            return false;
        }

        if (year < 1900 || year > DateTime.Today.Year)
        {
            return false;
        }

        try
        {
            birthDate = new DateOnly(year, month, day);
            return birthDate <= DateOnly.FromDateTime(DateTime.Today);
        }
        catch
        {
            return false;
        }
    }
}
