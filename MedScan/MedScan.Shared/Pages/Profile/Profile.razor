@page "/profile"
@using MedScan.Shared.Models
@inject IAuthService AuthService
@inject IProfileService ProfileService
@inject NavigationManager Navigation

<PageTitle>Profiilid</PageTitle>

@if (!AuthService.IsLoggedIn) {
    <p>Suunan loginisse...</p>
} else {
    <div class="page-container">
        <div class="content-wrapper">
            <div class="profile-header">
                <span class="header-spacer"></span>
                <h1 class="page-title">Profiilid</h1>
                <span class="header-spacer"></span>
            </div>

            <div class="main-user-card" @onclick="OpenMainProfileView">
                <div class="avatar-outline">@GetInitials()</div>
                <div class="main-user-info">
                    <p class="name">@(AuthService.CurrentUser?.FullName ?? "Nimetu")</p>
                    <p class="subtitle">@GetMainUserDetails()</p>
                </div>
                <div class="main-user-chevron">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                </div>
            </div>

            <div class="section-header">
                <h2 class="section-title">Hoolealune</h2>
                @if (!isAdding) {
                    <button class="btn-add" @onclick="ToggleAddForm">+ Lisa</button>
                }
            </div>

            <PatientProfileEditDialog IsOpen="isAdding"
                                      Model="_newPatientModel"
                                      NamePlaceholder="nt. Maie Tamm"
                                      OnSave="SavePatientAsync"
                                      OnCancel="ToggleAddForm" />

            <div class="patients-list">
                @if (CareReceivers.Any()) {
                    @foreach (var patient in CareReceivers) {
                        <div class="patient-card" @onclick="() => OpenProfileView(patient.Id)">
                            <div class="patient-avatar">
                                @patient.Initials
                            </div>
                            <div class="patient-info">
                                <p class="patient-name">@patient.Name</p>
                                <p class="patient-details">@GetPatientDetails(patient)</p>
                            </div>
                            <div class="patient-chevron">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="9 18 15 12 9 6"></polyline>
                                </svg>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    private List<Patient> CareReceivers = [];
    private int _mainProfileId;
    private Patient? _mainUserProfile;
    private bool isAdding = false;
    private CreatePatientProfileRequest _newPatientModel = new();

    protected override async Task OnInitializedAsync() {
        await AuthService.InitializeAsync();

        if (!AuthService.IsLoggedIn) {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadPatientsAsync();
    }

    private void ToggleAddForm() {
        isAdding = !isAdding;
        if (isAdding) {
            _newPatientModel = new CreatePatientProfileRequest();
        }
    }

    private async Task SavePatientAsync() {
        if (string.IsNullOrWhiteSpace(_newPatientModel.Name)) {
            return;
        }

        var createdProfile = await ProfileService.CreatePatientProfileAsync(_newPatientModel);
        CareReceivers.Add(new Patient {
            Id = createdProfile.Id,
            Name = createdProfile.Name,
            BirthDate = createdProfile.BirthDate,
            Gender = createdProfile.Gender
        });

        isAdding = false;
        _newPatientModel = new CreatePatientProfileRequest();
    }

    private async Task LoadPatientsAsync() {
        var profiles = await ProfileService.GetMyProfilesAsync();

        _mainProfileId = AuthService.CurrentUser?.DefaultProfileId
            ?? profiles.FirstOrDefault(p => ProfileTypeMapper.IsMainUser(p.Type))?.Id
            ?? 0;

        var mainProfile = profiles.FirstOrDefault(p => p.Id == _mainProfileId)
            ?? profiles.FirstOrDefault(p => ProfileTypeMapper.IsMainUser(p.Type));

        _mainUserProfile = mainProfile is null
            ? null
            : new Patient {
                Id = mainProfile.Id,
                Name = mainProfile.Name,
                BirthDate = mainProfile.BirthDate,
                Gender = ProfileDisplayFormatter.NormalizeGender(mainProfile.Gender)
            };

        CareReceivers = profiles
            .Where(p => ProfileTypeMapper.IsPatient(p.Type))
            .Select(p => new Patient {
                Id = p.Id,
                Name = p.Name,
                BirthDate = p.BirthDate,
                Gender = ProfileDisplayFormatter.NormalizeGender(p.Gender)
            })
            .ToList();
    }

    private static string GetPatientDetails(Patient patient) {
        return ProfileDisplayFormatter.BuildDetails(patient);
    }

    private string GetMainUserDetails() {
        if (_mainUserProfile is null) {
            return ProfileDisplayFormatter.BuildDetails(null);
        }

        return GetPatientDetails(_mainUserProfile);
    }

    private void OpenProfileView(int profileId) {
        Navigation.NavigateTo($"/profile/view/{profileId}");
    }

    private void OpenMainProfileView() {
        if (_mainProfileId > 0) {
            Navigation.NavigateTo($"/profile/view/{_mainProfileId}");
        }
    }

    private string GetInitials() {
        return ProfileDisplayFormatter.BuildInitials(AuthService.CurrentUser?.FullName);
    }
}