@page "/profile/view/{ProfileId:int}"
@inherits MedScan.Shared.Pages.Medication.MedicationScannerComponentBase
@using MedScan.Shared.DTOs.Medication
@using MedScan.Shared.Models
@using MedScan.Shared.Models.Enums
@inject IAuthService AuthService
@inject IProfileService ProfileService
@inject IMedicationService MedicationService

<PageTitle>Profiili vaade</PageTitle>

@if (!_isReady) {
    <p><em>Laen...</em></p>
} else if (_patient is null) {
    <div class="profile-view-page">
        <div class="profile-view-content">
            <BackButton OnClick="GoBack" />
            <div class="empty-box">Profiili ei leitud.</div>
        </div>
    </div>
} else {
    <div class="profile-view-page">
        <div class="profile-view-content">
            <BackButton OnClick="GoBack" />

            <section class="profile-summary-card @(_isPatientProfile ? "patient-card-view" : "main-card-view")">
                <div class="profile-avatar @(_isPatientProfile ? "patient-avatar-view" : "main-avatar-view")">@_patient.Initials</div>
                <div class="profile-main-info @(_isPatientProfile ? "patient-info-view" : "main-info-view")">
                    <h1>@_patient.Name</h1>
                    <p>@ProfileDisplayFormatter.BuildDetails(_patient)</p>
                </div>
            </section>

            @if (!string.IsNullOrWhiteSpace(_errorMessage)) {
                <div class="error-box">@_errorMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(_medicationCheckMessage)) {
                <div class="@(_medicationCheckIsSuccess ? "success-box" : "error-box")">@_medicationCheckMessage</div>
            }

            <section class="today-overview-panel">
                <section class="action-panel">
                    <button class="primary-action" @onclick="StartScannerAsync">
                        <span class="action-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7V4h3"></path><path d="M4 17v3h3"></path><path d="M20 7V4h-3"></path><path d="M20 17v3h-3"></path><line x1="8" y1="12" x2="16" y2="12"></line></svg>
                        </span>
                        Kontrolli ravimit
                    </button>

                    <button class="secondary-action" @onclick="OpenTodayOverview">
                        <span class="action-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line><path d="M9 14h.01"></path><path d="M12 14h.01"></path><path d="M15 14h.01"></path></svg>
                        </span>
                        Manustamise logi
                    </button>
                </section>

                <section class="schedule-panel">
                    <h2 class="section-title">Tänane raviskeem</h2>
                    <section class="dose-list">
                        @if (_entries.Count == 0) {
                            <div class="empty-box">Sellel profiilil pole tänaseid ravikirjeid.</div>
                        } else {
                            @foreach (var entry in _entries) {
                                var status = GetStatusView(entry.Status);

                                <article class="dose-card">
                                    <div class="dose-title-row">
                                        <span class="status-pill @status.CssClass">@status.Label</span>
                                        <strong>@entry.Time.ToString("HH:mm") – @entry.DisplayName</strong>
                                    </div>
                                </article>
                            }
                        }
                    </section>
                </section>
            </section>

            @if (_isPatientProfile) {
                <section class="crud-panel patient-action-panel">
                    <button class="patient-edit-btn" @onclick="ToggleEdit">
                        Muuda hooldatava andmeid
                    </button>
                    <button class="patient-delete-btn" @onclick="PromptDelete">Kustuta hooldatav</button>
                </section>
            }

            @if (_isPatientProfile) {
                <PatientProfileEditDialog IsOpen="_isEditing"
                                          Model="_editModel"
                                          OnSave="SaveChangesAsync"
                                          OnCancel="CloseEdit" />
            }

            @if (_showDeleteConfirm && _patient is not null && _isPatientProfile) {
                <div class="confirm-overlay">
                    <div class="confirm-dialog">
                        <p>Kas soovite @_patient.Name ära kustutada?</p>
                        <div class="confirm-actions">
                            <button class="confirm-yes" @onclick="ConfirmDeleteAsync">Jah</button>
                            <button class="confirm-no" @onclick="CancelDelete">Ei</button>
                        </div>
                    </div>
                </div>
            }

            @if (_isManualSearchOpen) {
                <div class="confirm-overlay" @onclick="CloseManualSearch">
                    <div class="confirm-dialog manual-search-dialog" @onclick:stopPropagation="true">
                        <p>Otsi ravim käsitsi</p>

                        @if (!string.IsNullOrWhiteSpace(_manualSearchMessage)) {
                            <div class="error-box">@_manualSearchMessage</div>
                        }

                        <div class="manual-search-bar manual-search-bar-spaced">
                            <input class="form-control" @bind="_manualSearchQuery" placeholder="Sisesta ravimi nimi" />
                            <button class="save-btn" @onclick="SearchMedicationAsync" disabled="@_isManualSearchBusy">
                                @(_isManualSearchBusy ? "Otsin..." : "Otsi")
                            </button>
                        </div>

                        @if (_manualSearchResults.Count > 0) {
                            <div class="manual-search-results">
                                @foreach (var item in _manualSearchResults) {
                                    <button class="manual-search-result" @onclick="() => SelectManualSearchResultAsync(item)">
                                        <strong>@item.Name</strong>
                                        <span>@item.ActiveIngredient</span>
                                    </button>
                                }
                            </div>
                        }

                        <div class="confirm-actions confirm-actions-spaced">
                            <button class="patient-delete-btn" @onclick="CloseManualSearch">Sulge</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] 
    public int ProfileId { get; set; }

    private bool _isReady;
    private bool _isEditing;
    private bool _isPatientProfile;
    private bool _showDeleteConfirm;
    private string? _errorMessage;
    private string? _medicationCheckMessage;
    private bool _medicationCheckIsSuccess;
    private Patient? _patient;
    private readonly List<DoseEntry> _entries = [];
    private readonly List<UserMedicationDto> _profileMedications = [];
    private CreatePatientProfileRequest _editModel = new();
    private bool _isManualSearchOpen;
    private bool _isManualSearchBusy;
    private string _manualSearchQuery = string.Empty;
    private string? _manualSearchMessage;
    private IReadOnlyList<MedicationLookupResult> _manualSearchResults = [];

    protected override async Task OnParametersSetAsync() {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn) {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync() {
        _isReady = false;
        _errorMessage = null;

        try {
            var profile = await ProfileService.GetByIdAsync(ProfileId);
            if (profile is null) {
                _patient = null;
                _entries.Clear();
                return;
            }

            _isPatientProfile = ProfileTypeMapper.IsPatient(profile.Type);

            _patient = new Patient {
                Id = profile.Id,
                Name = profile.Name,
                Gender = ProfileDisplayFormatter.NormalizeGender(profile.Gender),
                BirthDate = profile.BirthDate
            };

            _editModel = new CreatePatientProfileRequest {
                Name = _patient.Name,
                Gender = _patient.Gender,
                BirthDate = _patient.BirthDate
            };

            var medications = (await MedicationService.GetScheduleAsync(ProfileId))
                .Where(medication => medication.IsActive)
                .ToList();

            _profileMedications.Clear();
            _profileMedications.AddRange(medications);

            _entries.Clear();
            _entries.AddRange(BuildEntries(medications));
        } catch {
            _errorMessage = "Profiili laadimine ebaõnnestus.";
        } finally {
            _isReady = true;
        }
    }

    private void PromptDelete() {
        _showDeleteConfirm = true;
    }

    private void CancelDelete() {
        _showDeleteConfirm = false;
    }

    private async Task ConfirmDeleteAsync() {
        _showDeleteConfirm = false;
        await DeleteAsync();
    }

    private static IEnumerable<DoseEntry> BuildEntries(IEnumerable<UserMedicationDto> medications) {
        return medications
            .Where(m => m.IsActive)
            .SelectMany(m => {
                if (m.TodayDoses.Count > 0) {
                    return m.TodayDoses.Select(dose => new DoseEntry(
                        dose.ScheduledTime,
                        MedicationTextFormatter.BuildDisplayName(m),
                        m,
                        dose.Status));
                }

                if (m.ScheduleUnit != MedicationScheduleUnit.Day) {
                    return Enumerable.Empty<DoseEntry>();
                }

                return m.ScheduledTimes.Select(time => new DoseEntry(
                    time,
                    MedicationTextFormatter.BuildDisplayName(m),
                    m,
                    DoseStatusEnum.Pending));
            })
            .OrderBy(entry => entry.Time)
            .ThenBy(entry => entry.DisplayName)
            .ToList();
    }

    private static StatusView GetStatusView(DoseStatusEnum? status) {
        return new StatusView(MedicationTextFormatter.GetDoseStatusLabel(status),MedicationTextFormatter.GetDoseStatusCss(status),string.Empty);
    }

    private async Task SaveChangesAsync() {
        if (_patient is null || string.IsNullOrWhiteSpace(_editModel.Name)) {
            return;
        }

        _errorMessage = null;

        try {
            var updated = await ProfileService.UpdatePatientProfileAsync(ProfileId,_editModel);
            if (updated is null) {
                _errorMessage = "Profiili uuendamine ebaõnnestus.";
                return;
            }

            _patient.Name = updated.Name;
            _patient.Gender = ProfileDisplayFormatter.NormalizeGender(updated.Gender);
            _patient.BirthDate = updated.BirthDate;
            _isEditing = false;
        } catch {
            _errorMessage = "Profiili uuendamine ebaõnnestus.";
        }
    }

    private async Task DeleteAsync() {
        if (_patient is null) {
            return;
        }

        _errorMessage = null;

        try {
            var deleted = await ProfileService.DeletePatientProfileAsync(ProfileId);
            if (!deleted) {
                _errorMessage = "Hooldatava kustutamine ebaõnnestus.";
                return;
            }

            Navigation.NavigateTo("/profile");
        } catch {
            _errorMessage = "Hooldatava kustutamine ebaõnnestus.";
        }
    }

    private void ToggleEdit() {
        _isEditing = !_isEditing;
        _errorMessage = null;

        if (_isEditing && _patient is not null) {
            _editModel = new CreatePatientProfileRequest {
                Name = _patient.Name,
                Gender = _patient.Gender,
                BirthDate = _patient.BirthDate
            };
        }
    }

    private void CloseEdit() {
        if (!_isEditing) {
            return;
        }

        ToggleEdit();
    }

    private void GoBack() => Navigation.NavigateTo("/profile");

    protected override Task OnBeforeScannerAsync() {
        _errorMessage = null;
        _medicationCheckMessage = null;

        return Task.CompletedTask;
    }

    protected override async Task OnSuccessfulScanAsync(BarcodeScanResult scanResult,int? targetProfileId,bool replace) {
        await VerifyMedicationByBarcodeAsync(scanResult.Barcode ?? string.Empty);
    }

    protected override Task OnManualSearchScanAsync(int? targetProfileId,bool replace) {
        OpenManualSearch();
        return Task.CompletedTask;
    }

    protected override Task OnPermissionDeniedScanAsync() {
        _errorMessage = "Skänneri kasutamiseks on vaja kaameraluba.";
        return Task.CompletedTask;
    }

    private void OpenTodayOverview() {
        Navigation.NavigateTo($"/profile/view/{ProfileId}/history");
    }

    private async Task VerifyMedicationByBarcodeAsync(string barcode) {
        try {
            var medication = await ScannerFlowService.FindByBarcodeAsync(barcode);
            if (medication is null) {
                SetMedicationCheckResult(false,"Tuvastatud ravimit ei leitud andmebaasist.");
                return;
            }

            ApplyMedicationCheckResult(medication);
        } catch {
            SetMedicationCheckResult(false,"Ravimi kontroll ebaõnnestus.");
        }
    }

    private void ApplyMedicationCheckResult(MedicationLookupResult medication) {
        var isInSchedule = _profileMedications.Any(item => item.MedicationId == medication.Id);
        if (isInSchedule) {
            SetMedicationCheckResult(true,$"{medication.Name} on kasutaja raviskeemis.");
            return;
        }

        SetMedicationCheckResult(false,$"{medication.Name} ei kuulu kasutaja raviskeemi.");
    }

    private void SetMedicationCheckResult(bool isSuccess,string message) {
        _medicationCheckIsSuccess = isSuccess;
        _medicationCheckMessage = message;
    }

    private void OpenManualSearch() {
        _isManualSearchOpen = true;
        _manualSearchQuery = string.Empty;
        _manualSearchMessage = null;
        _manualSearchResults = [];
    }

    private void CloseManualSearch() {
        _isManualSearchOpen = false;
        _manualSearchMessage = null;
        _manualSearchResults = [];
    }

    private async Task SearchMedicationAsync() {
        if (_isManualSearchBusy) {
            return;
        }

        if (string.IsNullOrWhiteSpace(_manualSearchQuery)) {
            _manualSearchMessage = "Sisesta ravimi nimi.";
            _manualSearchResults = [];
            return;
        }

        _isManualSearchBusy = true;
        _manualSearchMessage = null;
        _manualSearchResults = [];

        try {
            _manualSearchResults = await ScannerFlowService.SearchByNameAsync(_manualSearchQuery,20);
            if (_manualSearchResults.Count == 0) {
                _manualSearchMessage = "Vastavaid ravimeid ei leitud.";
            }
        } catch {
            _manualSearchMessage = "Otsing ebaõnnestus.";
        } finally {
            _isManualSearchBusy = false;
        }
    }

    private Task SelectManualSearchResultAsync(MedicationLookupResult medication) {
        ApplyMedicationCheckResult(medication);
        CloseManualSearch();
        return Task.CompletedTask;
    }

    private sealed record DoseEntry(TimeOnly Time,string DisplayName,UserMedicationDto Source,DoseStatusEnum Status);
    private sealed record StatusView(string Label,string CssClass,string Detail);
}