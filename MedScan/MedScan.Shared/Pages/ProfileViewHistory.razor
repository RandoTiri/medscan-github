@page "/profile/view/{ProfileId:int}/history"
@using MedScan.Shared.DTOs.Medication
@using MedScan.Shared.Models.Enums
@using MedScan.Shared.Services
@inject IAuthService AuthService
@inject IMedicationService MedicationService
@inject NavigationManager Navigation

<PageTitle>Manustamise logi</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else
{
    <div class="history-page">
        <div class="history-content">
            <div class="history-header">
                <button class="back-link" @onclick="GoBack">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                    Tagasi
                </button>
                <h1>Manustamise logi</h1>
                <span class="header-spacer"></span>
            </div>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="error-box">@_errorMessage</div>
            }

            <section class="filter-card">
                <label>Kuupäev</label>
                <div class="birthdate-picker">
                    <div class="birth-field">
                        <label>Päev</label>
                        <select class="birth-select" @bind="_selectedDay" @bind:after="OnDateChangedAsync">
                            @foreach (var day in _days)
                            {
                                <option value="@day">@day</option>
                            }
                        </select>
                    </div>

                    <div class="birth-field">
                        <label>Kuu</label>
                        <select class="birth-select" @bind="_selectedMonth" @bind:after="OnDateChangedAsync">
                            @foreach (var month in _months)
                            {
                                <option value="@month">@month</option>
                            }
                        </select>
                    </div>

                    <div class="birth-field">
                        <label>Aasta</label>
                        <select class="birth-select" @bind="_selectedYear" @bind:after="OnDateChangedAsync">
                            @foreach (var year in _years)
                            {
                                <option value="@year">@year</option>
                            }
                        </select>
                    </div>
                </div>
            </section>

            @if (_historyItems.Count == 0)
            {
                <div class="empty-box">Selle kuupäeva kohta manustamise kirjeid ei leitud.</div>
            }
            else
            {
                <section class="history-list">
                    @foreach (var item in _historyItems)
                    {
                        <article class="history-card">
                            <div class="history-title-row">
                                <div>
                                    <h2>@item.DisplayName</h2>
                                    <p>@item.ScheduleText</p>
                                </div>
                                <span class="status-pill @item.StatusCss">@item.StatusLabel</span>
                            </div>
                        </article>
                    }
                </section>
            }
        </div>
    </div>
}



@code {
    [Parameter] public int ProfileId { get; set; }

    private bool _isReady;
    private string? _errorMessage;
    private readonly List<int> _days = Enumerable.Range(1, 31).ToList();
    private readonly List<int> _months = Enumerable.Range(1, 12).ToList();
    private readonly List<int> _years = Enumerable.Range(1900, DateTime.Today.Year - 1900 + 1).Reverse().ToList();
    private int _selectedDay = DateTime.Today.Day;
    private int _selectedMonth = DateTime.Today.Month;
    private int _selectedYear = DateTime.Today.Year;
    private readonly List<HistoryItem> _historyItems = [];

    protected override async Task OnParametersSetAsync()
    {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
        await LoadHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        _errorMessage = null;
        _historyItems.Clear();

        try
        {
            var selectedDate = new DateOnly(_selectedYear, _selectedMonth, _selectedDay);
            var history = await MedicationService.GetHistoryAsync(ProfileId, selectedDate);

            _historyItems.AddRange(history
                .Select(entry =>
                {
                    var localTime = entry.ScheduledTime.ToLocalTime();
                    return new HistoryItem(
                        DisplayName: BuildDisplayName(entry.MedicationName, entry.Strength),
                        ScheduleText: $"{selectedDate:dd.MM.yyyy} · {localTime:HH:mm}",
                        StatusLabel: entry.Status == DoseStatusEnum.Done ? "Võetud" : "Võtmata",
                        StatusCss: entry.Status == DoseStatusEnum.Done ? "status-done" : "status-missed",
                        SortKey: localTime.TimeOfDay);
                })
                .OrderBy(item => item.SortKey)
                .ThenBy(item => item.DisplayName));
        }
        catch
        {
            _errorMessage = "Manustamise logi laadimine ebaõnnestus.";
        }
    }

    private static string BuildDisplayName(string medicationName, string? strength)
    {
        if (string.IsNullOrWhiteSpace(strength) || medicationName.Contains(strength, StringComparison.OrdinalIgnoreCase))
        {
            return medicationName;
        }

        return $"{medicationName} {strength}";
    }

    private void GoBack()
    {
        Navigation.NavigateTo($"/profile/view/{ProfileId}");
    }

    private Task OnDateChangedAsync()
    {
        var maxDay = DateTime.DaysInMonth(_selectedYear, _selectedMonth);
        if (_selectedDay > maxDay)
        {
            _selectedDay = maxDay;
        }

        return LoadHistoryAsync();
    }

    private sealed record HistoryItem(
        string DisplayName,
        string ScheduleText,
        string StatusLabel,
        string StatusCss,
        TimeSpan SortKey);
}



