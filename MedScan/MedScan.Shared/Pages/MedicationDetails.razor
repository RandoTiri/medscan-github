@page "/home-pharmacy/details/{Id:int}"
@using MedScan.Shared.DTOs.Medication
@using MedScan.Shared.DTOs.HomePharmacy
@using MedScan.Shared.Models.Enums
@using MedScan.Shared.Services
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject IHomePharmacyService HomePharmacyService
@inject IMedicationService MedicationService

<PageTitle>Ravimi detail</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else if (_isLoading)
{
    <p><em>Laen ravimi andmeid...</em></p>
}
else if (_item is null)
{
    <p><em>Ravimit ei leitud.</em></p>
}
else
{
    <div class="medicine-screen">
        <div class="medicine-header">
            <button class="back-link" @onclick="BackToList">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Tagasi
            </button>
            <h1>Ravimi info</h1>
            <span class="header-spacer"></span>
        </div>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="error-box">@_errorMessage</div>
        }
        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="success-box">@_message</div>
        }

        <div class="content-scroll">
            <div class="section-card medication-card">
                <div class="field-title">Ravim</div>
                <div class="medication-name-box">
                    <span class="medication-name">@_item.MedicationName</span>
                </div>
            </div>

            <div class="info-card">
                <div class="card-title">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#267863" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                        <polyline points="9 12 11 14 15 10"></polyline>
                    </svg>
                    Põhiinfo
                </div>
                <div class="info-row">
                    <span class="label">Toimeaine</span>
                    <span class="val">@(_item.ActiveIngredient ?? "-")</span>
                </div>
                <div class="info-row">
                    <span class="label">Ravimivorm</span>
                    <span class="val">@(_item.MedicationForm ?? "-")</span>
                </div>
                <div class="info-row">
                    <span class="label">Tugevus</span>
                    <span class="val">@(_item.Strength ?? "-")</span>
                </div>
                <div class="info-row">
                    <span class="label">Pakendi kogus</span>
                    <span class="val">@FormatPackSize(_item.PackSize)</span>
                </div>
                <div class="info-row">
                    <span class="label">Näidustus</span>
                    <span class="val">@(_item.Indication ?? "-")</span>
                </div>
                <div class="info-row">
                    <span class="label">Säilimisaeg</span>
                    <span class="val">@ShelfLifeDisplay</span>
                </div>
                <div class="info-row quantity-edit-row">
                    <span class="label">Alles (tk)</span>
                    <div class="quantity-edit-controls">
                        <select class="quantity-select" @bind="_editableQuantity">
                            @for (var qty = 1; qty <= 100; qty++)
                            {
                                <option value="@qty">@qty</option>
                            }
                        </select>
                        <button class="quantity-save-btn" @onclick="SaveQuantityAsync" disabled="@(_isSaving || _item is null || _editableQuantity == _item.Quantity)">Salvesta</button>
                    </div>
                </div>
            </div>

            @if (!_hasSchedule && !_isAddingSchedule)
            {
                <div class="info-card">
                    <div class="card-title">Märkused</div>
                    <textarea id="medication-notes" class="notes-area" @bind="_editableNotes" placeholder="Lisa märkused..."></textarea>
                    @if (!NotesUnchanged)
                    {
                        <button class="save-schedule-btn" @onclick="SaveNotesAsync" disabled="@(_isSaving || _item is null)">
                            @(_isSaving ? "Salvestan..." : "Salvesta")
                        </button>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_item.Warnings))
            {
                <div class="warnings-card">
                    <div class="card-title warning-title">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                            <line x1="12" y1="9" x2="12" y2="13"></line>
                            <line x1="12" y1="17" x2="12.01" y2="17"></line>
                        </svg>
                        Hoiatused
                    </div>
                    <div class="warning-list">
                        @foreach (var warning in _item.Warnings.Split(new[] { '\n', ';' }, StringSplitOptions.RemoveEmptyEntries))
                        {
                            <div class="warning-item">
                                <span class="warning-icon">⚠</span>
                                <span>@warning.Trim()</span>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (_hasSchedule || _isAddingSchedule)
            {
                <div class="schedule-card">
                    <div class="card-title">Manustamine</div>

                    <div class="section-title">Manustamissagedus</div>
                    <div class="frequency-grid">
                        @foreach (var option in _frequencyOptions)
                        {
                            var active = _frequencyPerDay == option;
                            <button class="frequency-btn @(active ? "active" : null)" @onclick="() => SetFrequency(option)">@option x</button>
                        }
                    </div>
                    <div class="frequency-meta">
                        <select class="period-select" value="@_scheduleUnit" @onchange="OnScheduleUnitChanged">
                            <option value="@MedicationScheduleUnit.Day">päevas</option>
                            <option value="@MedicationScheduleUnit.Week">nädalas</option>
                            <option value="@MedicationScheduleUnit.Month">kuus</option>
                        </select>
                    </div>

                    <div class="section-title time-title">Kellaajad</div>
                    @for (var i = 0; i < _scheduledTimeTexts.Count; i++)
                    {
                        var index = i;
                        <div class="time-row @(ShowWeeklyDaySelector ? "with-day" : "without-day")">
                            @if (ShowWeeklyDaySelector)
                            {
                                <select class="day-select" value="@GetWeeklyDayValue(index)" @onchange="args => OnWeeklyDayChanged(index, args)">
                                    @foreach (var day in _weekdayOptions)
                                    {
                                        <option value="@day.Value">@day.Label</option>
                                    }
                                </select>
                            }
                            <div class="time-controls">
                                <span class="clock-icon">◷</span>
                                <div class="time-wheel-box">
                                    <select class="time-wheel-part" value="@GetHourPart(index)" @onchange="args => OnHourChanged(index, args)">
                                        @for (var hour = 0; hour < 24; hour++)
                                        {
                                            var hourText = hour.ToString("D2");
                                            <option value="@hourText">@hourText</option>
                                        }
                                    </select>
                                </div>
                                <span class="time-separator">:</span>
                                <div class="time-wheel-box">
                                    <select class="time-wheel-part" value="@GetMinutePart(index)" @onchange="args => OnMinuteChanged(index, args)">
                                        @for (var minute = 0; minute < 60; minute++)
                                        {
                                            var minuteText = minute.ToString("D2");
                                            <option value="@minuteText">@minuteText</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="toggle-row">
                        <span>Meeldetuletus</span>
                        <label class="switch">
                            <input type="checkbox" checked="@_remindersEnabled" @onchange="OnRemindersChanged" />
                            <span class="slider"></span>
                        </label>
                    </div>

                    <label class="section-title" for="schedule-notes">Märkused (valikuline)</label>
                    <textarea id="schedule-notes" class="notes-area" @bind="_editableNotes" placeholder="Lisa märkused..."></textarea>

                    @if (_isAddingSchedule || _scheduleDirty || !NotesUnchanged)
                    {
                        <button class="save-schedule-btn" @onclick="SaveScheduleAsync" disabled="@_isSaving">
                            @(_isSaving ? "Salvestan..." : "Salvesta")
                        </button>
                    }

                    <button class="end-schedule-btn" @onclick="EndScheduleAsync" disabled="@_isSaving">
                        Lõpeta raviskeem
                    </button>
                </div>
            }
            else
            {
                <div class="schedule-card">
                    <div class="card-title">Manustamine</div>
                    <button class="add-schedule-btn" @onclick="StartAddSchedule">+ Lisa raviskeemi</button>
                    <button type="button" class="add-schedule-btn one-time-in-card-btn" @onclick="OpenTakeOnceModal" disabled="@_isSaving">
                        Märgi ühekordselt võetuks
                    </button>
                </div>
            }

            <button class="action-pdf" @onclick="OpenPdfAsync" disabled="@_isSaving">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
                Ametlik infoleht (PDF)
            </button>

            <button class="delete-med-btn" @onclick="DeleteMedicationAsync" disabled="@_isSaving">
                Kustuta ravim
            </button>
        </div>

        @if (_showTakeOnceModal)
        {
            <div class="modal-backdrop" @onclick="CloseTakeOnceModal">
                <div class="take-once-modal" @onclick:stopPropagation="true">
                    <h3>Kinnita võtmine</h3>
                    <p>
                        @if (_item?.Quantity == 1)
                        {
                            <text>See on viimane ühik. Võtmisega jätkates pead uue paki ostma.</text>
                        }
                        else
                        {
                            <text>Kas oled kindel, et võtsid selle ravimi praegu? Salvestame selle logisse ilma meeldetuletuseta.</text>
                        }
                    </p>
                    <div class="take-once-actions">
                        <button type="button" class="confirm-btn" @onclick="ConfirmTakeOnceAsync" disabled="@_isSaving">Jah</button>
                        <button type="button" class="cancel-btn" @onclick="CloseTakeOnceModal" disabled="@_isSaving">Ei</button>
                    </div>
                </div>
            </div>
        }
    </div>
}



@code {
    [Parameter] public int Id { get; set; }

    private static readonly int[] _frequencyOptions = [1, 2, 3, 4];
    private static readonly (int Value, string Label)[] _weekdayOptions =
    [
        ((int)DayOfWeek.Monday, "Esmaspäev"),
        ((int)DayOfWeek.Tuesday, "Teisipäev"),
        ((int)DayOfWeek.Wednesday, "Kolmapäev"),
        ((int)DayOfWeek.Thursday, "Neljapäev"),
        ((int)DayOfWeek.Friday, "Reede"),
        ((int)DayOfWeek.Saturday, "Laupäev"),
        ((int)DayOfWeek.Sunday, "Pühapäev")
    ];

    private bool _isReady;
    private bool _isLoading;
    private bool _isSaving;
    private bool _showTakeOnceModal;
    private string? _message;
    private string? _errorMessage;
    private HomePharmacyItemDto? _item;
    private UserMedicationDto? _schedule;
    private bool _hasSchedule;
    private bool _isAddingSchedule;
    private int _editableQuantity = 1;
    private string? _editableNotes;

    private int _frequencyPerDay = 1;
    private MedicationScheduleUnit _scheduleUnit = MedicationScheduleUnit.Day;
    private List<string> _scheduledTimeTexts = ["08:00"];
    private List<int> _weeklyDays = [];
    private bool _remindersEnabled = true;
    private string? _scheduleNotes;

    private int _originalFrequency = 1;
    private MedicationScheduleUnit _originalScheduleUnit = MedicationScheduleUnit.Day;
    private List<string> _originalTimes = ["08:00"];
    private List<int> _originalWeeklyDays = [];
    private bool _originalReminders = true;
    private string? _originalNotes;

    private bool _scheduleDirty =>
        _frequencyPerDay != _originalFrequency ||
        _scheduleUnit != _originalScheduleUnit ||
        _remindersEnabled != _originalReminders ||
        !_scheduledTimeTexts.SequenceEqual(_originalTimes) ||
        !_weeklyDays.SequenceEqual(_originalWeeklyDays) ||
        !string.Equals(_scheduleNotes?.Trim(), _originalNotes?.Trim(), StringComparison.Ordinal);

    private bool ShowWeeklyDaySelector => _scheduleUnit == MedicationScheduleUnit.Week && _frequencyPerDay > 1;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _message = null;
        _errorMessage = null;

        try
        {
            _item = await HomePharmacyService.GetByIdAsync(Id);
            if (_item is null)
            {
                _errorMessage = "Ravimit ei leitud.";
                return;
            }

            _editableQuantity = Math.Clamp(_item.Quantity, 1, 100);
            _editableNotes = _item.Notes;

            var schedules = await MedicationService.GetScheduleAsync(_item.ProfileId);
            _schedule = schedules.FirstOrDefault(x => x.MedicationId == _item.MedicationId && x.IsActive);
            _hasSchedule = _schedule is not null;

            if (_schedule is not null)
            {
                ApplySchedule(_schedule);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task EndScheduleAsync()
    {
        if (_isSaving || _schedule is null)
        {
            return;
        }

        _isSaving = true;
        _message = null;
        _errorMessage = null;

        try
        {
            var removed = await MedicationService.RemoveFromScheduleAsync(_schedule.Id);
            if (!removed)
            {
                _errorMessage = "Raviskeemi ei leitud.";
                return;
            }

            _schedule = null;
            _hasSchedule = false;
            _isAddingSchedule = false;
            _frequencyPerDay = 1;
            _scheduleUnit = MedicationScheduleUnit.Day;
            _scheduledTimeTexts = ["08:00"];
            _weeklyDays = [];
            _remindersEnabled = true;
            _scheduleNotes = null;
            _originalFrequency = _frequencyPerDay;
            _originalScheduleUnit = _scheduleUnit;
            _originalTimes = _scheduledTimeTexts.ToList();
            _originalWeeklyDays = _weeklyDays.ToList();
            _originalReminders = _remindersEnabled;
            _originalNotes = _scheduleNotes;
            _message = "Raviskeem lõpetatud.";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ApplySchedule(UserMedicationDto schedule)
    {
        _frequencyPerDay = Math.Clamp(schedule.FrequencyPerDay, 1, 4);
        _scheduleUnit = schedule.ScheduleUnit;
        _scheduledTimeTexts = schedule.ScheduledTimes.Count > 0
            ? schedule.ScheduledTimes.Select(t => t.ToString("HH:mm")).ToList()
            : ["08:00"];
        _weeklyDays = schedule.WeeklyDays.ToList();

        EnsureVisibleTimeCount();
        SyncWeeklyDays();

        _remindersEnabled = schedule.RemindersEnabled;
        _scheduleNotes = schedule.Notes;

        _originalFrequency = _frequencyPerDay;
        _originalScheduleUnit = _scheduleUnit;
        _originalTimes = _scheduledTimeTexts.ToList();
        _originalWeeklyDays = _weeklyDays.ToList();
        _originalReminders = _remindersEnabled;
        _originalNotes = _scheduleNotes;
    }

    private void SetFrequency(int frequency)
    {
        _frequencyPerDay = frequency;
        _scheduledTimeTexts = GetDefaultTimes(GetVisibleTimeCount());
        SyncWeeklyDays();
    }

    private void OnScheduleUnitChanged(ChangeEventArgs args)
    {
        if (!Enum.TryParse<MedicationScheduleUnit>(args.Value?.ToString(), out var parsed))
        {
            parsed = MedicationScheduleUnit.Day;
        }

        _scheduleUnit = parsed;
        EnsureVisibleTimeCount();
        SyncWeeklyDays();
    }

    private int GetVisibleTimeCount()
    {
        return _scheduleUnit == MedicationScheduleUnit.Month ? 1 : _frequencyPerDay;
    }

    private void EnsureVisibleTimeCount()
    {
        var targetTimeCount = GetVisibleTimeCount();
        var defaults = GetDefaultTimes(Math.Max(_frequencyPerDay, targetTimeCount));

        while (_scheduledTimeTexts.Count < targetTimeCount)
        {
            _scheduledTimeTexts.Add(defaults[_scheduledTimeTexts.Count]);
        }

        while (_scheduledTimeTexts.Count > targetTimeCount)
        {
            _scheduledTimeTexts.RemoveAt(_scheduledTimeTexts.Count - 1);
        }
    }

    private static List<string> GetDefaultTimes(int frequency)
    {
        return frequency switch
        {
            1 => ["08:00"],
            2 => ["08:00", "20:00"],
            3 => ["08:00", "14:00", "20:00"],
            4 => ["08:00", "12:00", "16:00", "20:00"],
            _ => ["08:00"]
        };
    }

    private void SyncWeeklyDays()
    {
        if (!ShowWeeklyDaySelector)
        {
            _weeklyDays = [];
            return;
        }

        var defaults = GetDefaultWeeklyDays(_frequencyPerDay);
        if (_weeklyDays.Count > _frequencyPerDay)
        {
            _weeklyDays = _weeklyDays.Take(_frequencyPerDay).ToList();
        }

        while (_weeklyDays.Count < _frequencyPerDay)
        {
            _weeklyDays.Add(defaults[_weeklyDays.Count]);
        }

        ReorderWeeklyPairs();
    }

    private static List<int> GetDefaultWeeklyDays(int frequency)
    {
        var mondayBasedDays = new[]
        {
            (int)DayOfWeek.Monday,
            (int)DayOfWeek.Tuesday,
            (int)DayOfWeek.Wednesday,
            (int)DayOfWeek.Thursday,
            (int)DayOfWeek.Friday,
            (int)DayOfWeek.Saturday,
            (int)DayOfWeek.Sunday
        };

        return mondayBasedDays.Take(frequency).ToList();
    }

    private string GetWeeklyDayValue(int index)
    {
        return index < _weeklyDays.Count
            ? _weeklyDays[index].ToString()
            : ((int)DayOfWeek.Monday).ToString();
    }

    private void OnWeeklyDayChanged(int index, ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var parsedDay))
        {
            return;
        }

        while (_weeklyDays.Count <= index)
        {
            _weeklyDays.Add((int)DayOfWeek.Monday);
        }

        _weeklyDays[index] = parsedDay;
        ReorderWeeklyPairs();
    }

    private void ReorderWeeklyPairs()
    {
        if (!ShowWeeklyDaySelector || _weeklyDays.Count != _scheduledTimeTexts.Count)
        {
            return;
        }

        var orderedPairs = _weeklyDays
            .Select((day, index) => new { Day = day, Time = _scheduledTimeTexts[index], Index = index })
            .OrderBy(pair => GetWeekdayOrder(pair.Day))
            .ThenBy(pair => pair.Index)
            .ToList();

        _weeklyDays = orderedPairs.Select(pair => pair.Day).ToList();
        _scheduledTimeTexts = orderedPairs.Select(pair => pair.Time).ToList();
    }

    private static int GetWeekdayOrder(int day)
    {
        return day == (int)DayOfWeek.Sunday ? 6 : day - 1;
    }

    private void OnHourChanged(int index, ChangeEventArgs args)
    {
        var hour = args.Value?.ToString() ?? "00";
        var minute = GetMinutePart(index);
        _scheduledTimeTexts[index] = $"{hour}:{minute}";
    }

    private void OnMinuteChanged(int index, ChangeEventArgs args)
    {
        var hour = GetHourPart(index);
        var minute = args.Value?.ToString() ?? "00";
        _scheduledTimeTexts[index] = $"{hour}:{minute}";
    }

    private string GetHourPart(int index)
    {
        var value = _scheduledTimeTexts[index];
        return value.Length >= 2 ? value[..2] : "00";
    }

    private string GetMinutePart(int index)
    {
        var value = _scheduledTimeTexts[index];
        return value.Length >= 5 ? value.Substring(3, 2) : "00";
    }

    private void OnRemindersChanged(ChangeEventArgs args)
    {
        _remindersEnabled = args.Value is bool value && value;
    }

    private async Task SaveScheduleAsync()
    {
        if (_isSaving || _item is null)
        {
            return;
        }

        var times = new List<TimeOnly>();
        foreach (var text in _scheduledTimeTexts)
        {
            if (!TimeOnly.TryParse(text, out var parsed))
            {
                _errorMessage = "Sisesta kõik kellaajad korrektselt.";
                return;
            }

            times.Add(parsed);
        }

        var expectedTimeCount = GetVisibleTimeCount();
        if (times.Count != expectedTimeCount)
        {
            _errorMessage = "Kellaaegade arv peab vastama manustamissagedusele.";
            return;
        }

        if (ShowWeeklyDaySelector)
        {
            if (_weeklyDays.Count != _frequencyPerDay)
            {
                _errorMessage = "Vali igale nädalasele korrale päev.";
                return;
            }

            if (_weeklyDays.Distinct().Count() != _weeklyDays.Count)
            {
                _errorMessage = "Vali igale nädalasele korrale erinev päev.";
                return;
            }
        }

        _isSaving = true;
        _message = null;
        _errorMessage = null;

        try
        {
            if (_schedule is null)
            {
                var created = await MedicationService.AddToScheduleAsync(new AddMedicationDto
                {
                    ProfileId = _item.ProfileId,
                    MedicationId = _item.MedicationId,
                    FrequencyPerDay = _frequencyPerDay,
                    ScheduleUnit = _scheduleUnit,
                    ScheduledTimes = times.ToList(),
                    WeeklyDays = _weeklyDays.ToList(),
                    StartDate = DateOnly.FromDateTime(DateTime.Now),
                    RemindersEnabled = _remindersEnabled,
                    Notes = NormalizeNotes(_editableNotes)
                });

                var updatedItem = await SaveMedicationNotesAsync();
                if (updatedItem is null)
                {
                    _errorMessage = "Ravimi märkuste uuendamine ebaõnnestus.";
                    return;
                }

                _schedule = created;
                _item = updatedItem;
                _hasSchedule = true;
                _isAddingSchedule = false;
                _editableNotes = updatedItem.Notes;
                ApplySchedule(created);
                _message = "Raviskeem salvestatud.";
                return;
            }

            var updated = await MedicationService.UpdateScheduleAsync(_schedule.Id, new AddMedicationDto
            {
                ProfileId = _item.ProfileId,
                MedicationId = _item.MedicationId,
                FrequencyPerDay = _frequencyPerDay,
                ScheduleUnit = _scheduleUnit,
                ScheduledTimes = times.ToList(),
                WeeklyDays = _weeklyDays.ToList(),
                StartDate = _schedule.StartDate,
                RemindersEnabled = _remindersEnabled,
                Notes = NormalizeNotes(_editableNotes)
            });

            if (updated is null)
            {
                _errorMessage = "Raviskeemi ei leitud.";
                return;
            }

            var updatedItemAfterSchedule = await SaveMedicationNotesAsync();
            if (updatedItemAfterSchedule is null)
            {
                _errorMessage = "Ravimi märkuste uuendamine ebaõnnestus.";
                return;
            }

            _schedule = updated;
            _item = updatedItemAfterSchedule;
            _editableNotes = updatedItemAfterSchedule.Notes;
            ApplySchedule(updated);
            _message = "Raviskeem salvestatud.";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void StartAddSchedule()
    {
        if (_item is null)
        {
            return;
        }

        _isAddingSchedule = true;
        _hasSchedule = false;
        _schedule = null;
        _frequencyPerDay = 1;
        _scheduleUnit = MedicationScheduleUnit.Day;
        _scheduledTimeTexts = ["08:00"];
        _weeklyDays = [];
        _remindersEnabled = true;
        _originalFrequency = _frequencyPerDay;
        _originalScheduleUnit = _scheduleUnit;
        _originalTimes = _scheduledTimeTexts.ToList();
        _originalWeeklyDays = _weeklyDays.ToList();
        _originalReminders = _remindersEnabled;
        _scheduleNotes = null;
        _originalNotes = null;
        _message = null;
        _errorMessage = null;
    }

    private async Task DeleteMedicationAsync()
    {
        if (_isSaving || _item is null)
        {
            return;
        }

        _isSaving = true;
        _message = null;
        _errorMessage = null;

        try
        {
            var removed = await HomePharmacyService.RemoveAsync(_item.Id);
            if (!removed)
            {
                _errorMessage = "Ravimit ei leitud.";
                return;
            }

            Navigation.NavigateTo($"/home-pharmacy?profileId={_item.ProfileId}");
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task SaveQuantityAsync()
    {
        if (_isSaving || _item is null || _editableQuantity == _item.Quantity)
        {
            return;
        }

        _isSaving = true;
        _message = null;
        _errorMessage = null;

        try
        {
            var updated = await HomePharmacyService.UpdateAsync(_item.Id, new UpdateHomePharmacyItemDto
            {
                PackageNumber = _item.PackageNumber,
                BatchNumber = _item.BatchNumber,
                ExpiresOn = _item.ExpiresOn,
                Quantity = _editableQuantity,
                Notes = NormalizeNotes(_editableNotes)
            });

            if (updated is null)
            {
                _errorMessage = "Ravimi koguse uuendamine ebaõnnestus.";
                return;
            }

            _item = updated;
            _editableQuantity = Math.Clamp(updated.Quantity, 1, 100);
            _editableNotes = updated.Notes;
            _message = "Ravimi kogus uuendatud.";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void OpenTakeOnceModal()
    {
        if (_isSaving || _item is null)
        {
            return;
        }

        _message = null;
        _errorMessage = null;
        _showTakeOnceModal = true;
    }

    private void CloseTakeOnceModal()
    {
        if (_isSaving)
        {
            return;
        }

        _showTakeOnceModal = false;
    }

    private async Task ConfirmTakeOnceAsync()
    {
        if (_isSaving || _item is null)
        {
            return;
        }

        _isSaving = true;
        _message = null;
        _errorMessage = null;

        try
        {
            var result = await MedicationService.TakeOnceAsync(_item.MedicationId, new TakeMedicationOnceDto
            {
                ProfileId = _item.ProfileId,
                Quantity = 1,
                Notes = NormalizeNotes(_editableNotes),
                ConfirmLastUnit = true
            });

            if (!result.Success)
            {
                _errorMessage = string.IsNullOrWhiteSpace(result.Message)
                    ? "Ühekordse võtmise salvestamine ebaõnnestus."
                    : result.Message;
                return;
            }

            _message = result.Message;
            _showTakeOnceModal = false;

            if (result.RemovedFromHomePharmacy || result.RemainingQuantity == 0)
            {
                Navigation.NavigateTo($"/home-pharmacy?profileId={_item.ProfileId}");
                return;
            }

            await LoadAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private bool NotesUnchanged => string.Equals(NormalizeNotes(_editableNotes), NormalizeNotes(_item?.Notes), StringComparison.Ordinal);

    private async Task SaveNotesAsync()
    {
        if (_isSaving || _item is null || NotesUnchanged)
        {
            return;
        }

        _isSaving = true;
        _message = null;
        _errorMessage = null;

        try
        {
            var updated = await SaveMedicationNotesAsync();
            if (updated is null)
            {
                _errorMessage = "Ravimi märkuste uuendamine ebaõnnestus.";
                return;
            }

            _item = updated;
            _editableNotes = updated.Notes;
            _editableQuantity = Math.Clamp(updated.Quantity, 1, 100);
            _message = "Ravimi märkused uuendatud.";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void BackToList()
    {
        Navigation.NavigateTo($"/home-pharmacy?profileId={_item?.ProfileId}");
    }

    private string ShelfLifeDisplay => _item?.ExpiresOn?.ToString("dd.MM.yyyy")
        ?? "Puudub";

    private void OpenPdfAsync()
    {
        if (_item is null || string.IsNullOrWhiteSpace(_item.PdfUrl))
        {
            _errorMessage = "Ametlik infoleht puudub.";
            return;
        }

        Navigation.NavigateTo(_item.PdfUrl, true);
    }

    private static string FormatPackSize(string? packSize)
    {
        if (string.IsNullOrWhiteSpace(packSize))
        {
            return "-";
        }

        var digits = new string(packSize.Where(char.IsDigit).ToArray());
        return string.IsNullOrWhiteSpace(digits) ? packSize.Trim() : digits;
    }

    private async Task<HomePharmacyItemDto?> SaveMedicationNotesAsync()
    {
        if (_item is null)
        {
            return null;
        }

        return await HomePharmacyService.UpdateAsync(_item.Id, new UpdateHomePharmacyItemDto
        {
            PackageNumber = _item.PackageNumber,
            BatchNumber = _item.BatchNumber,
            ExpiresOn = _item.ExpiresOn,
            Quantity = _item.Quantity,
            Notes = NormalizeNotes(_editableNotes)
        });
    }

    private static string? NormalizeNotes(string? notes)
    {
        return string.IsNullOrWhiteSpace(notes) ? null : notes.Trim();
    }
}

