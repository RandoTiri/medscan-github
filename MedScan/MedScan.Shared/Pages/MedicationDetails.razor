    private static string FormatPackSize(string? packSize)
    {
        if (string.IsNullOrWhiteSpace(packSize))
        {
            return "-";
        }

        var digits = new string(packSize.Where(char.IsDigit).ToArray());
        return string.IsNullOrWhiteSpace(digits) ? packSize.Trim() : digits;
    }

    private async Task<HomePharmacyItemDto?> SaveMedicationNotesAsync()
    {
        if (_item is null)
        {
            return null;
        }

        return await HomePharmacyService.UpdateAsync(_item.Id, new UpdateHomePharmacyItemDto
        {
            PackageNumber = _item.PackageNumber,
            BatchNumber = _item.BatchNumber,
            ExpiresOn = _item.ExpiresOn,
            Quantity = _item.Quantity,
            Notes = NormalizeNotes(_editableNotes)
        });
    }

    private static string? NormalizeNotes(string? notes)
    {
        return string.IsNullOrWhiteSpace(notes) ? null : notes.Trim();
    }
