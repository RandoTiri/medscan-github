        if (_isSaving || _item is null)
        {
            return;
        }

        _message = null;
        _errorMessage = null;
        _showTakeOnceModal = true;
    }

    private void CloseTakeOnceModal()
    {
        if (_isSaving)
        {
            return;
        }

        _showTakeOnceModal = false;
    }

    private async Task ConfirmTakeOnceAsync()
    {
        if (_isSaving || _item is null)
        {
            return;
        }

        _isSaving = true;
        _message = null;
        _errorMessage = null;

        try
        {
            var result = await MedicationService.TakeOnceAsync(_item.MedicationId, new TakeMedicationOnceDto
            {
                ProfileId = _item.ProfileId,
                Quantity = 1,
                Notes = NormalizeNotes(_editableNotes),
                ConfirmLastUnit = true
            });

            if (!result.Success)
            {
                _errorMessage = string.IsNullOrWhiteSpace(result.Message)
                    ? "Ühekordse võtmise salvestamine ebaõnnestus."
                    : result.Message;
                return;
            }

            _message = result.Message;
            _showTakeOnceModal = false;

            if (result.RemovedFromHomePharmacy || result.RemainingQuantity == 0)
            {
                Navigation.NavigateTo($"/home-pharmacy?profileId={_item.ProfileId}");
                return;
            }

            await LoadAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private bool NotesUnchanged => string.Equals(NormalizeNotes(_editableNotes), NormalizeNotes(_item?.Notes), StringComparison.Ordinal);

    private async Task SaveNotesAsync()
    {
        if (_isSaving || _item is null || NotesUnchanged)
        {
            return;
        }

        _isSaving = true;
        _message = null;
        _errorMessage = null;

        try
        {
            var updated = await SaveMedicationNotesAsync();
            if (updated is null)
            {
                _errorMessage = "Ravimi märkuste uuendamine ebaõnnestus.";
                return;
            }

            _item = updated;
            _editableNotes = updated.Notes;
            _editableQuantity = Math.Clamp(updated.Quantity, 1, 100);
            _message = "Ravimi märkused uuendatud.";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

