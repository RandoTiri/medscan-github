@page "/settings/main-profile/{ProfileId:int}"
@using MedScan.Shared.Models
@using MedScan.Shared.Services
@inject IAuthService AuthService
@inject IProfileService ProfileService
@inject NavigationManager Navigation

<PageTitle>Põhikasutaja seaded</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else if (_profile is null)
{
    <div class="main-profile-page">
        <div class="main-profile-content">
            <button class="back-link" @onclick="GoBack">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Tagasi
            </button>
            <div class="error-box">Põhiprofiili ei leitud.</div>
        </div>
    </div>
}
else
{
    <div class="main-profile-page">
        <div class="main-profile-content">
            <button class="back-link" @onclick="GoBack">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Tagasi
            </button>

            <section class="profile-summary-card">
                <div class="profile-avatar">@_profile.Initials</div>
                <div class="profile-main-info">
                    <h1>@_profile.Name</h1>
                    <p>@GetProfileDetails(_profile)</p>
                </div>
            </section>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="error-box">@_errorMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(_successMessage))
            {
                <div class="success-box">@_successMessage</div>
            }

            <section class="settings-actions-panel">
                <section class="crud-panel">
                    <button class="crud-toggle" @onclick="ToggleEdit">
                        Muuda kasutaja andmeid
                    </button>
                </section>

                <section class="crud-panel">
                    <button class="crud-toggle" @onclick="TogglePasswordForm">
                        Muuda parooli
                    </button>
                </section>

                <button class="delete-btn main-profile-delete" @onclick="PromptDeleteAccount">Kustuta kasutaja</button>
            </section>

            @if (_isEditing)
            {
                <div class="confirm-overlay" @onclick="CloseEdit">
                    <div class="edit-dialog" @onclick:stopPropagation="true">
                        <div class="auth-input-group">
                            <label for="edit-name">Nimi</label>
                            <div class="input-wrapper">
                                <div class="input-icon">
                                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                        <circle cx="12" cy="7" r="4"></circle>
                                    </svg>
                                </div>
                                <input id="edit-name" type="text" @bind="_editModel.Name" />
                            </div>
                        </div>

                        <div class="auth-input-group">
                            <label for="edit-gender">Sugu</label>
                            <div class="input-wrapper">
                                <div class="input-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-gender-ambiguous" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M11.5 1a.5.5 0 0 1 0-1h4a.5.5 0 0 1 .5.5v4a.5.5 0 0 1-1 0V1.707l-3.45 3.45A4 4 0 0 1 8.5 10.97V13H10a.5.5 0 0 1 0 1H8.5v1.5a.5.5 0 0 1-1 0V14H6a.5.5 0 0 1 0-1h1.5v-2.03a4 4 0 1 1 3.471-6.648L14.293 1H11.5zm-.997 4.046a3 3 0 1 0-5.006 3.09 3 3 0 0 0 5.006-3.09z"/>
                                    </svg>
                                </div>
                                <select id="edit-gender" @bind="_editModel.Gender">
                                    <option value="Mees">Mees</option>
                                    <option value="Naine">Naine</option>
                                    <option value="Määramata">Määramata</option>
                                </select>
                            </div>
                        </div>

                        <div class="auth-input-group">
                            <label for="edit-birthdate">Sünnikuupäev</label>
                            <div id="edit-birthdate" class="birth-grid">
                                <select class="birth-select" @bind="_birthDay">
                                    <option value="">Päev</option>
                                    @foreach (var day in _days)
                                    {
                                        <option value="@day">@day</option>
                                    }
                                </select>

                                <select class="birth-select" @bind="_birthMonth">
                                    <option value="">Kuu</option>
                                    @foreach (var month in _months)
                                    {
                                        <option value="@month">@month</option>
                                    }
                                </select>

                                <select class="birth-select" @bind="_birthYear">
                                    <option value="">Aasta</option>
                                    @foreach (var year in _years)
                                    {
                                        <option value="@year">@year</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="edit-actions">
                            <button class="save-btn" @onclick="SaveProfileAsync">Salvesta</button>
                            <button class="cancel-btn" @onclick="CloseEdit">Sulge</button>
                        </div>
                    </div>
                </div>
            }

            @if (_isChangingPassword)
            {
                <div class="confirm-overlay" @onclick="ClosePasswordForm">
                    <div class="edit-dialog" @onclick:stopPropagation="true">
                        <div class="auth-input-group">
                            <label for="current-password">Praegune parool</label>
                            <div class="input-wrapper">
                                <div class="input-icon">
                                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                    </svg>
                                </div>
                                <input id="current-password" type="password" @bind="_currentPassword" />
                            </div>
                        </div>

                        <div class="auth-input-group">
                            <label for="new-password">Uus parool</label>
                            <div class="input-wrapper">
                                <div class="input-icon">
                                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                    </svg>
                                </div>
                                <input id="new-password" type="password" @bind="_newPassword" />
                            </div>
                        </div>

                        <div class="auth-input-group">
                            <label for="confirm-password">Korda uut parooli</label>
                            <div class="input-wrapper">
                                <div class="input-icon">
                                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                    </svg>
                                </div>
                                <input id="confirm-password" type="password" @bind="_confirmNewPassword" />
                            </div>
                        </div>

                        <div class="edit-actions">
                            <button class="save-btn" @onclick="ChangePasswordAsync">Salvesta</button>
                            <button class="cancel-btn" @onclick="ClosePasswordForm">Sulge</button>
                        </div>
                    </div>
                </div>
            }

            @if (_showDeleteConfirm)
            {
                <div class="confirm-overlay">
                    <div class="confirm-dialog">
                        <p>Kas soovite kasutaja ära kustutada?</p>
                        <div class="confirm-actions">
                            <button class="confirm-yes" @onclick="ConfirmDeleteAccountAsync">Jah</button>
                            <button class="confirm-no" @onclick="CancelDeleteAccount">Ei</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}



@code {
    [Parameter] public int ProfileId { get; set; }

    private bool _isReady;
    private bool _isEditing;
    private bool _isChangingPassword;
    private bool _showDeleteConfirm;
    private string? _errorMessage;
    private string? _successMessage;
    private Patient? _profile;
    private readonly List<int> _days = Enumerable.Range(1, 31).ToList();
    private readonly List<int> _months = Enumerable.Range(1, 12).ToList();
    private readonly List<int> _years = Enumerable.Range(1900, DateTime.Today.Year - 1900 + 1).Reverse().ToList();
    private string _birthDay = string.Empty;
    private string _birthMonth = string.Empty;
    private string _birthYear = string.Empty;
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmNewPassword = string.Empty;
    private CreatePatientProfileRequest _editModel = new();

    protected override async Task OnParametersSetAsync()
    {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isReady = false;
        _errorMessage = null;

        try
        {
            var profile = await ProfileService.GetByIdAsync(ProfileId);
            if (profile is null)
            {
                _profile = null;
                return;
            }

            _profile = new Patient
            {
                Id = profile.Id,
                Name = profile.Name,
                Gender = string.IsNullOrWhiteSpace(profile.Gender) ? "Määramata" : profile.Gender,
                BirthDate = profile.BirthDate
            };

            _editModel = new CreatePatientProfileRequest
            {
                Name = _profile.Name,
                Gender = _profile.Gender,
                BirthDate = _profile.BirthDate
            };
        }
        catch
        {
            _errorMessage = "Profiili laadimine ebaõnnestus.";
        }
        finally
        {
            _isReady = true;
        }
    }

    private static string GetProfileDetails(Patient patient)
    {
        var age = patient.Age > 0 ? $"{patient.Age} a" : "Vanus puudub";
        var gender = string.IsNullOrWhiteSpace(patient.Gender) ? "Määramata" : patient.Gender;
        return $"{age} · {gender}";
    }

    private void ToggleEdit()
    {
        _isEditing = !_isEditing;
        _errorMessage = null;
        _successMessage = null;

        if (_isEditing && _profile is not null)
        {
            _isChangingPassword = false;
            _currentPassword = string.Empty;
            _newPassword = string.Empty;
            _confirmNewPassword = string.Empty;

            _editModel = new CreatePatientProfileRequest
            {
                Name = _profile.Name,
                Gender = _profile.Gender,
                BirthDate = _profile.BirthDate
            };

            if (_editModel.BirthDate.HasValue)
            {
                _birthDay = _editModel.BirthDate.Value.Day.ToString();
                _birthMonth = _editModel.BirthDate.Value.Month.ToString();
                _birthYear = _editModel.BirthDate.Value.Year.ToString();
            }
            else
            {
                _birthDay = string.Empty;
                _birthMonth = string.Empty;
                _birthYear = string.Empty;
            }
        }
    }

    private void CloseEdit()
    {
        if (!_isEditing)
        {
            return;
        }

        ToggleEdit();
    }

    private async Task SaveProfileAsync()
    {
        if (_profile is null || string.IsNullOrWhiteSpace(_editModel.Name))
        {
            return;
        }

        _errorMessage = null;
        _successMessage = null;

        if (!ApplyBirthDateFromPicker())
        {
            return;
        }

        try
        {
            var updated = await ProfileService.UpdatePatientProfileAsync(ProfileId, _editModel);
            if (updated is null)
            {
                _errorMessage = "Kasutaja andmete uuendamine ebaõnnestus.";
                return;
            }

            _profile.Name = updated.Name;
            _profile.Gender = string.IsNullOrWhiteSpace(updated.Gender) ? "Määramata" : updated.Gender;
            _profile.BirthDate = updated.BirthDate;
            _isEditing = false;
            _successMessage = "Kasutaja andmed salvestatud.";
        }
        catch
        {
            _errorMessage = "Kasutaja andmete uuendamine ebaõnnestus.";
        }
    }

    private bool ApplyBirthDateFromPicker()
    {
        var hasAny = !string.IsNullOrWhiteSpace(_birthDay) || !string.IsNullOrWhiteSpace(_birthMonth) || !string.IsNullOrWhiteSpace(_birthYear);
        var hasAll = !string.IsNullOrWhiteSpace(_birthDay) && !string.IsNullOrWhiteSpace(_birthMonth) && !string.IsNullOrWhiteSpace(_birthYear);

        if (!hasAny)
        {
            _editModel.BirthDate = null;
            return true;
        }

        if (!hasAll)
        {
            _errorMessage = "Palun vali sünniajast päev, kuu ja aasta.";
            return false;
        }

        if (!int.TryParse(_birthYear, out var year) || !int.TryParse(_birthMonth, out var month) || !int.TryParse(_birthDay, out var day))
        {
            _errorMessage = "Sünniaja väärtused on vigased.";
            return false;
        }

        try
        {
            _editModel.BirthDate = new DateOnly(year, month, day);
            return true;
        }
        catch
        {
            _errorMessage = "Valitud sünniaeg ei ole korrektne kuupäev.";
            return false;
        }
    }

    private void TogglePasswordForm()
    {
        _isChangingPassword = !_isChangingPassword;
        _errorMessage = null;
        _successMessage = null;

        if (!_isChangingPassword)
        {
            _currentPassword = string.Empty;
            _newPassword = string.Empty;
            _confirmNewPassword = string.Empty;
            return;
        }

        _isEditing = false;
    }

    private void ClosePasswordForm()
    {
        if (!_isChangingPassword)
        {
            return;
        }

        TogglePasswordForm();
    }

    private async Task ChangePasswordAsync()
    {
        _errorMessage = null;
        _successMessage = null;

        if (string.IsNullOrWhiteSpace(_currentPassword) || string.IsNullOrWhiteSpace(_newPassword) || string.IsNullOrWhiteSpace(_confirmNewPassword))
        {
            _errorMessage = "Kõik parooli väljad on kohustuslikud.";
            return;
        }

        if (_newPassword != _confirmNewPassword)
        {
            _errorMessage = "Uued paroolid ei kattu.";
            return;
        }

        var result = await AuthService.ChangePasswordAsync(_currentPassword, _newPassword);
        if (!result.Success)
        {
            _errorMessage = result.ErrorMessage;
            return;
        }

        _currentPassword = string.Empty;
        _newPassword = string.Empty;
        _confirmNewPassword = string.Empty;
        _isChangingPassword = false;
        _successMessage = "Parool edukalt muudetud.";
    }

    private void PromptDeleteAccount()
    {
        _showDeleteConfirm = true;
        _errorMessage = null;
        _successMessage = null;
    }

    private void CancelDeleteAccount()
    {
        _showDeleteConfirm = false;
    }

    private async Task ConfirmDeleteAccountAsync()
    {
        _showDeleteConfirm = false;

        var result = await AuthService.DeleteAccountAsync();
        if (!result.Success)
        {
            _errorMessage = result.ErrorMessage;
            return;
        }

        Navigation.NavigateTo("/login", true);
    }

    private void GoBack() => Navigation.NavigateTo("/settings");
}
