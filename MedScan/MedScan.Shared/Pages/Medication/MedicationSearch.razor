@page "/home-pharmacy/search"
@using MedScan.Shared.DTOs.HomePharmacy
@using MedScan.Shared.Models
@using MedScan.Shared.Services
@using Microsoft.AspNetCore.Components.Forms
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject IScannerFlowService ScannerFlowService
@inject IHomePharmacyService HomePharmacyService

<PageTitle>Lisa ravim</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else
{
    <div class="medicine-screen">
        <div class="medicine-header">
            <button class="back-link" @onclick="BackToScannerAsync">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Tagasi
            </button>
            <h1>Lisa ravim</h1>
            <span class="header-spacer"></span>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="error-box">@_message</div>
        }

        <section class="search-card">
            <div class="manual-search-bar">
                <input class="field-input"
                       placeholder="Otsi ravimit nime järgi"
                       value="@_query"
                       @oninput="OnQueryInputAsync" />
                <button class="search-btn"
                        @onclick="SearchAsync"
                        disabled="@_isBusy">
                    Otsi
                </button>
            </div>

            @if (_suggestions.Count > 0)
            {
                <div class="search-suggestions">
                    @foreach (var item in _suggestions)
                    {
                        <button class="manual-result-item" @onclick="() => SelectMedication(item)">
                            <div class="manual-result-text">
                                <strong>@item.Name</strong>
                                <span>@item.ActiveIngredient</span>
                            </div>
                            <span class="add-indicator" aria-hidden="true">+</span>
                        </button>
                    }
                </div>
            }

            @if (_results.Count > 0)
            {
                <div class="manual-results">
                    @foreach (var item in _results)
                    {
                        <button class="manual-result-item" @onclick="() => SelectMedication(item)">
                            <div class="manual-result-text">
                                <strong>@item.Name</strong>
                                <span>@item.ActiveIngredient</span>
                            </div>
                            <span class="add-indicator" aria-hidden="true">+</span>
                        </button>
                    }
                </div>
            }
        </section>
    </div>
}

@code {
    [SupplyParameterFromQuery] public int? ProfileId { get; set; }

    private bool _isReady;
    private bool _isBusy;
    private int _targetProfileId;
    private string _query = string.Empty;
    private string? _message;
    private int _suggestionRequestId;
    private IReadOnlyList<MedicationLookupResult> _suggestions = [];
    private IReadOnlyList<MedicationLookupResult> _results = [];

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _targetProfileId = ResolveTargetProfileId();
        if (_targetProfileId <= 0)
        {
            _message = "Vaikimisi profiili ei leitud.";
        }

        _isReady = true;
    }

    private int ResolveTargetProfileId()
    {
        if (ProfileId is int routeProfileId && routeProfileId > 0)
        {
            return routeProfileId;
        }

        return AuthService.CurrentUser?.DefaultProfileId ?? 0;
    }

    private async Task SearchAsync()
    {
        if (_isBusy)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_query))
        {
            _message = "Sisesta ravimi nimi.";
            _suggestions = [];
            _results = [];
            return;
        }

        _isBusy = true;
        _message = null;
        _suggestions = [];
        _results = [];

        try
        {
            _results = await ScannerFlowService.SearchByNameAsync(_query, 20);
            if (_results.Count == 0)
            {
                _message = "Vastavaid ravimeid ei leitud.";
            }
        }
        catch
        {
            _message = "Otsing ebaonnestus.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task OnQueryInputAsync(ChangeEventArgs args)
    {
        _query = args.Value?.ToString() ?? string.Empty;
        _message = null;

        if (_query.Trim().Length < 3)
        {
            _suggestions = [];
            return;
        }

        var requestId = ++_suggestionRequestId;
        try
        {
            var lookupResults = await ScannerFlowService.SearchByNameAsync(_query, 8);
            if (requestId != _suggestionRequestId)
            {
                return;
            }

            _suggestions = lookupResults;
        }
        catch
        {
            if (requestId == _suggestionRequestId)
            {
                _suggestions = [];
            }
        }
    }

    private void SelectMedication(MedicationLookupResult medication)
    {
        _suggestions = [];
        Navigation.NavigateTo($"/home-pharmacy/save-medication/{Uri.EscapeDataString(medication.Barcode)}?ProfileId={_targetProfileId}");
    }

    private async Task BackToScannerAsync()
    {
        var scanResult = await ScannerFlowService.ScanAsync();

        if (scanResult.Status == BarcodeScanStatus.Success && !string.IsNullOrWhiteSpace(scanResult.Barcode))
        {
            var route = $"/home-pharmacy/save-medication/{Uri.EscapeDataString(scanResult.Barcode)}";
            if (_targetProfileId > 0)
            {
                route += $"?profileId={_targetProfileId}";
            }
            if (scanResult.ExpirationDate is DateOnly expirationDate)
            {
                route += route.Contains('?')
                    ? $"&exp={Uri.EscapeDataString(expirationDate.ToString("yyyy-MM-dd"))}"
                    : $"?exp={Uri.EscapeDataString(expirationDate.ToString("yyyy-MM-dd"))}";
            }
            if (!string.IsNullOrWhiteSpace(scanResult.BatchNumber))
            {
                route += route.Contains('?')
                    ? $"&lot={Uri.EscapeDataString(scanResult.BatchNumber)}"
                    : $"?lot={Uri.EscapeDataString(scanResult.BatchNumber)}";
            }

            Navigation.NavigateTo(route, replace: true);
            return;
        }

        if (scanResult.Status == BarcodeScanStatus.Canceled)
        {
            Navigation.NavigateTo("/home-pharmacy", replace: true);
        }
    }
}
