@page "/home-pharmacy/add-medication/{Barcode}"
@using MedScan.Shared.DTOs.HomePharmacy
@using MedScan.Shared.DTOs.Medication
@using MedScan.Shared.Models
@using MedScan.Shared.Models.Enums
@using MedScan.Shared.Services
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject IScannerFlowService ScannerFlowService
@inject IProfileService ProfileService
@inject IMedicationService MedicationService
@inject IHomePharmacyService HomePharmacyService

<PageTitle>Lisa nimekirja</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else if (_isLoading)
{
    <p><em>Laadin ravimi andmeid...</em></p>
}
else if (_medication is null)
{
    <p><em>Ravimit ei leitud.</em></p>
}
else
{
    <div class="add-med-screen">
        @if (_takeMode is null)
        {
            <div class="decision-overlay">
                <div class="decision-modal">
                    <h2>Kuidas soovid seda ravimit kasutada?</h2>
                    <div class="decision-actions">
                        <button class="decision-btn yes" @onclick="() => SetTakeMode(MedicationTakeMode.Regular)">Regulaarselt</button>
                        <button class="decision-btn now" @onclick="() => SetTakeMode(MedicationTakeMode.OneTimeNow)">Ühekordne kasutus</button>
                        <button class="decision-btn no" @onclick="() => SetTakeMode(MedicationTakeMode.StorageOnly)">Lisa ravim kasutaja nimekirja</button>
                    </div>
                </div>
            </div>
        }

        <div class="medicine-header">
            <button class="back-link" @onclick="GoBack">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Tagasi
            </button>
            <h1>Lisa nimekirja</h1>
            <span class="header-spacer"></span>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="error-box">@_message</div>
        }

        <div class="content-scroll">
            <section class="section-card quick-add-card">
                <div class="field-title">Ravim</div>
                <div class="medication-name-box">
                    <span class="medication-name">@_medication.Name</span>
                </div>
            </section>

            <section class="section-card quick-add-card">
                <div class="section-title profile-title">Kellele?</div>
                <div class="profile-segment">
                    @foreach (var profile in _profiles)
                    {
                        var active = profile.Id == _selectedProfileId;
                        <button class="profile-chip @(active ? "active" : null)" @onclick="() => SelectProfile(profile.Id)">@profile.Name</button>
                    }
                </div>
            </section>

            @if (_takeMode == MedicationTakeMode.Regular)
            {
                <section class="section-card">
                    <div class="section-title">Manustamissagedus</div>
                    <div class="frequency-grid">
                        @foreach (var option in _frequencyOptions)
                        {
                            var active = _frequencyPerDay == option;
                            <button class="frequency-btn @(active ? "active" : null)" @onclick="() => SetFrequency(option)">@option x</button>
                        }
                    </div>
                    <div class="frequency-meta">
                        <select class="period-select" value="@_scheduleUnit" @onchange="OnScheduleUnitChanged">
                            <option value="@MedicationScheduleUnit.Day">päevas</option>
                            <option value="@MedicationScheduleUnit.Week">nädalas</option>
                            <option value="@MedicationScheduleUnit.Month">kuus</option>
                        </select>
                    </div>

                    <div class="section-title time-title">Kellaajad</div>
                    @for (var i = 0; i < _scheduledTimeTexts.Count; i++)
                    {
                        var index = i;
                        <div class="time-row @(ShowWeeklyDaySelector ? "with-day" : "without-day")">
                            @if (ShowWeeklyDaySelector)
                            {
                                <select class="day-select" value="@GetWeeklyDayValue(index)" @onchange="args => OnWeeklyDayChanged(index, args)">
                                    @foreach (var day in _weekdayOptions)
                                    {
                                        <option value="@day.Value">@day.Label</option>
                                    }
                                </select>
                            }
                            <div class="time-controls">
                                <span class="clock-icon">◷</span>
                                <div class="time-wheel-box">
                                    <select class="time-wheel-part" value="@GetHourPart(index)" @onchange="args => OnHourChanged(index, args)">
                                        @for (var hour = 0; hour < 24; hour++)
                                        {
                                            var hourText = hour.ToString("D2");
                                            <option value="@hourText">@hourText</option>
                                        }
                                    </select>
                                </div>
                                <span class="time-separator">:</span>
                                <div class="time-wheel-box">
                                    <select class="time-wheel-part" value="@GetMinutePart(index)" @onchange="args => OnMinuteChanged(index, args)">
                                        @for (var minute = 0; minute < 60; minute++)
                                        {
                                            var minuteText = minute.ToString("D2");
                                            <option value="@minuteText">@minuteText</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    }
                </section>
            }

            @if (_takeMode == MedicationTakeMode.Regular)
            {
                <section class="section-card toggle-card">
                    <div>
                        <div class="section-title">Meeldetuletused</div>
                        <div class="toggle-caption">Teavita enne manustamist</div>
                    </div>
                    <label class="switch">
                        <input type="checkbox" @bind="_remindersEnabled" />
                        <span class="slider"></span>
                    </label>
                </section>
            }

            <section class="section-card">
                <label class="section-title" for="notes">Märkused (valikuline)</label>
                <textarea id="notes" class="notes-area" placeholder="Lisa märkused (nt võtta toiduga)..." @bind="_notes"></textarea>
            </section>
        </div>

        <div class="action-bar">
            <button class="save-btn" @onclick="SaveAsync" disabled="@_isSaving">@(_isSaving ? "Salvestan..." : "Salvesta")</button>
        </div>
    </div>
}



@code {
    [Parameter] public string Barcode { get; set; } = string.Empty;
    [SupplyParameterFromQuery(Name = "profileId")] public int? ProfileId { get; set; }
    [SupplyParameterFromQuery(Name = "exp")] public string? ExpirationQuery { get; set; }
    [SupplyParameterFromQuery(Name = "lot")] public string? BatchQuery { get; set; }

    private static readonly int[] _frequencyOptions = [1, 2, 3, 4];
    private static readonly (int Value, string Label)[] _weekdayOptions =
    [
        ((int)DayOfWeek.Monday, "Esmaspäev"),
        ((int)DayOfWeek.Tuesday, "Teisipäev"),
        ((int)DayOfWeek.Wednesday, "Kolmapäev"),
        ((int)DayOfWeek.Thursday, "Neljapäev"),
        ((int)DayOfWeek.Friday, "Reede"),
        ((int)DayOfWeek.Saturday, "Laupäev"),
        ((int)DayOfWeek.Sunday, "Pühapäev")
    ];

    private readonly List<ProfileSummary> _profiles = [];
    private bool _isReady;
    private bool _isLoading;
    private bool _isSaving;
    private string? _message;
    private MedicationLookupResult? _medication;
    private MedicationTakeMode? _takeMode;
    private int _selectedProfileId;
    private int _frequencyPerDay = 1;
    private MedicationScheduleUnit _scheduleUnit = MedicationScheduleUnit.Day;
    private List<string> _scheduledTimeTexts = ["08:00"];
    private List<int> _weeklyDays = [];
    private bool _remindersEnabled = true;
    private string? _notes;
    private DateOnly? _expiresOn;
    private string? _batchNumber;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        try
        {
            var profiles = await ProfileService.GetMyProfilesAsync();
            _profiles.Clear();
            _profiles.AddRange(profiles.OrderBy(p => p.Id));
            _selectedProfileId = ResolveTargetProfileId();
            if (_selectedProfileId <= 0)
            {
                _message = "Profiili ei leitud.";
            }
        }
        catch
        {
            _message = "Profiilide laadimine ebaõnnestus.";
        }

        _isReady = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_isReady)
        {
            return;
        }

        _isLoading = true;
        _message = null;

        try
        {
            _expiresOn = ParseExpirationQuery(ExpirationQuery);
            _batchNumber = ParseBatchQuery(BatchQuery);
            _medication = await ScannerFlowService.FindByBarcodeAsync(Barcode);
            if (_medication is null)
            {
                _message = "Ravimit ei leitud.";
                return;
            }
        }
        catch
        {
            _message = "Ravimi andmete laadimine ebaõnnestus.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool ShowWeeklyDaySelector => _scheduleUnit == MedicationScheduleUnit.Week && _frequencyPerDay > 1;

    private int ResolveTargetProfileId()
    {
        if (ProfileId is int routeProfileId && _profiles.Any(profile => profile.Id == routeProfileId))
        {
            return routeProfileId;
        }

        if (AuthService.CurrentUser?.DefaultProfileId is int defaultProfileId && _profiles.Any(profile => profile.Id == defaultProfileId))
        {
            return defaultProfileId;
        }

        return _profiles.FirstOrDefault()?.Id ?? 0;
    }

    private void SelectProfile(int profileId)
    {
        _selectedProfileId = profileId;
    }

    private void SetFrequency(int frequency)
    {
        _frequencyPerDay = frequency;
        var targetTimeCount = GetVisibleTimeCount();
        var defaults = GetDefaultTimes(Math.Max(frequency, targetTimeCount));

        if (_scheduledTimeTexts.Count > targetTimeCount)
        {
            _scheduledTimeTexts = _scheduledTimeTexts.Take(targetTimeCount).ToList();
        }

        while (_scheduledTimeTexts.Count < targetTimeCount)
        {
            _scheduledTimeTexts.Add(defaults[_scheduledTimeTexts.Count]);
        }

        SyncWeeklyDays();
    }

    private static List<string> GetDefaultTimes(int frequency)
    {
        return frequency switch
        {
            1 => ["08:00"],
            2 => ["08:00", "20:00"],
            3 => ["08:00", "14:00", "20:00"],
            4 => ["08:00", "12:00", "16:00", "20:00"],
            _ => ["08:00"]
        };
    }

    private void OnScheduleUnitChanged(ChangeEventArgs args)
    {
        if (!Enum.TryParse<MedicationScheduleUnit>(args.Value?.ToString(), out var parsed))
        {
            parsed = MedicationScheduleUnit.Day;
        }

        _scheduleUnit = parsed;
        EnsureVisibleTimeCount();
        SyncWeeklyDays();
    }

    private int GetVisibleTimeCount()
    {
        return _scheduleUnit == MedicationScheduleUnit.Month
            ? 1
            : _frequencyPerDay;
    }

    private void EnsureVisibleTimeCount()
    {
        var targetTimeCount = GetVisibleTimeCount();
        var defaults = GetDefaultTimes(Math.Max(_frequencyPerDay, targetTimeCount));

        if (_scheduledTimeTexts.Count > targetTimeCount)
        {
            _scheduledTimeTexts = _scheduledTimeTexts.Take(targetTimeCount).ToList();
        }

        while (_scheduledTimeTexts.Count < targetTimeCount)
        {
            _scheduledTimeTexts.Add(defaults[_scheduledTimeTexts.Count]);
        }
    }

    private void SyncWeeklyDays()
    {
        if (!ShowWeeklyDaySelector)
        {
            _weeklyDays = [];
            return;
        }

        var defaults = GetDefaultWeeklyDays(_frequencyPerDay);
        if (_weeklyDays.Count > _frequencyPerDay)
        {
            _weeklyDays = _weeklyDays.Take(_frequencyPerDay).ToList();
        }

        while (_weeklyDays.Count < _frequencyPerDay)
        {
            _weeklyDays.Add(defaults[_weeklyDays.Count]);
        }

        ReorderWeeklyPairs();
    }

    private static List<int> GetDefaultWeeklyDays(int frequency)
    {
        var mondayBasedDays =
            new[]
            {
                (int)DayOfWeek.Monday,
                (int)DayOfWeek.Tuesday,
                (int)DayOfWeek.Wednesday,
                (int)DayOfWeek.Thursday,
                (int)DayOfWeek.Friday,
                (int)DayOfWeek.Saturday,
                (int)DayOfWeek.Sunday
            };

        return mondayBasedDays.Take(frequency).ToList();
    }

    private string GetWeeklyDayValue(int index)
    {
        return index < _weeklyDays.Count
            ? _weeklyDays[index].ToString()
            : ((int)DayOfWeek.Monday).ToString();
    }

    private void OnWeeklyDayChanged(int index, ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var parsedDay))
        {
            return;
        }

        while (_weeklyDays.Count <= index)
        {
            _weeklyDays.Add((int)DayOfWeek.Monday);
        }

        _weeklyDays[index] = parsedDay;
        ReorderWeeklyPairs();
    }

    private void ReorderWeeklyPairs()
    {
        if (!ShowWeeklyDaySelector || _weeklyDays.Count != _scheduledTimeTexts.Count)
        {
            return;
        }

        var orderedPairs = _weeklyDays
            .Select((day, index) => new { Day = day, Time = _scheduledTimeTexts[index], Index = index })
            .OrderBy(pair => GetWeekdayOrder(pair.Day))
            .ThenBy(pair => pair.Index)
            .ToList();

        _weeklyDays = orderedPairs.Select(pair => pair.Day).ToList();
        _scheduledTimeTexts = orderedPairs.Select(pair => pair.Time).ToList();
    }

    private static int GetWeekdayOrder(int day)
    {
        return day == (int)DayOfWeek.Sunday ? 6 : day - 1;
    }

    private void OnHourChanged(int index, ChangeEventArgs args)
    {
        var hour = args.Value?.ToString() ?? "00";
        var minute = GetMinutePart(index);
        _scheduledTimeTexts[index] = $"{hour}:{minute}";
    }

    private void OnMinuteChanged(int index, ChangeEventArgs args)
    {
        var hour = GetHourPart(index);
        var minute = args.Value?.ToString() ?? "00";
        _scheduledTimeTexts[index] = $"{hour}:{minute}";
    }

    private string GetHourPart(int index)
    {
        var value = _scheduledTimeTexts[index];
        return value.Length >= 2 ? value[..2] : "00";
    }

    private string GetMinutePart(int index)
    {
        var value = _scheduledTimeTexts[index];
        return value.Length >= 5 ? value.Substring(3, 2) : "00";
    }

    private async Task SaveAsync()
    {
        if (_isSaving || _medication is null)
        {
            return;
        }

        if (_takeMode is null)
        {
            _message = "Vali esmalt ravimi kasutusviis.";
            return;
        }

        if (_selectedProfileId <= 0)
        {
            _message = "Vali profiil.";
            return;
        }

        var parsedTimes = new List<TimeOnly>();
        foreach (var text in _scheduledTimeTexts)
        {
            if (!TimeOnly.TryParse(text, out var parsed))
            {
                _message = "Sisesta kõik kellaajad korrektselt.";
                return;
            }

            parsedTimes.Add(parsed);
        }

        if (_takeMode == MedicationTakeMode.Regular)
        {
            var expectedTimeCount = GetVisibleTimeCount();
            if (parsedTimes.Count != expectedTimeCount)
            {
                _message = "Kellaaegade arv peab vastama manustamissagedusele.";
                return;
            }

            if (ShowWeeklyDaySelector)
            {
                if (_weeklyDays.Count != _frequencyPerDay)
                {
                    _message = "Vali igale nädalasele korrale päev.";
                    return;
                }

                if (_weeklyDays.Distinct().Count() != _weeklyDays.Count)
                {
                    _message = "Vali igale nädalasele korrale erinev päev.";
                    return;
                }
            }
        }

        _isSaving = true;
        _message = null;

        try
        {
            if (_takeMode == MedicationTakeMode.Regular)
            {
                await MedicationService.AddToScheduleAsync(new AddMedicationDto
                {
                    ProfileId = _selectedProfileId,
                    MedicationId = _medication.Id,
                    FrequencyPerDay = _frequencyPerDay,
                    ScheduleUnit = _scheduleUnit,
                    ScheduledTimes = parsedTimes,
                    WeeklyDays = ShowWeeklyDaySelector ? _weeklyDays.ToList() : [],
                    StartDate = DateOnly.FromDateTime(DateTime.Now),
                    ExpiresOn = _expiresOn,
                    RemindersEnabled = _remindersEnabled,
                    Notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim()
                });
            }

            await HomePharmacyService.AddAsync(new AddHomePharmacyItemDto
            {
                ProfileId = _selectedProfileId,
                MedicationId = _medication.Id,
                BatchNumber = _batchNumber,
                ExpiresOn = _expiresOn,
                Quantity = ResolveInitialQuantity(_medication.PackSize),
                Notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim()
            });

            if (_takeMode == MedicationTakeMode.OneTimeNow)
            {
                var oneTimeResult = await MedicationService.TakeOnceAsync(_medication.Id, new TakeMedicationOnceDto
                {
                    ProfileId = _selectedProfileId,
                    Quantity = 1,
                    Notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim(),
                    ConfirmLastUnit = true
                });

                if (!oneTimeResult.Success)
                {
                    _message = string.IsNullOrWhiteSpace(oneTimeResult.Message)
                        ? "Ühekordse võtmise salvestamine ebaõnnestus."
                        : oneTimeResult.Message;
                    return;
                }
            }

            var profileName = _profiles.FirstOrDefault(p => p.Id == _selectedProfileId)?.Name ?? "kasutaja";
            Navigation.NavigateTo($"/home-pharmacy/saved-medication?medicationName={Uri.EscapeDataString(_medication.Name)}&profileName={Uri.EscapeDataString(profileName)}&profileId={_selectedProfileId}");
        }
        catch
        {
            _message = "Ravimi salvestamine ebaõnnestus.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void SetTakeMode(MedicationTakeMode mode)
    {
        _takeMode = mode;
    }

    private void GoBack()
    {
        Navigation.NavigateTo($"/home-pharmacy/save-medication/{Uri.EscapeDataString(Barcode)}?profileId={_selectedProfileId}");
    }

    private static DateOnly? ParseExpirationQuery(string? query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return null;
        }

        return DateOnly.TryParse(query, out var parsed) ? parsed : null;
    }

    private static string? ParseBatchQuery(string? query)
    {
        return string.IsNullOrWhiteSpace(query) ? null : query.Trim();
    }

    private static int ResolveInitialQuantity(string? packSize)
    {
        if (string.IsNullOrWhiteSpace(packSize))
        {
            return 1;
        }

        var digits = new string(packSize.Where(char.IsDigit).ToArray());
        return int.TryParse(digits, out var parsed) && parsed > 0
            ? parsed
            : 1;
    }

    private enum MedicationTakeMode
    {
        Regular,
        OneTimeNow,
        StorageOnly
    }
}

