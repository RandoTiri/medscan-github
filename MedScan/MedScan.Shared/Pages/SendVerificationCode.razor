@page "/send-verification-code"
@layout MedScan.Shared.Layout.AuthLayout
@using MedScan.Shared.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>MedScan - Unustasin parooli</PageTitle>

<style>
    .forgot-container {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        display: flex;
        flex-direction: column;

        width: 100%;
        min-height: 100vh;
        background-color: var(--ms-surface);
        max-width: 450px;
        margin: 0 auto;
        color: #1c3d4f;
        box-sizing: border-box;

        padding-top: 0;
        padding-bottom: calc(max(20px, env(safe-area-inset-bottom)) + 20px);
        padding-left: max(0px, env(safe-area-inset-left));
        padding-right: max(0px, env(safe-area-inset-right));
    }
    .header-section {
        background: linear-gradient(180deg, #ecf7f4 0%, #fff 100%);
        padding: calc(max(20px, env(safe-area-inset-top)) + 20px) 30px 20px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }
    .form-section {
        padding: 0 30px 20px;
        display: flex;
        flex-direction: column;
    }
    .back-button {
        display: inline-flex;
        align-items: center;
        color: #267863;
        font-size: 16px;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        padding: 10px 0;
        margin-bottom: 20px;
        margin-top: 20px;
        background: none;
        border: none;
    }
    .back-button svg {
        margin-right: 8px;
    }
    .icon-container {
        background-color: #ecf7f4;
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        color: #267863;
    }
    .title {
        font-size: 26px;
        font-weight: 700;
        margin: 0 0 10px;
        color: #0b2b40;
    }
    .subtitle {
        font-size: 14px;
        color: #648191;
        margin: 0 0 30px;
        line-height: 1.5;
    }
    .auth-input-group {
        margin-bottom: 20px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        width: 100%;
        box-sizing: border-box;
    }
    .auth-input-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 8px;
        color: #1c3d4f;
        text-align: left;
        width: 100%;
    }
    .input-wrapper {
        display: flex;
        align-items: center;
        border: 2px solid #d4dfe5;
        border-radius: 16px;
        overflow: hidden;
        padding: 0 15px;
        background: #fafafc;
        width: 100%;
        box-sizing: border-box;
        transition: all 0.2s ease;
    }
    .input-wrapper:focus-within {
        border-color: #267863;
        background: var(--ms-surface);
        box-shadow: 0 0 0 4px rgba(38, 120, 99, 0.1);
    }
    .input-wrapper input {
        border: none;
        outline: none;
        padding: 15px 10px;
        width: 100%;
        font-size: 14px;
        color: #1c3d4f;
        background: transparent;
    }
    .input-wrapper input::placeholder {
        color: #a0b6c2;
    }
    .input-icon {
        color: #a0b6c2;
        display: flex;
        flex-shrink: 0;
    }
    .btn-primary {
        background-color: #267863;
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 16px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 4px 10px rgba(38, 120, 99, 0.2);
        width: 100%;
        transition: all 0.1s ease;
    }
    .btn-primary:active {
        transform: scale(0.98);
        background-color: #1e604f;
    }
    .btn-primary:disabled {
        opacity: 0.7;
        transform: none;
    }
    .success-message {
        color: #2e7d32;
        background: #e8f5e9;
        padding: 10px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 14px;
    }
    .auth-error {
        color: #e53935;
        background: #ffebee;
        padding: 10px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 14px;
    }
</style>

<div class="forgot-container">
    <div class="header-section">
        <button class="back-button" @onclick="GoBack">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Tagasi
        </button>

        <div class="icon-container">
            <svg viewBox="0 0 24 24" width="30" height="30" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
        </div>

        <h1 class="title">Unustasin parooli</h1>
        <p class="subtitle">Sisesta oma e-mail ja saadame sulle parooli lähtestamise lingi.</p>
    </div>

    <div class="form-section">
        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="auth-error">@ErrorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
    {
        <div class="success-message">@SuccessMessage</div>
    }

    <div class="auth-input-group">
        <label for="email">E-mail</label>
        <div class="input-wrapper">
            <div class="input-icon">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
            </div>
            <input id="email" type="email" placeholder="sinuemail@gmail.com" @bind="Email" disabled="@IsBusy" />
        </div>
    </div>

    <button class="btn-primary" @onclick="SendCode" disabled="@IsBusy">
        @(IsBusy ? "Saadab..." : "Saada kood")
    </button>

    @if (CodeSent)
    {
        <div class="auth-input-group" style="margin-top: 20px;">
            <label for="code">Sisesta kood</label>
            <div class="input-wrapper">
                <input id="code" type="text" placeholder="123456" @bind="VerificationCode" maxlength="6" disabled="@IsVerifying" />
            </div>
        </div>

        <button class="btn-primary" @onclick="VerifyCode" disabled="@IsVerifying">
            @(IsVerifying ? "Kontrollib..." : "Sisesta kood")
        </button>
    }
    </div>
</div>

@code {
    private string Email = string.Empty;
    private string VerificationCode = string.Empty;
    private string ErrorMessage = string.Empty;
    private string SuccessMessage = string.Empty;
    private bool IsBusy;
    private bool IsVerifying;
    private bool CodeSent;

    private void GoBack()
    {
        Navigation.NavigateTo("/login");
    }

    private async Task SendCode()
    {
        if (IsBusy)
        {
            return;
        }

        IsBusy = true;
        ErrorMessage = string.Empty;
        SuccessMessage = string.Empty;

        try
        {
            if (string.IsNullOrWhiteSpace(Email))
            {
                ErrorMessage = "Palun sisesta email.";
                return;
            }

            var result = await AuthService.ForgotPasswordAsync(Email);

            if (result.Success)
            {
                CodeSent = true;
                SuccessMessage = $"Saatsime emailile {Email} 6-kohalise koodi.";
            }
            else
            {
                ErrorMessage = result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Tehniline viga: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task VerifyCode()
    {
        if (IsVerifying)
        {
            return;
        }

        IsVerifying = true;
        ErrorMessage = string.Empty;
        SuccessMessage = string.Empty;

        try
        {
            if (string.IsNullOrWhiteSpace(Email))
            {
                ErrorMessage = "Palun sisesta email.";
                return;
            }

            if (string.IsNullOrWhiteSpace(VerificationCode))
            {
                ErrorMessage = "Palun sisesta kood.";
                return;
            }

            var result = await AuthService.VerifyCodeAsync(Email, VerificationCode);

            if (result.Success)
            {
                // Suunab parooli uuendamise lehele
                Navigation.NavigateTo($"/update-password?email={Uri.EscapeDataString(Email)}&code={Uri.EscapeDataString(VerificationCode)}");
            }
            else
            {
                ErrorMessage = result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Tehniline viga: {ex.Message}";
        }
        finally
        {
            IsVerifying = false;
        }
    }
}

