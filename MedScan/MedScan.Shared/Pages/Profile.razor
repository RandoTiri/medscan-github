@page "/profile"
@using MedScan.Shared.Models
@using MedScan.Shared.Services
@inject IAuthService AuthService
@inject IProfileService ProfileService
@inject NavigationManager Navigation



<PageTitle>Profiilid</PageTitle>

@if (!AuthService.IsLoggedIn)
{
    <p>Suunan loginisse...</p>
}
else
{
    <div class="page-container">
        <div class="content-wrapper">
            <div class="profile-header">
                <span class="header-spacer"></span>
                <h1 class="page-title">Profiilid</h1>
                <span class="header-spacer"></span>
            </div>

            <div class="main-user-card" @onclick="OpenMainProfileView">
                <div class="avatar-outline">@GetInitials()</div>
                <div class="main-user-info">
                    <p class="name">@(AuthService.CurrentUser?.FullName ?? "Nimetu")</p>
                    <p class="subtitle">@GetMainUserDetails()</p>
                </div>
                <div class="main-user-chevron">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                </div>
            </div>

            <div class="section-header">
                <h2 class="section-title">Hoolealune</h2>
                @if (!isAdding)
                {
                    <button class="btn-add" @onclick="ToggleAddForm">+ Lisa</button>
                }
            </div>

            @if (isAdding)
            {
                <div class="add-form-container">
                    <div class="form-group">
                        <label>Nimi</label>
                        <input class="form-control" @bind="newPatient.Name" placeholder="nt. Maie Tamm" />
                    </div>
                    <div class="form-group">
                        <label>Sugu</label>
                        <select class="form-control" @bind="newPatient.Gender">
                            <option value="">Vali sugu...</option>
                            <option value="Mees">Mees</option>
                            <option value="Naine">Naine</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Sünniaeg</label>
                        <div class="birthdate-picker">
                            <div class="birth-field">
                                <label>Päev</label>
                                <select class="birth-select" @bind="_birthDay" @bind:after="OnBirthDatePartChanged">
                                    <option value="">pp</option>
                                    @foreach (var day in _days)
                                    {
                                        <option value="@day">@day</option>
                                    }
                                </select>
                            </div>

                            <div class="birth-field">
                                <label>Kuu</label>
                                <select class="birth-select" @bind="_birthMonth" @bind:after="OnBirthDatePartChanged">
                                    <option value="">kk</option>
                                    @foreach (var month in _months)
                                    {
                                        <option value="@month">@month</option>
                                    }
                                </select>
                            </div>

                            <div class="birth-field">
                                <label>Aasta</label>
                                <select class="birth-select" @bind="_birthYear" @bind:after="OnBirthDatePartChanged">
                                    <option value="">aaaa</option>
                                    @foreach (var year in _years)
                                    {
                                        <option value="@year">@year</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button class="btn-close-add" @onclick="ToggleAddForm">Sulge</button>
                        <button class="btn-save" @onclick="SavePatientAsync">Salvesta</button>
                    </div>
                </div>
            }

            <div class="patients-list">
                @if (CareReceivers.Any())
                {
                    @foreach (var patient in CareReceivers)
                    {
                        <div class="patient-card" @onclick="() => OpenProfileView(patient.Id)">
                            <div class="patient-avatar">
                                @patient.Initials
                            </div>
                            <div class="patient-info">
                                <p class="patient-name">@patient.Name</p>
                                <p class="patient-details">@GetPatientDetails(patient)</p>
                            </div>
                            <div class="patient-chevron">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="9 18 15 12 9 6"></polyline>
                                </svg>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    private List<Patient> CareReceivers = [];
    private int _mainProfileId;
    private Patient? _mainUserProfile;
    private readonly List<int> _days = Enumerable.Range(1, 31).ToList();
    private readonly List<int> _months = Enumerable.Range(1, 12).ToList();
    private readonly List<int> _years = Enumerable.Range(1900, DateTime.Today.Year - 1900 + 1).Reverse().ToList();

    private bool isAdding = false;
    private Patient newPatient = new Patient();
    private string _birthDay = string.Empty;
    private string _birthMonth = string.Empty;
    private string _birthYear = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();

        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadPatientsAsync();
    }

    private void ToggleAddForm()
    {
        isAdding = !isAdding;
        if (isAdding)
        {
            newPatient = new Patient();
            _birthDay = string.Empty;
            _birthMonth = string.Empty;
            _birthYear = string.Empty;
        }
    }

    private async Task SavePatientAsync()
    {
        if (string.IsNullOrWhiteSpace(newPatient.Name))
        {
            return;
        }

        if (!ApplyBirthDateFromPicker())
        {
            return;
        }

        var request = new CreatePatientProfileRequest
        {
            Name = newPatient.Name,
            Gender = string.IsNullOrWhiteSpace(newPatient.Gender) ? "Määramata" : newPatient.Gender,
            BirthDate = newPatient.BirthDate
        };

        var createdProfile = await ProfileService.CreatePatientProfileAsync(request);
        CareReceivers.Add(new Patient
        {
            Id = createdProfile.Id,
            Name = createdProfile.Name,
            BirthDate = createdProfile.BirthDate,
            Gender = createdProfile.Gender
        });

        isAdding = false;
        newPatient = new Patient();
        _birthDay = string.Empty;
        _birthMonth = string.Empty;
        _birthYear = string.Empty;
    }

    private Task OnBirthDatePartChanged()
    {
        var hasAll = !string.IsNullOrWhiteSpace(_birthDay)
            && !string.IsNullOrWhiteSpace(_birthMonth)
            && !string.IsNullOrWhiteSpace(_birthYear);

        if (!hasAll)
        {
            newPatient.BirthDate = null;
            return Task.CompletedTask;
        }

        if (!int.TryParse(_birthYear, out var year) || !int.TryParse(_birthMonth, out var month))
        {
            newPatient.BirthDate = null;
            return Task.CompletedTask;
        }

        if (int.TryParse(_birthDay, out var day))
        {
            var maxDay = DateTime.DaysInMonth(year, month);
            if (day > maxDay)
            {
                _birthDay = maxDay.ToString();
            }
        }

        ApplyBirthDateFromPicker();
        return Task.CompletedTask;
    }

    private bool ApplyBirthDateFromPicker()
    {
        var hasAny = !string.IsNullOrWhiteSpace(_birthDay) || !string.IsNullOrWhiteSpace(_birthMonth) || !string.IsNullOrWhiteSpace(_birthYear);
        var hasAll = !string.IsNullOrWhiteSpace(_birthDay) && !string.IsNullOrWhiteSpace(_birthMonth) && !string.IsNullOrWhiteSpace(_birthYear);

        if (!hasAny)
        {
            newPatient.BirthDate = null;
            return true;
        }

        if (!hasAll)
        {
            return false;
        }

        if (!int.TryParse(_birthYear, out var year) || !int.TryParse(_birthMonth, out var month) || !int.TryParse(_birthDay, out var day))
        {
            return false;
        }

        try
        {
            newPatient.BirthDate = new DateOnly(year, month, day);
            return true;
        }
        catch
        {
            return false;
        }
    }

    private async Task LoadPatientsAsync()
    {
        var profiles = await ProfileService.GetMyProfilesAsync();

        _mainProfileId = AuthService.CurrentUser?.DefaultProfileId
            ?? profiles.FirstOrDefault(p => p.Type.Equals("Ise", StringComparison.OrdinalIgnoreCase))?.Id
            ?? 0;

        var mainProfile = profiles.FirstOrDefault(p => p.Id == _mainProfileId)
            ?? profiles.FirstOrDefault(p => p.Type.Equals("Ise", StringComparison.OrdinalIgnoreCase));

        _mainUserProfile = mainProfile is null
            ? null
            : new Patient
            {
                Id = mainProfile.Id,
                Name = mainProfile.Name,
                BirthDate = mainProfile.BirthDate,
                Gender = string.IsNullOrWhiteSpace(mainProfile.Gender) ? "Määramata" : mainProfile.Gender
            };

        CareReceivers = profiles
            .Where(p => p.Type.Equals("Patsient", StringComparison.OrdinalIgnoreCase))
            .Select(p => new Patient
            {
                Id = p.Id,
                Name = p.Name,
                BirthDate = p.BirthDate,
                Gender = string.IsNullOrWhiteSpace(p.Gender) ? "Määramata" : p.Gender
            })
            .ToList();
    }

    private static string GetPatientDetails(Patient patient)
    {
        var agePart = patient.Age > 0 ? $"{patient.Age} a" : "Vanus puudub";
        return $"{agePart} · {patient.Gender}";
    }

    private string GetMainUserDetails()
    {
        if (_mainUserProfile is null)
        {
            return "Vanus puudub · Määramata";
        }

        return GetPatientDetails(_mainUserProfile);
    }

    private void OpenProfileView(int profileId)
    {
        Navigation.NavigateTo($"/profile/view/{profileId}");
    }

    private void OpenMainProfileView()
    {
        if (_mainProfileId > 0)
        {
            Navigation.NavigateTo($"/profile/view/{_mainProfileId}");
        }
    }

    private string GetInitials()
    {
        var fullName = AuthService.CurrentUser?.FullName;

        if (string.IsNullOrWhiteSpace(fullName))
        {
            return "U";
        }

        var parts = fullName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(p => char.ToUpperInvariant(p[0]));

        return string.Concat(parts);
    }
}
