@page "/settings/notifications"
@using MedScan.Shared.DTOs.Medication
@inject IAuthService AuthService
@inject IProfileService ProfileService
@inject IMedicationService MedicationService
@inject NavigationManager Navigation

<PageTitle>Meeldetuletused</PageTitle>

@if (!_isReady) {
    <p><em>Laen...</em></p>
} else {
    <div class="settings-subpage">
        <div class="settings-subpage-content">
            <div class="medicine-header">
                <BackButton OnClick="GoBack" />
                <h1>Meeldetuletused</h1>
                <span class="header-spacer"></span>
            </div>

            @if (!string.IsNullOrWhiteSpace(_errorMessage)) {
                <div class="error-box">@_errorMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(_successMessage)) {
                <div class="success-box">@_successMessage</div>
            }

            <div class="settings-card">
                <div class="settings-item">
                    <div class="item-text">
                        <h3>Teavitused</h3>
                        <p>@(_notificationsEnabled ? "Teavitused sees" : "Teavitused väljas")</p>
                    </div>
                    <label class="toggle-switch" aria-label="Teavitused">
                        <input type="checkbox"
                               checked="@_notificationsEnabled"
                               disabled="@_isSaving"
                               @onchange="OnNotificationsToggleChanged" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _isReady;
    private bool _isSaving;
    private bool _notificationsEnabled = true;
    private string? _errorMessage;
    private string? _successMessage;

    protected override async Task OnInitializedAsync() {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn) {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadNotificationStateAsync();
        _isReady = true;
    }

    private async Task LoadNotificationStateAsync() {
        var medications = await GetAllUserMedicationsAsync();
        _notificationsEnabled = medications.Any(m => m.RemindersEnabled);
    }

    private async Task OnNotificationsToggleChanged(ChangeEventArgs args) {
        if (_isSaving) {
            return;
        }

        _errorMessage = null;
        _successMessage = null;

        var enabled = args.Value is bool value && value;
        await SetNotificationsEnabledAsync(enabled);
    }

    private async Task SetNotificationsEnabledAsync(bool enabled) {
        _isSaving = true;

        try {
            var medications = await GetAllUserMedicationsAsync();

            foreach (var medication in medications.Where(m => m.RemindersEnabled != enabled)) {
                var update = new AddMedicationDto {
                    ProfileId = medication.ProfileId,
                    MedicationId = medication.MedicationId,
                    FrequencyPerDay = medication.FrequencyPerDay,
                    ScheduleUnit = medication.ScheduleUnit,
                    ScheduledTimes = medication.ScheduledTimes.ToList(),
                    WeeklyDays = medication.WeeklyDays.ToList(),
                    StartDate = medication.StartDate,
                    RemindersEnabled = enabled,
                    Notes = medication.Notes
                };

                await MedicationService.UpdateScheduleAsync(medication.Id,update);
            }

            _notificationsEnabled = enabled;
            _successMessage = enabled ? "Teavitused on sisse lülitatud." : "Teavitused on välja lülitatud.";
        } catch {
            _errorMessage = "Teavituste seadistamine ebaõnnestus.";
        } finally {
            _isSaving = false;
        }
    }

    private async Task<List<UserMedicationDto>> GetAllUserMedicationsAsync() {
        var profiles = await ProfileService.GetMyProfilesAsync();
        var medications = new List<UserMedicationDto>();

        foreach (var profile in profiles) {
            var schedule = await MedicationService.GetScheduleAsync(profile.Id);
            medications.AddRange(schedule);
        }

        return medications;
    }

    private void GoBack() => Navigation.NavigateTo("/settings");
}