@page "/settings/appearance"
@inject IAuthService AuthService
@inject IThemeService ThemeService
@inject NavigationManager Navigation

<PageTitle>Välimus</PageTitle>

@if (!_isReady) {
    <p><em>Laen...</em></p>
} else {
    <div class="settings-subpage">
        <div class="settings-subpage-content">
            <div class="medicine-header">
                <BackButton OnClick="GoBack" />
                <h1>Välimus</h1>
                <span class="header-spacer"></span>
            </div>

            <div class="settings-card">
                <div class="settings-item">
                    <div class="item-text">
                        <h3>Teema</h3>
                        <p>@(_darkModeEnabled ? "Tume teema" : "Hele teema")</p>
                    </div>
                    <label class="toggle-switch" aria-label="Teema">
                        <input type="checkbox"
                               checked="@_darkModeEnabled"
                               @onchange="OnThemeToggleChanged" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _isReady;
    private bool _darkModeEnabled;

    protected override async Task OnInitializedAsync() {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn) {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (!firstRender) {
            return;
        }

        await ThemeService.InitializeAsync();
        _darkModeEnabled = ThemeService.IsDarkMode;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnThemeToggleChanged(ChangeEventArgs args) {
        _darkModeEnabled = args.Value is bool value && value;
        await ThemeService.SetDarkModeAsync(_darkModeEnabled);
    }

    private void GoBack() => Navigation.NavigateTo("/settings");
}