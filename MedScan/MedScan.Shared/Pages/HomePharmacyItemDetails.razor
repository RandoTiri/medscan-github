@page "/mymedicine/{Id:int}"
@page "/home-pharmacy/{Id:int}"
@using MedScan.Shared.DTOs.HomePharmacy
@using MedScan.Shared.Services
@using Microsoft.AspNetCore.Components.Forms
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject IHomePharmacyService HomePharmacyService

<PageTitle>Ravimi detail</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else
{
    <div class="medicine-screen">
        <div class="medicine-header">
            <button class="back-link" @onclick="BackToList">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Tagasi
            </button>
            <h1>Ravimi detail</h1>
            <span class="header-spacer"></span>
        </div>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="error-box">@_errorMessage</div>
        }
        else if (_item is null)
        {
            <div class="empty-state">Kirjet ei leitud.</div>
        }
        else
        {
            <article class="detail-card">
                <div class="title-row">
                    <div class="left-icon">R</div>
                    <div>
                        <h2>@_item.MedicationName</h2>
                        <p class="meta-line">@(_item.ActiveIngredient ?? "-") @(string.IsNullOrWhiteSpace(_item.Strength) ? string.Empty : $"· {_item.Strength}")</p>
                    </div>
                </div>

                <div class="info-grid">
                    <p><span>Profiil</span><strong>@_item.ProfileName</strong></p>
                    <p><span>Karp nr</span><strong>@(_item.PackageNumber?.ToString() ?? "-")</strong></p>
                    <p><span>Aegub</span><strong>@(_item.ExpiresOn?.ToString("dd.MM.yyyy") ?? "-")</strong></p>
                    <p><span>Kogus</span><strong>@_item.Quantity</strong></p>
                    <p><span>Näitus</span><strong>@(_item.Indication ?? "-")</strong></p>
                    <p><span>Hoiatused</span><strong>@(_item.Warnings ?? "-")</strong></p>
                </div>

                @if (!string.IsNullOrWhiteSpace(_item.PdfUrl))
                {
                    <a class="leaflet-link" href="@_item.PdfUrl" target="_blank">Ava infoleht</a>
                }
            </article>

            <section class="edit-card">
                <h3>Muuda kirjet</h3>

                @if (!string.IsNullOrWhiteSpace(_message))
                {
                    <div class="success-box">@_message</div>
                }

                <label class="field-label">Kogus</label>
                <input class="field-input" type="number" min="1" @bind="_quantity" />

                <label class="field-label">Karbi number (valikuline)</label>
                <input class="field-input" type="number" min="1" @bind="_packageNumber" />

                <label class="field-label">Aegumiskuupaev (valikuline)</label>
                <InputDate class="field-input" @bind-Value="_expiresOnDate" />

                <label class="field-label">Markmed</label>
                <textarea class="field-input field-textarea" @bind="_notes"></textarea>
            </section>

            <div class="action-bar">
                <button class="action-save" @onclick="SaveAsync" disabled="@_isBusy">
                    @(_isBusy ? "Salvestan..." : "Salvesta")
                </button>
                <button class="action-delete" @onclick="DeleteAsync" disabled="@_isBusy">
                    Kustuta
                </button>
            </div>
        }
    </div>
}

<style>
    .medicine-screen {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background: #f3f4f4;
        min-height: 100vh;
        width: 100vw;
        position: relative;
        left: 50%;
        margin-left: -50vw;
        margin-top: -1.1rem;
        box-sizing: border-box;
        padding: 20px;
        padding-top: calc(max(20px, env(safe-area-inset-top)) + 20px);
        padding-bottom: calc(max(24px, env(safe-area-inset-bottom)) + 170px);
        padding-left: max(12px, env(safe-area-inset-left));
        padding-right: max(12px, env(safe-area-inset-right));
    }

    .medicine-header {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 8px;
        padding: 6px 6px 14px 6px;
        border-bottom: 1px solid #dfe3e2;
    }

    .medicine-header h1 {
        margin: 0;
        font-size: 22px;
        letter-spacing: -0.02em;
        color: #132340;
        font-weight: 800;
        text-align: center;
    }

    .header-spacer {
        width: 56px;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        border: none;
        background: transparent;
        color: #267863;
        font-size: 16px;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        padding: 10px 0;
    }

    .back-link svg {
        margin-right: 8px;
    }

    .detail-card, .edit-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 8px 18px rgba(30, 55, 45, 0.08);
        padding: 14px;
        margin-top: 12px;
    }

    .title-row {
        display: grid;
        grid-template-columns: 64px 1fr;
        gap: 12px;
        align-items: start;
        margin-bottom: 8px;
    }

    .left-icon {
        width: 64px;
        height: 64px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: #e7efed;
        color: #2f6f58;
        font-size: 28px;
        font-weight: 700;
    }

    .title-row h2 {
        margin: 0;
        color: #132340;
        font-size: 24px;
        font-weight: 800;
        line-height: 1.1;
    }

    .meta-line {
        margin: 6px 0 0 0;
        color: #5e7072;
        font-size: 15px;
    }

    .info-grid {
        display: grid;
        gap: 8px;
        margin-top: 8px;
    }

    .info-grid p {
        margin: 0;
        display: grid;
        gap: 2px;
    }

    .info-grid p span {
        color: #6b7c7d;
        font-size: 13px;
    }

    .info-grid p strong {
        color: #132340;
        font-size: 15px;
        font-weight: 700;
    }

    .leaflet-link {
        margin-top: 10px;
        display: inline-block;
        color: #2f6f58;
        font-weight: 700;
        text-decoration: none;
    }

    .edit-card h3 {
        margin: 0 0 10px 0;
        font-size: 22px;
        color: #132340;
        font-weight: 800;
    }

    .field-label {
        display: block;
        margin-top: 8px;
        margin-bottom: 6px;
        color: #132340;
        font-size: 14px;
        font-weight: 700;
    }

    .field-input {
        width: 100%;
        border: 1px solid #d9dfde;
        border-radius: 12px;
        background: #f9fbfa;
        padding: 10px 12px;
        font-size: 16px;
        color: #1f2a3d;
    }

    .field-textarea {
        min-height: 92px;
        resize: vertical;
    }

    .action-bar {
        position: fixed;
        left: 0;
        right: 0;
        bottom: calc(max(12px, env(safe-area-inset-bottom)) + 76px);
        padding: 0 16px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        z-index: 40;
    }

    .action-save, .action-delete {
        border: 0;
        border-radius: 14px;
        padding: 12px 14px;
        font-size: 16px;
        font-weight: 700;
    }

    .action-save {
        background: #2f6f58;
        color: #fff;
    }

    .action-delete {
        background: #fbe8ea;
        color: #ab3f4c;
    }

    .error-box, .success-box, .empty-state {
        border-radius: 14px;
        padding: 12px;
        font-size: 15px;
        margin-top: 12px;
    }

    .error-box {
        background: #fde9eb;
        color: #ab3f4c;
    }

    .success-box {
        background: #e7f4ed;
        color: #2f6f58;
    }

    .empty-state {
        background: #fff;
        color: #607175;
    }
</style>

@code {
    [Parameter] public int Id { get; set; }

    private bool _isReady;
    private bool _isBusy;
    private string? _errorMessage;
    private string? _message;
    private HomePharmacyItemDto? _item;
    private int _quantity = 1;
    private int? _packageNumber;
    private DateTime? _expiresOnDate;
    private string? _notes;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _errorMessage = null;
        _message = null;

        try
        {
            _item = await HomePharmacyService.GetByIdAsync(Id);
            if (_item is null)
            {
                _errorMessage = "Kirjet ei leitud.";
                return;
            }

            _quantity = Math.Max(1, _item.Quantity);
            _packageNumber = _item.PackageNumber;
            _expiresOnDate = _item.ExpiresOn?.ToDateTime(TimeOnly.MinValue);
            _notes = _item.Notes;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task SaveAsync()
    {
        if (_isBusy || _item is null)
        {
            return;
        }

        _isBusy = true;
        _message = null;
        _errorMessage = null;

        try
        {
            var updated = await HomePharmacyService.UpdateAsync(_item.Id, new UpdateHomePharmacyItemDto
            {
                Quantity = Math.Max(1, _quantity),
                PackageNumber = _packageNumber,
                ExpiresOn = ToDateOnlyOrNull(_expiresOnDate),
                Notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim()
            });

            if (updated is null)
            {
                _errorMessage = "Kirjet ei leitud.";
                return;
            }

            _item = updated;
            _message = "Muudatused salvestatud.";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (_isBusy || _item is null)
        {
            return;
        }

        _isBusy = true;
        _message = null;
        _errorMessage = null;

        try
        {
            var removed = await HomePharmacyService.RemoveAsync(_item.Id);
            if (!removed)
            {
                _errorMessage = "Kirjet ei leitud.";
                return;
            }

            Navigation.NavigateTo("/mymedicine");
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private static DateOnly? ToDateOnlyOrNull(DateTime? value)
    {
        if (value is null)
        {
            return null;
        }

        return DateOnly.FromDateTime(value.Value);
    }

    private void BackToList()
    {
        Navigation.NavigateTo("/mymedicine");
    }
}
