@page "/scanner/result/{Barcode}"
@using MedScan.Shared.Models
@using MedScan.Shared.Services
@inject IAuthService AuthService
@inject IScannerFlowService ScannerFlowService
@inject NavigationManager Navigation

<PageTitle>Ravimi info</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else if (_isLoading)
{
    <p><em>Otsin ravimi infot...</em></p>
}
else if (_medication is null)
{
    <p><em>Tuvastatud triipkoodi andmeid ei leitud andmebaasist. Suunan ümber...</em></p>
}
else
{
    <div class="page-container">
        <div class="content-wrapper">
            <h1>@_medication.Name</h1>
            <p><strong>Toimeaine:</strong> @_medication.ActiveIngredient</p>
            <p><strong>Tugevus:</strong> @(_medication.Strength ?? "-")</p>
            <p><strong>Luhikirjeldus:</strong> @(_medication.ShortDescription ?? "-")</p>
            <p><strong>Hoiatused:</strong> @(_medication.Warnings ?? "-")</p>

            <hr />
            <h2>Lisa raviplaani</h2>
            <div class="scanner-form">
                <div class="form-group mb-3">
                    <label>Kordi paevas</label>
                    <input class="form-control" type="number" min="1" max="8" @bind="_frequencyPerDay" @bind:after="SyncScheduledTimes" />
                </div>

                @for (var i = 0; i < _scheduledTimeTexts.Count; i++)
                {
                    var index = i;
                    <div class="form-group mb-3">
                        <label>Meeldetuletuse aeg @(index + 1)</label>
                        <input class="form-control" type="time" value="@_scheduledTimeTexts[index]" @onchange="args => OnScheduledTimeChanged(index, args)" />
                    </div>
                }

                <div class="form-check mb-3">
                    <input class="form-check-input darker-border-checkbox" type="checkbox" id="remindersCheck" @bind="_remindersEnabled" />
                    <label class="form-check-label" for="remindersCheck">Meeldetuletused sees</label>
                </div>

                <div class="form-group mb-3">
                    <label>Markmed</label>
                    <textarea class="form-control" @bind="_notes"></textarea>
                </div>

                <button class="btn btn-success w-100 mb-3"
                        @onclick="AddToScheduleAsync"
                        disabled="@_isSavingMedication">
                    @(_isSavingMedication ? "Lisan..." : "Lisa raviplaani")
                </button>

                @if (!string.IsNullOrWhiteSpace(_addMessage))
                {
                    <p class="text-success">@_addMessage</p>
                }
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary flex-fill" @onclick="ScanAgain">
                    Skaneeri uuesti
                </button>
                <button class="btn btn-outline-secondary flex-fill" @onclick="OpenManualSearch">
                    Kasitsi otsimine
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Barcode { get; set; } = string.Empty;

    private bool _isReady;
    private bool _isLoading;
    private bool _isSavingMedication;
    private int _frequencyPerDay = 1;
    private readonly List<string> _scheduledTimeTexts = ["08:00"];
    private bool _remindersEnabled = true;
    private string? _notes;
    private string? _addMessage;
    private MedicationLookupResult? _medication;

    protected override async Task OnParametersSetAsync()
    {
        await AuthService.InitializeAsync();

        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
        _isLoading = true;

        try
        {
            _medication = await ScannerFlowService.FindByBarcodeAsync(Barcode);
            if (_medication == null)
            {
                Navigation.NavigateTo("/scanner/search");
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ScanAgain()
    {
        var scanResult = await ScannerFlowService.ScanAsync();
        if (scanResult.Status == MedScan.Shared.Models.BarcodeScanStatus.Success && !string.IsNullOrWhiteSpace(scanResult.Barcode))
        {
            Navigation.NavigateTo($"/scanner/result/{Uri.EscapeDataString(scanResult.Barcode)}");
        }
    }
    
    private void OpenManualSearch() => Navigation.NavigateTo("/scanner/search");

    private async Task AddToScheduleAsync()
    {
        if (_medication is null || _isSavingMedication)
        {
            return;
        }

        var parsedTimes = new List<TimeOnly>();
        foreach (var text in _scheduledTimeTexts)
        {
            if (!TimeOnly.TryParse(text, out var parsed))
            {
                _addMessage = "Sisesta koik meeldetuletuse ajad korrektselt.";
                return;
            }

            parsedTimes.Add(parsed);
        }

        _isSavingMedication = true;
        _addMessage = null;

        try
        {
            var result = await ScannerFlowService.AddMedicationToDefaultProfileAsync(
                _medication.Id,
                _frequencyPerDay,
                parsedTimes,
                _remindersEnabled,
                _notes);

            _addMessage = result.Message;
        }
        finally
        {
            _isSavingMedication = false;
        }
    }

    private Task SyncScheduledTimes()
    {
        _frequencyPerDay = Math.Clamp(_frequencyPerDay, 1, 8);

        while (_scheduledTimeTexts.Count < _frequencyPerDay)
        {
            _scheduledTimeTexts.Add("08:00");
        }

        while (_scheduledTimeTexts.Count > _frequencyPerDay)
        {
            _scheduledTimeTexts.RemoveAt(_scheduledTimeTexts.Count - 1);
        }

        return Task.CompletedTask;
    }

    private void OnScheduledTimeChanged(int index, ChangeEventArgs args)
    {
        _scheduledTimeTexts[index] = args.Value?.ToString() ?? _scheduledTimeTexts[index];
    }
}

