@page "/scanner/result/{Barcode}"
@using MedScan.Shared.Models
@using MedScan.Shared.Services
@inject AuthService AuthService
@inject IScannerFlowService ScannerFlowService
@inject NavigationManager Navigation

<PageTitle>Ravimi info</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else if (_isLoading)
{
    <p><em>Otsin ravimi infot...</em></p>
}
else if (_medication is null)
{
    <div class="scanner-page">
        <h1>Tundmatu triipkood</h1>
        <p>Tuvastatud triipkoodi andmeid ei leitud andmebaasist.</p>

        <div class="scanner-actions">
            <button class="btn btn-outline-primary" @onclick="ScanAgain">
                Skaneeri uuesti
            </button>
            <button class="btn btn-outline-secondary" @onclick="OpenManualSearch">
                Kasitsi otsimine
            </button>
        </div>
    </div>
}
else
{
    <div class="scanner-page">
        <h1>@_medication.Name</h1>
        <p><strong>Toimeaine:</strong> @_medication.ActiveIngredient</p>
        <p><strong>Tugevus:</strong> @(_medication.Strength ?? "-")</p>
        <p><strong>Luhikirjeldus:</strong> @(_medication.ShortDescription ?? "-")</p>
        <p><strong>Hoiatused:</strong> @(_medication.Warnings ?? "-")</p>

        <hr />
        <h2>Lisa raviplaani</h2>
        <div class="scanner-form">
            <label>
                Kordi paevas
                <input class="form-control" type="number" min="1" max="24" @bind="_frequencyPerDay" />
            </label>

            <label>
                Esimene meeldetuletuse aeg
                <input class="form-control" type="time" value="@_scheduledTimeText" @onchange="OnScheduledTimeChanged" />
            </label>

            <label class="scanner-toggle">
                <input type="checkbox" @bind="_remindersEnabled" />
                Meeldetuletused sees
            </label>

            <label>
                Markmed
                <textarea class="form-control" @bind="_notes"></textarea>
            </label>

            <button class="btn btn-success"
                    @onclick="AddToScheduleAsync"
                    disabled="@_isSavingMedication">
                @(_isSavingMedication ? "Lisan..." : "Lisa raviplaani")
            </button>

            @if (!string.IsNullOrWhiteSpace(_addMessage))
            {
                <p class="scanner-message">@_addMessage</p>
            }
        </div>

        <div class="scanner-actions">
            <button class="btn btn-outline-primary" @onclick="ScanAgain">
                Skaneeri uuesti
            </button>
            <button class="btn btn-outline-secondary" @onclick="OpenManualSearch">
                Kasitsi otsimine
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public string Barcode { get; set; } = string.Empty;

    private bool _isReady;
    private bool _isLoading;
    private bool _isSavingMedication;
    private int _frequencyPerDay = 1;
    private string _scheduledTimeText = "08:00";
    private bool _remindersEnabled = true;
    private string? _notes;
    private string? _addMessage;
    private MedicationLookupResult? _medication;

    protected override async Task OnParametersSetAsync()
    {
        await AuthService.InitializeAsync();

        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
        _isLoading = true;

        try
        {
            _medication = await ScannerFlowService.FindByBarcodeAsync(Barcode);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ScanAgain() => Navigation.NavigateTo("/scanner");
    private void OpenManualSearch() => Navigation.NavigateTo("/scanner/search");

    private async Task AddToScheduleAsync()
    {
        if (_medication is null || _isSavingMedication)
        {
            return;
        }

        if (!TimeOnly.TryParse(_scheduledTimeText, out var scheduledTime))
        {
            _addMessage = "Sisesta korrektne kellaaeg.";
            return;
        }

        _isSavingMedication = true;
        _addMessage = null;

        try
        {
            var result = await ScannerFlowService.AddMedicationToDefaultProfileAsync(
                _medication.Id,
                _frequencyPerDay,
                [scheduledTime],
                _remindersEnabled,
                _notes);

            _addMessage = result.Message;
        }
        finally
        {
            _isSavingMedication = false;
        }
    }

    private void OnScheduledTimeChanged(ChangeEventArgs args)
    {
        _scheduledTimeText = args.Value?.ToString() ?? _scheduledTimeText;
    }
}
