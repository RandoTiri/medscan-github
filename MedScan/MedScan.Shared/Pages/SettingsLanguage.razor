@page "/settings/language"
@using MedScan.Shared.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Keel</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else
{
    <div class="settings-subpage">
        <div class="settings-subpage-content">
            <button class="back-link" @onclick="GoBack">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Seaded
            </button>

            <h1 class="page-title">Keel</h1>

            <div class="settings-card">
                <div class="settings-item selected">
                    <div class="item-text">
                        <h3>Eesti keel</h3>
                        <p>Ainus saadaval olev valik</p>
                    </div>
                    <svg class="check-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .settings-subpage {
        width: 100vw;
        position: relative;
        left: 50%;
        margin-left: -50vw;
        margin-top: -1.1rem;
        min-height: 100vh;
        background: var(--ms-bg);
        padding-top: calc(max(20px, env(safe-area-inset-top)) + 18px);
        padding-bottom: calc(max(20px, env(safe-area-inset-bottom)) + 84px);
        padding-left: max(20px, env(safe-area-inset-left));
        padding-right: max(20px, env(safe-area-inset-right));
        box-sizing: border-box;
    }

    .settings-subpage-content {
        max-width: 560px;
        margin: 0 auto;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        border: none;
        background: transparent;
        color: var(--ms-accent);
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        padding: 10px 0;
        margin-bottom: 12px;
        margin-top: 16px;
    }

    .back-link svg {
        margin-right: 8px;
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: var(--ms-text);
        margin: 0 0 20px 0;
    }

    .settings-card {
        background: var(--ms-surface);
        border-radius: 15px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        overflow: hidden;
    }

    .settings-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 16px;
        gap: 14px;
    }

    .settings-item.selected {
        background: var(--ms-surface-soft);
    }

    .item-text h3 {
        margin: 0;
        font-size: 16px;
        color: var(--ms-text);
        font-weight: 700;
    }

    .item-text p {
        margin: 3px 0 0 0;
        font-size: 13px;
        color: var(--ms-text-muted);
    }

    .check-icon {
        color: var(--ms-accent);
        flex-shrink: 0;
    }
</style>

@code {
    private bool _isReady;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
    }

    private void GoBack() => Navigation.NavigateTo("/settings");
}
