@page "/update-password"
@layout MedScan.Shared.Layout.AuthLayout
@using MedScan.Shared.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>MedScan - Uuenda parool</PageTitle>

<style>
    .update-container {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        display: flex;
        flex-direction: column;

        width: 100%;
        min-height: 100vh;
        background-color: #fff;
        max-width: 450px;
        margin: 0 auto;
        color: #1c3d4f;
        box-sizing: border-box;

        padding-top: 0;
        padding-bottom: calc(max(20px, env(safe-area-inset-bottom)) + 20px);
        padding-left: max(0px, env(safe-area-inset-left));
        padding-right: max(0px, env(safe-area-inset-right));
    }
    .header-section {
        background: linear-gradient(180deg, #ecf7f4 0%, #fff 100%);
        padding: calc(max(20px, env(safe-area-inset-top)) + 40px) 30px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    .form-section {
        padding: 20px 30px;
        display: flex;
        flex-direction: column;
    }
    .title {
        font-size: 26px;
        font-weight: 700;
        margin: 20px 0 30px;
        color: #0b2b40;
    }
    .auth-input-group {
        margin-bottom: 20px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        width: 100%;
        box-sizing: border-box;
    }
    .auth-input-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 8px;
        color: #1c3d4f;
        text-align: left;
        width: 100%;
    }
    .input-wrapper {
        display: flex;
        align-items: center;
        border: 2px solid #d4dfe5;
        border-radius: 16px;
        overflow: hidden;
        padding: 0 15px;
        background: #fafafc;
        width: 100%;
        box-sizing: border-box;
        transition: all 0.2s ease;
    }
    .input-wrapper:focus-within {
        border-color: #267863;
        background: #fff;
        box-shadow: 0 0 0 4px rgba(38, 120, 99, 0.1);
    }
    .input-wrapper input {
        border: none;
        outline: none;
        padding: 15px 10px;
        width: 100%;
        font-size: 14px;
        color: #1c3d4f;
        background: transparent;
    }
    .input-wrapper input::placeholder {
        color: #a0b6c2;
    }
    .input-icon, .input-action {
        color: #a0b6c2;
        display: flex;
        flex-shrink: 0;
        cursor: pointer;
        padding: 5px;
    }
    .input-action:hover {
        color: #267863;
    }
    .btn-primary {
        background-color: #267863;
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 16px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 4px 10px rgba(38, 120, 99, 0.2);
        width: 100%;
        transition: all 0.1s ease;
        margin-top: 10px;
    }
    .btn-primary:active {
        transform: scale(0.98);
        background-color: #1e604f;
    }
    .btn-primary:disabled {
        opacity: 0.7;
        transform: none;
    }
    .success-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-top: 50px;
    }
    .success-icon {
        color: #267863;
        margin-bottom: 20px;
    }
    .success-message {
        font-size: 18px;
        font-weight: bold;
        color: #2e7d32;
        margin-bottom: 30px;
    }
    .auth-error {
        color: #e53935;
        background: #ffebee;
        padding: 10px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 14px;
    }
</style>

<div class="update-container">
    @if (IsSuccess)
    {
        <div class="form-section">
            <div class="success-container">
                <div class="success-icon">
                    <svg viewBox="0 0 24 24" width="80" height="80" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                </div>
                <div class="success-message">Olete edukalt parooli muutnud!</div>
                <button class="btn-primary" @onclick="GoToLogin">Logi sisse</button>
            </div>
        </div>
    }
    else
    {
        <div class="header-section">
            <h1 class="title">Uuenda parool</h1>
        </div>

        <div class="form-section">
            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="auth-error">@ErrorMessage</div>
        }

        <div class="auth-input-group">
            <label for="password">Sisesta parool</label>
            <div class="input-wrapper">
                <div class="input-icon">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                </div>
                <input id="password" type="@PasswordInputType" placeholder="••••••••" @bind="Password" disabled="@IsBusy" />
                <div class="input-action" @onclick="TogglePasswordVisibility">
                    @if (ShowPassword)
                    {
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
                            <line x1="1" y1="1" x2="23" y2="23"></line>
                        </svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                    }
                </div>
            </div>
        </div>

        <div class="auth-input-group">
            <label for="confirm-password">Sisesta parool uuesti</label>
            <div class="input-wrapper">
                <div class="input-icon">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                </div>
                <input id="confirm-password" type="@ConfirmPasswordInputType" placeholder="••••••••" @bind="ConfirmPassword" disabled="@IsBusy" />
                <div class="input-action" @onclick="ToggleConfirmPasswordVisibility">
                    @if (ShowConfirmPassword)
                    {
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
                            <line x1="1" y1="1" x2="23" y2="23"></line>
                        </svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                    }
                </div>
            </div>
        </div>

        <button class="btn-primary" @onclick="HandleUpdatePassword" disabled="@IsBusy">
            @(IsBusy ? "Uuendab..." : "Uuenda parool")
        </button>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    [SupplyParameterFromQuery]
    public string? Code { get; set; }

    private string Password = string.Empty;
    private string ConfirmPassword = string.Empty;
    private string ErrorMessage = string.Empty;
    private bool IsBusy;
    private bool IsSuccess;

    private bool ShowPassword = false;
    private string PasswordInputType => ShowPassword ? "text" : "password";

    private bool ShowConfirmPassword = false;
    private string ConfirmPasswordInputType => ShowConfirmPassword ? "text" : "password";

    private void TogglePasswordVisibility()
    {
        ShowPassword = !ShowPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        ShowConfirmPassword = !ShowConfirmPassword;
    }

    private async Task HandleUpdatePassword()
    {
        if (IsBusy) return;

        IsBusy = true;
        ErrorMessage = string.Empty;

        try
        {
            if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Code))
            {
                ErrorMessage = "E-mail või kinnituskood on puudu. Palun alusta parooli lähtestamist uuesti.";
                return;
            }

            if (string.IsNullOrWhiteSpace(Password) || string.IsNullOrWhiteSpace(ConfirmPassword))
            {
                ErrorMessage = "Palun täida kõik väljad.";
                return;
            }

            if (Password.Length < 6)
            {
                ErrorMessage = "Parool peab olema olema vähemalt 6 tähemärki pikk.";
                return;
            }

            if (Password != ConfirmPassword)
            {
                ErrorMessage = "Paroolid ei kattu.";
                return;
            }

            var result = await AuthService.ResetPasswordAsync(Email, Code, Password);

            if (result.Success)
            {
                IsSuccess = true;
            }
            else
            {
                ErrorMessage = result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Tehniline viga: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }
}

