    </div>

    <style>
        .mobile-container {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            min-height: 100vh;
            display: flex;
            flex-direction: column;

            width: 100vw;
            position: relative;
            left: 50%;
            margin-left: -50vw;
            margin-top: -1.1rem;

            padding-bottom: calc(max(24px, env(safe-area-inset-bottom)) + 80px);
            padding-left: max(0px, env(safe-area-inset-left));
            padding-right: max(0px, env(safe-area-inset-right));
            box-sizing: border-box;
        }

        .settings-content {
            padding: 20px;
            padding-top: calc(max(20px, env(safe-area-inset-top)) + 20px);
            max-width: 600px;
            margin: 0 auto;
            width: 100%;
        }

        .page-title {
            font-size: 24px;
            font-weight: bold;
            color: #1a4a3c;
            margin-bottom: 20px;
            margin-top: 10px;
        }

        .profile-summary-card {
            background-color: #258d6b;
            color: white;
            border-radius: 15px;
            padding: 20px;
            display: flex;
            align-items: center;
            margin-bottom: 30px;
            box-shadow: 0 4px 10px rgba(37,141,107,0.2);
        }

        .profile-avatar-lg {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            border: 2px solid white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: bold;
            margin-right: 15px;
            flex-shrink: 0;
        }

        .profile-summary-info {
            flex-grow: 1;
        }
        
        .profile-summary-info h2 {
            margin: 0;
            font-size: 18px;
            font-weight: bold;
        }
        .profile-summary-info p {
            margin: 2px 0 5px 0;
            font-size: 14px;
            opacity: 0.9;
        }
        .user-meta {
            font-size: 12px;
            opacity: 0.8;
        }
        
        .right-arrow {
            font-size: 24px;
            color: #a0b0aa;
            margin-left: 10px;
        }
        .profile-summary-card .right-arrow {
            color: rgba(255,255,255,0.7);
        }

        .settings-section {
            margin-bottom: 25px;
        }
        .section-label {
            font-size: 12px;
            font-weight: bold;
            color: #90a09a;
            margin-bottom: 10px;
            display: block;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .settings-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }

        .settings-item {
            display: flex;
            align-items: center;
            padding: 15px;
            cursor: pointer;
        }
        .item-divider {
            height: 1px;
            background-color: #f0f0f0;
            margin: 0 15px;
        }

        .icon-wrapper {
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            flex-shrink: 0;
            background-color: transparent;
        }

        .item-text {
            flex-grow: 1;
        }
        
        .item-text h3 {
            margin: 0;
            font-size: 16px;
            color: #1a4a3c;
            font-weight: bold;
        }
        .item-text p {
            margin: 2px 0 0 0;
            font-size: 13px;
            color: #90a09a;
        }
        
        .logout-btn {
            width: 100%;
            background-color: #fef2f2;
            color: #cf3d3d;
            border: 1px solid #fce7e7;
            padding: 15px;
            border-radius: 12px;
            font-size: 16px;
            font-weight: bold;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            margin-top: 10px;
            cursor: pointer;
        }

        .version-info {
            text-align: center;
            margin-top: 20px;
            font-size: 12px;
            color: #b0c0ba;
        }
    </style>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
        }
    }

    private string GetInitials()
    {
        var name = AuthService.CurrentUser?.FullName;
        if (string.IsNullOrWhiteSpace(name)) return "NA";
        
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        
        return (parts[0].Substring(0, 1) + parts[^1].Substring(0, 1)).ToUpper();
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", true);
    }

}
