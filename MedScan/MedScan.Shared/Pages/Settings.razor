            justify-content: center;
            align-items: center;
            gap: 8px;
            margin-top: 10px;
            cursor: pointer;
        }

        .version-info {
            text-align: center;
            margin-top: 20px;
            font-size: 12px;
            color: #b0c0ba;
        }
    </style>
}

@code {
    private int _mainProfileId;
    private Patient? _mainUserProfile;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadMainProfileAsync();
    }

    private async Task LoadMainProfileAsync()
    {
        var profiles = await ProfileService.GetMyProfilesAsync();

        _mainProfileId = AuthService.CurrentUser?.DefaultProfileId
            ?? profiles.FirstOrDefault(p => p.Type.Equals("Ise", StringComparison.OrdinalIgnoreCase))?.Id
            ?? 0;

        var profile = profiles.FirstOrDefault(p => p.Id == _mainProfileId)
            ?? profiles.FirstOrDefault(p => p.Type.Equals("Ise", StringComparison.OrdinalIgnoreCase));

        _mainUserProfile = profile is null
            ? null
            : new Patient
            {
                Id = profile.Id,
                Name = profile.Name,
                BirthDate = profile.BirthDate,
                Gender = string.IsNullOrWhiteSpace(profile.Gender) ? "Määramata" : profile.Gender
            };
    }

    private string GetMainUserDetails()
    {
        if (_mainUserProfile is null)
        {
            return "Vanus puudub · Määramata";
        }

        var age = _mainUserProfile.Age > 0 ? $"{_mainUserProfile.Age} a" : "Vanus puudub";
        return $"{age} · {_mainUserProfile.Gender}";
    }

    private void OpenMainProfileView()
    {
        if (_mainProfileId > 0)
        {
            Navigation.NavigateTo($"/settings/main-profile/{_mainProfileId}");
        }
    }

    private string GetInitials()
    {
        var name = AuthService.CurrentUser?.FullName;
        if (string.IsNullOrWhiteSpace(name)) return "NA";
        
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        
        return (parts[0].Substring(0, 1) + parts[^1].Substring(0, 1)).ToUpper();
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", true);
    }

}

