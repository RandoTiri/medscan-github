            width: 24px;
            height: 24px;
        }
        .profile-summary-card .right-arrow {
            color: rgba(255,255,255,0.7);
        }

        .settings-section {
            margin-bottom: 25px;
        }
        .section-label {
            font-size: 12px;
            font-weight: bold;
            color: #90a09a;
            margin-bottom: 10px;
            display: block;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .settings-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }

        .settings-item {
            display: flex;
            align-items: center;
            padding: 15px;
            cursor: pointer;
        }
        .item-divider {
            height: 1px;
            background-color: #f0f0f0;
            margin: 0 15px;
        }

        .icon-wrapper {
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            flex-shrink: 0;
            background-color: transparent;
        }

        .item-text {
            flex-grow: 1;
        }
        
        .item-text h3 {
            margin: 0;
            font-size: 16px;
            color: #1a4a3c;
            font-weight: bold;
        }
        .item-text p {
            margin: 2px 0 0 0;
            font-size: 13px;
            color: #90a09a;
