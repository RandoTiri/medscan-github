                    <div class="settings-item">
                        <div class="icon-wrapper">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#258d6b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                        </div>
                        <div class="item-text">
                            <h3>Turvalisus</h3>
                            <p>Parool ja autentimine</p>
                        </div>
                        <div class="right-arrow">›</div>
                    </div>
                </div>
            </div>

            <div class="settings-section">
                <span class="section-label">RAKENDUS</span>
                <div class="settings-card">
                    <div class="settings-item">
                        <div class="icon-wrapper">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f5a623" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 17H2a3 3 0 0 0 3-3V9a7 7 0 0 1 14 0v5a3 3 0 0 0 3 3zm-8.27 4a2 2 0 0 1-3.46 0"></path></svg>
                        </div>
                        <div class="item-text">
                            <h3>Meeldetuletused</h3>
                            <p>Teavitused ja helid</p>
                        </div>
                        <div class="right-arrow">›</div>
                    </div>
                    <div class="item-divider"></div>
                    <div class="settings-item">
                        <div class="icon-wrapper">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#8a4baf" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                        </div>
                        <div class="item-text">
                            <h3>Välimus</h3>
                            <p>Heledus ja teema</p>
                        </div>
                        <div class="right-arrow">›</div>
                    </div>
                    <div class="item-divider"></div>
                    <div class="settings-item">
                        <div class="icon-wrapper">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                        </div>
                        <div class="item-text">
                            <h3>Keel</h3>
                            <p>Eesti keel</p>
                        </div>
                        <div class="right-arrow">›</div>
                    </div>
                </div>
            </div>

            <div class="settings-section">
                <span class="section-label">ANDMED</span>
                <div class="settings-card">
                    @* <div class="settings-item" @onclick="GoToMyMedicine">
                        <div class="icon-wrapper">
                           <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#258d6b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.5 20.5l-6-6a4.95 4.95 0 1 1 7-7l6 6a4.95 4.95 0 1 1-7 7z"></path><line x1="8.5" y1="8.5" x2="15.5" y2="15.5"></line></svg>
                        </div>
                        <div class="item-text">
                            <h3>Minu ravimid</h3>
                            <p>Ava koduapteegi vaade</p>
                        </div>
                        <div class="right-arrow">›</div>
                    </div>
                    <div class="item-divider"></div> *@
                    <div class="settings-item">
                        <div class="icon-wrapper">
                           <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#258d6b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                        </div>
                        <div class="item-text">
                            <h3>Ravimiregister</h3>
                            <p>www.ravimiregister.ee</p>
                        </div>
                        <div class="right-arrow">›</div>
                    </div>
                    <div class="item-divider"></div>
                    <div class="settings-item">
                        <div class="icon-wrapper">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#8a4baf" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
