@page "/home-pharmacy/save-medication/{Barcode}"
@using MedScan.Shared.Models
@using MedScan.Shared.Services
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject IScannerFlowService ScannerFlowService

<PageTitle>Liiguta apteeki - @_medication?.Name</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else if (_isLoading)
{
    <p><em>Laadin ravimi andmeid...</em></p>
}
else if (_medication is null)
{
    <p><em>Ravimit ei leitud.</em></p>
}
else
{
    <div class="medicine-screen">
        <div class="medicine-header">
            <button class="back-link" @onclick="BackToSearch">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Tagasi
            </button>
            <h1>Ravimi info</h1>
            <span class="header-spacer"></span>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="error-box">@_message</div>
        }

        <div class="content-scroll">
            <div class="section-card medication-card">
                <div class="field-title">Ravim</div>
                <div class="medication-name">@_medication.Name</div>
            </div>

            <div class="info-card">
                <div class="card-title">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#267863" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                        <polyline points="9 12 11 14 15 10"></polyline>
                    </svg>
                    Põhiinfo
                </div>
                <div class="info-row">
                    <span class="label">Toimeaine</span>
                    <span class="val">@_medication.ActiveIngredient</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(_medication.MedicationForm))
                {
                    <div class="info-row">
                        <span class="label">Ravimivorm</span>
                        <span class="val">@_medication.MedicationForm</span>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_medication.Strength))
                {
                    <div class="info-row">
                        <span class="label">Tugevus</span>
                        <span class="val">@_medication.Strength</span>
                    </div>
                }
                <div class="info-row">
                    <span class="label">Pakendi kogus</span>
                    <span class="val">@FormatPackSize(_medication.PackSize)</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(_medication.ShortDescription))
                {
                    <div class="info-row">
                        <span class="label">Näidustus</span>
                        <span class="val">@_medication.ShortDescription</span>
                    </div>
                }
                <div class="info-row">
                    <span class="label">Säilimisaeg</span>
                    <span class="val">@ShelfLifeDisplay</span>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_medication.Warnings))
            {
                <div class="warnings-card">
                    <div class="card-title warning-title">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                            <line x1="12" y1="9" x2="12" y2="13"></line>
                            <line x1="12" y1="17" x2="12.01" y2="17"></line>
                        </svg>
                        Hoiatused
                    </div>
                    <div class="warning-list">
                        @foreach (var warning in _medication.Warnings.Split(new[] { '\n', ';' }, StringSplitOptions.RemoveEmptyEntries))
                        {
                            <div class="warning-item">
                                <span class="warning-icon">⚠</span>
                                <span>@warning.Trim()</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="action-bar">
            <button class="action-btn action-pdf" @onclick="OpenPdfAsync">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
                Ametlik infoleht (PDF)
            </button>
            <button class="action-btn action-save" @onclick="OpenAddMedicationPage">
                + Lisa nimekirja
            </button>
        </div>
    </div>
}

<style>
    .medicine-screen {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background: var(--ms-bg);
        min-height: 100vh;
        width: 100vw;
        position: relative;
        left: 50%;
        margin-left: -50vw;
        margin-top: 0;
        box-sizing: border-box;
        padding-top: calc(max(32px, env(safe-area-inset-top)));
        padding-bottom: calc(env(safe-area-inset-bottom) + 160px);
        color-scheme: light;
    }

    .medicine-header {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 8px;
        padding: 6px 16px 14px 16px;
        background: var(--ms-bg);
        border-bottom: 1px solid var(--ms-divider);
    }

    .medicine-header h1 {
        margin: 0;
        font-size: 24px;
        color: #1A2E29;
        font-weight: 800;
        text-align: center;
    }

    .header-spacer {
        width: 56px;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        border: none;
        background: transparent;
        color: #277863;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        padding: 10px 0;
        text-decoration: none;
    }

    .back-link svg {
        margin-right: 8px;
        width: 24px;
        height: 24px;
    }

    .content-scroll {
        background: var(--ms-bg);
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .section-card {
        background: #ffffff;
        border: 1px solid var(--ms-divider);
        border-radius: 16px;
        padding: 16px;
    }

    .medication-card {
    }

    .field-title {
        margin-bottom: 8px;
        font-size: 16px;
        color: #1A2E29;
        font-weight: 600;
    }

    .medication-name {
        font-size: 18px;
        font-weight: 600;
        color: #277863;
        background-color: #F6FBF8;
        padding: 12px;
        border-radius: 12px;
    }

    .header-card {
        display: flex;
        align-items: center;
        gap: 16px;
        background: var(--ms-surface);
        border: 1px solid var(--ms-divider);
        border-radius: 16px;
        padding: 20px;
    }

    .pill-icon {
        background: #e6f2ee;
        border-radius: 16px;
        width: 64px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .header-info h2 {
        margin: 0 0 4px 0;
        font-size: 20px;
        color: var(--ms-text);
        font-weight: 800;
    }

    .header-info p {
        margin: 0;
        color: var(--ms-text-muted);
        font-size: 14px;
    }

    .info-card {
        background: var(--ms-surface);
        border: 1px solid var(--ms-divider);
        border-radius: 16px;
        padding: 16px;
    }

    .card-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 16px;
        color: #1A2E29;
        font-weight: 600;
        margin-bottom: 12px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 10px;
        padding: 10px 0;
    }

    .info-row:not(:last-child) {
        border-bottom: 0.5px solid #A0B6C2;
    }

    .info-row .label {
        color: #1A2E29;
        font-size: 14px;
        font-weight: 400;
    }

    .info-row .val {
        color: #1A2E29;
        font-size: 14px;
        font-weight: 700;
        text-align: right;
        flex: 1;
        word-break: break-word;
    }

    .warnings-card {
        background: #fffbef;
        border: 1px solid #E8BD4F;
        border-radius: 16px;
        padding: 16px;
    }

    .warning-title {
        color: #b45502;
        font-size: 16px;
        font-weight: 600;
    }

    .warning-list {
        display: grid;
        gap: 8px;
    }

    .warning-item {
        color: #b45502;
        font-size: 14px;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 8px;
        padding: 10px 0;
    }

    .warning-item:not(:last-child) {
        border-bottom: 0.5px solid #E8BD4F;
    }

    .warning-icon {
        color: #b45502;
    }

    .action-bar {
        padding: 16px;
        display: grid;
        gap: 12px;
        z-index: 40;
    }

    .action-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        border-radius: 12px;
        padding: 14px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.1s ease;
    }

    .action-btn:active {
        transform: scale(0.98);
    }

    .action-pdf {
        background-color: #ffffff;
        color: #277863;
        border: 2px solid #277863;
    }

    .action-pdf:active {
        background-color: #f0f7f5;
    }

    .action-save {
        background: #277863;
        color: #fff;
        border: none;
    }

    .action-save:disabled {
        opacity: 0.7;
    }

    .error-box {
        border-radius: 14px;
        padding: 12px;
        font-size: 15px;
        margin: 16px 16px 0 16px;
        background: #fde9eb;
        color: #ab3f4c;
    }
</style>

@code {
    [Parameter] public string Barcode { get; set; } = string.Empty;
    [SupplyParameterFromQuery(Name = "profileId")] public int? ProfileId { get; set; }
    [SupplyParameterFromQuery(Name = "exp")] public string? ExpirationQuery { get; set; }
    [SupplyParameterFromQuery(Name = "lot")] public string? BatchQuery { get; set; }

    private bool _isReady;
    private bool _isLoading;
    private int _targetProfileId;
    
    private MedicationLookupResult? _medication;
    private string? _message;
    private DateOnly? _expirationDate;
    private string? _batchNumber;
    private string ShelfLifeDisplay => (_expirationDate ?? DateOnly.FromDateTime(DateTime.Now.AddYears(2))).ToString("dd.MM.yyyy");

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _targetProfileId = ResolveTargetProfileId();
        if (_targetProfileId <= 0)
        {
            _message = "Vaikimisi profiili ei leitud.";
        }

        _isReady = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_isReady)
        {
            _isLoading = true;
            try
            {
                _expirationDate = ParseExpirationQuery(ExpirationQuery);
                _batchNumber = ParseBatchQuery(BatchQuery);
                _medication = await ScannerFlowService.FindByBarcodeAsync(Barcode);
                if (_medication == null)
                {
                    _message = "Ravimit ei leitud.";
                }
            }
            catch
            {
                _message = "Ravimi andmete laadimine ebaõnnestus.";
            }
            finally
            {
                _isLoading = false;
            }
        }
    }

    private int ResolveTargetProfileId()
    {
        if (ProfileId is int routeProfileId && routeProfileId > 0)
        {
            return routeProfileId;
        }

        return AuthService.CurrentUser?.DefaultProfileId ?? 0;
    }

    private void OpenAddMedicationPage()
    {
        if (_medication is null)
        {
            return;
        }

        if (_targetProfileId > 0)
        {
            var route = $"/home-pharmacy/add-medication/{Uri.EscapeDataString(_medication.Barcode)}?profileId={_targetProfileId}";
            if (_expirationDate is DateOnly expirationDate)
            {
                route += $"&exp={Uri.EscapeDataString(expirationDate.ToString("yyyy-MM-dd"))}";
            }
            if (!string.IsNullOrWhiteSpace(_batchNumber))
            {
                route += $"&lot={Uri.EscapeDataString(_batchNumber)}";
            }

            Navigation.NavigateTo(route);
            return;
        }

        var fallbackRoute = $"/home-pharmacy/add-medication/{Uri.EscapeDataString(_medication.Barcode)}";
        if (_expirationDate is DateOnly fallbackExpirationDate)
        {
            fallbackRoute += $"?exp={Uri.EscapeDataString(fallbackExpirationDate.ToString("yyyy-MM-dd"))}";
        }
        if (!string.IsNullOrWhiteSpace(_batchNumber))
        {
            fallbackRoute += fallbackRoute.Contains('?')
                ? $"&lot={Uri.EscapeDataString(_batchNumber)}"
                : $"?lot={Uri.EscapeDataString(_batchNumber)}";
        }

        Navigation.NavigateTo(fallbackRoute);
    }

    private void OpenPdfAsync()
    {
        if (_medication is null || string.IsNullOrWhiteSpace(_medication.PdfUrl))
        {
            _message = "Ametlik infoleht puudub.";
            return;
        }

        Navigation.NavigateTo(_medication.PdfUrl, true);
    }

    private void BackToSearch()
    {
        Navigation.NavigateTo($"/home-pharmacy/search?ProfileId={ProfileId}");
    }

    private static DateOnly? ParseExpirationQuery(string? query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return null;
        }

        return DateOnly.TryParse(query, out var parsed) ? parsed : null;
    }

    private static string? ParseBatchQuery(string? query)
    {
        return string.IsNullOrWhiteSpace(query) ? null : query.Trim();
    }

    private static string FormatPackSize(string? packSize)
    {
        if (string.IsNullOrWhiteSpace(packSize))
        {
            return "-";
        }

        var digits = new string(packSize.Where(char.IsDigit).ToArray());
        return string.IsNullOrWhiteSpace(digits) ? packSize.Trim() : digits;
    }
}
