@page "/home-pharmacy"
@using MedScan.Shared.DTOs.HomePharmacy
@using MedScan.Shared.Models
@using MedScan.Shared.DTOs.Medication
@using MedScan.Shared.Models.Enums
@using MedScan.Shared.Services
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject IProfileService ProfileService
@inject IHomePharmacyService HomePharmacyService
@inject IScannerFlowService ScannerFlowService
@inject IMedicationService MedicationService

<PageTitle>Ravimid</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else
{
    <div class="medicine-screen">
        <div class="medicine-header">
            <span class="header-spacer"></span>
            <h1>Ravimid</h1>
            <button class="add-med-btn" @onclick="OpenAddPageAsync">+ Lisa</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="error-box">@_errorMessage</div>
        }

        <div class="profiles-row">
            @foreach (var profile in _profiles)
            {
                var active = profile.Id == _selectedProfileId;
                <button class="profile-chip @(active ? "active" : null)" @onclick="() => SelectProfileAsync(profile.Id)">
                    <span>@profile.Name</span>
                    <span class="count-badge">@GetProfileCount(profile.Id)</span>
                </button>
            }
        </div>

        @if (_selectedProfileId > 0)
        {
            <div class="schedule-toggle-container">
                <button class="schedule-toggle-btn @(_showSchedule ? "active" : "")" @onclick="ToggleScheduleView">
                    <span class="icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                    </span>
                    Raviskeem
                </button>
            </div>
        }

        @if (_isLoading)
        {
            <div class="redirect-loading-container">
                <div class="spinner-wrap" aria-label="Laadimine">
                    <div class="spinner-ring"></div>
                    <div class="spinner-icon">
                        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"></path>
                            <path d="m8.5 8.5 7 7"></path>
                        </svg>
                    </div>
                </div>
                <p>Laen koduapteegi ravimeid...</p>
            </div>

            <style>
                .redirect-loading-container {
                    min-height: 100vh;
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    justify-content: center;
                    gap: 14px;
                    color: #5f6f7d;
                }

                .spinner-wrap {
                    width: 88px;
                    height: 88px;
                    position: relative;
                    display: grid;
                    place-items: center;
                }

                .spinner-ring {
                    width: 88px;
                    height: 88px;
                    border-radius: 50%;
                    border: 6px solid #cfe8df;
                    border-top-color: #258d6b;
                    animation: home-login-spin 0.9s linear infinite;
                    box-sizing: border-box;
                }

                .spinner-icon {
                    position: absolute;
                    color: #258d6b;
                    display: grid;
                    place-items: center;
                }

                @@keyframes home-login-spin {
                    to {
                        transform: rotate(360deg);
                    }
                }
            </style>

        }
        else if (_showSchedule)
        {
            if (_scheduledMedications.Count == 0)
            {
                <div class="empty-state">Sellel profiilil pole aktiivset raviskeemi.</div>
            }
            else
            {
                <div class="medicine-cards">
                    @foreach (var med in _scheduledMedications)
                    {
                        <button class="medicine-card schedule-card" @onclick="() => OpenScheduledMedicationDetails(med)">
                            <div class="left-icon">R</div>
                            <div class="card-content">
                                <div class="top-line">
                                    <h2>@med.MedicationName</h2>
                                </div>
                                <p class="meta-line">@FormatSchedule(med)</p>
                                @if (!string.IsNullOrWhiteSpace(med.Notes))
                                {
                                    <p class="note-line">@med.Notes</p>
                                }
                            </div>
                            <span class="open-arrow" aria-hidden="true">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="9 18 15 12 9 6"></polyline>
                                </svg>
                            </span>
                        </button>
                    }
                </div>
            }
        }
        else if (_selectedItems.Count == 0)
        {
            <div class="empty-state">Selles profiilis pole veel koduapteegi ravimeid.</div>
        }
        else
        {
            <div class="medicine-cards">
                @foreach (var item in _selectedItems)
                {
                    <button class="medicine-card" @onclick="() => OpenDetails(item.Id)">
                        <div class="left-icon">R</div>

                        <div class="card-content">
                            <div class="top-line">
                                <h2>@item.MedicationName</h2>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(item.ActiveIngredient))
                            {
                                <p class="meta-line">@item.ActiveIngredient @(string.IsNullOrWhiteSpace(item.Strength) ? string.Empty : $"· {item.Strength}")</p>
                            }
                            else if (!string.IsNullOrWhiteSpace(item.Strength))
                            {
                                <p class="meta-line">@item.Strength</p>
                            }

                            <p class="quantity-line">@BuildShelfLifeLabel(item.ExpiresOn)</p>

                            @if (item.PackageNumber is not null || !string.IsNullOrWhiteSpace(item.BatchNumber))
                            {
                                <p class="meta-line">
                                    @if (item.PackageNumber is not null)
                                    {
                                        <span>Karp #@item.PackageNumber</span>
                                    }
                                    @if (item.PackageNumber is not null && !string.IsNullOrWhiteSpace(item.BatchNumber))
                                    {
                                        <span> · </span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.BatchNumber))
                                    {
                                        <span>LOT: @item.BatchNumber</span>
                                    }
                                </p>
                            }

                        </div>

                        <span class="open-arrow" aria-hidden="true">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 18 15 12 9 6"></polyline>
                            </svg>
                        </span>
                    </button>
                }
            </div>
        }
    </div>
}

<style>
    .medicine-screen {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background: var(--ms-bg);
        min-height: 100vh;
        width: 100vw;
        position: relative;
        left: 50%;
        margin-left: -50vw;
        margin-top: -1.1rem;
        box-sizing: border-box;
        padding: 20px;
        padding-top: calc(max(20px, env(safe-area-inset-top)) + 20px);
        padding-bottom: calc(max(24px, env(safe-area-inset-bottom)) + 80px);
        padding-left: max(12px, env(safe-area-inset-left));
        padding-right: max(12px, env(safe-area-inset-right));
    }

    .medicine-header {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 8px;
        padding: 6px 6px 14px 6px;
        border-bottom: 1px solid var(--ms-divider);
    }

    .medicine-header h1 {
        margin: 0;
        font-size: 22px;
        letter-spacing: -0.02em;
        color: var(--ms-text);
        font-weight: 800;
        text-align: center;
    }

    .header-spacer {
        width: 52px;
    }

    .add-med-btn {
        border: none;
        border-radius: 8px;
        background: #3b705e;
        color: #fff;
        padding: 12px 16px;
        font-size: 16px;
        font-weight: 700;
        line-height: 1;
        cursor: pointer;
        box-shadow: 0 4px 10px rgba(37, 141, 107, 0.2);
    }

    .add-med-btn:active {
        transform: scale(0.98);
    }

    .profiles-row {
        display: flex;
        gap: 14px;
        padding: 12px 6px 10px;
        border-bottom: 1px solid var(--ms-divider);
        margin-bottom: 12px;
        overflow-x: auto;
    }

    .profile-chip {
        border: 0;
        border-bottom: 4px solid transparent;
        background: transparent;
        color: var(--ms-text-muted);
        font-size: 17px;
        font-weight: 600;
        padding: 0 2px 8px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .profile-chip.active {
        color: #2f6654;
        border-bottom-color: #3b705e;
    }

    .count-badge {
        min-width: 28px;
        height: 28px;
        border-radius: 999px;
        background: var(--ms-divider);
        color: var(--ms-text-muted);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 8px;
        font-size: 14px;
        font-weight: 700;
    }

    .profile-chip.active .count-badge {
        background: #3b705e;
        color: #fff;
    }

    .medicine-cards {
        display: grid;
        gap: 12px;
    }

    .medicine-card {
        border: 0;
        width: 100%;
        text-align: left;
        cursor: pointer;
        background: var(--ms-surface);
        border-radius: 16px;
        box-shadow: 0 8px 18px rgba(30, 55, 45, 0.08);
        padding: 12px;
        display: grid;
        grid-template-columns: 64px 1fr auto;
        align-items: center;
        gap: 12px;
    }

    .medicine-card:active {
        transform: scale(0.997);
    }

    .left-icon {
        width: 64px;
        height: 64px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: #e7efed;
        color: #2f6f58;
        font-size: 28px;
        font-weight: 700;
    }

    .card-content {
        display: grid;
        gap: 6px;
    }

    .top-line {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }

    .top-line h2 {
        margin: 0;
        color: var(--ms-text);
        font-size: 18px;
        line-height: 1.08;
        font-weight: 800;
    }

    .open-arrow {
        color: var(--ms-text-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        padding-right: 4px;
    }

    .open-arrow svg {
        width: 24px;
        height: 24px;
    }

    .meta-line {
        margin: 0;
        color: var(--ms-text-muted);
        font-size: 15px;
    }

    .quantity-line {
        margin: 0;
        color: var(--ms-text-muted);
        font-size: 15px;
        font-weight: 400;
    }

    .note-line {
        margin: 0;
        color: #8f84a1;
        font-size: 14px;
        font-style: italic;
    }

    .schedule-toggle-container {
        padding: 0 6px 12px;
        display: flex;
        justify-content: flex-start;
    }

    .schedule-toggle-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        border: 2px solid var(--ms-text);
        background: transparent;
        color: var(--ms-text);
        transition: all 0.2s ease;
        cursor: pointer;
    }

    .schedule-toggle-btn .icon {
        display: grid;
        place-items: center;
    }

    .schedule-toggle-btn.active {
        background: #e2f1ea;
        border-color: #20835d;
        color: #20835d;
    }

    .schedule-card {
        grid-template-columns: 64px 1fr auto;
    }

    .error-box, .empty-state {
        background: var(--ms-surface);
        border-radius: 16px;
        padding: 12px;
        font-size: 15px;
        margin: 0 6px 10px;
    }

    .error-box {
        background: #fde9eb;
        color: #ab3f4c;
    }

    .empty-state {
        color: var(--ms-text);
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "profileId")]
    public int? RequestedProfileId { get; set; }

    private bool _isReady;
    private bool _isLoading;
    private bool _showSchedule;
    private string? _errorMessage;
    private int _selectedProfileId;

    private readonly List<ProfileSummary> _profiles = [];
    private readonly Dictionary<int, List<HomePharmacyItemDto>> _itemsByProfile = [];
    private readonly Dictionary<int, List<UserMedicationDto>> _medicationsByProfile = [];

    private List<HomePharmacyItemDto> _selectedItems =>
        _selectedProfileId != 0 && _itemsByProfile.TryGetValue(_selectedProfileId, out var items)
            ? items.Where(item => item.Quantity > 0).ToList()
            : [];

    private List<UserMedicationDto> _scheduledMedications =>
        _selectedProfileId != 0 && _medicationsByProfile.TryGetValue(_selectedProfileId, out var meds)
            ? meds.Where(m => m.IsActive).ToList()
            : [];

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _errorMessage = null;

        try
        {
            var profiles = await ProfileService.GetMyProfilesAsync();
            _profiles.Clear();
            _profiles.AddRange(profiles.OrderBy(p => p.Id));
            _itemsByProfile.Clear();
            _medicationsByProfile.Clear();

            _selectedProfileId = ResolveDefaultProfileId();
            if (_profiles.Count != 0)
            {
                await LoadAllProfileItemsAsync();
            }
        }
        catch
        {
            _errorMessage = "Koduapteegi laadimine ebaonnestus.";
        }
    }

    private async Task LoadAllProfileItemsAsync()
    {
        _isLoading = true;
        var hasLoadError = false;

        try
        {
            var loadTasks = _profiles.Select(async profile =>
            {
                try
                {
                    var itemsTask = HomePharmacyService.GetByProfileIdAsync(profile.Id);
                    var medsTask = MedicationService.GetScheduleAsync(profile.Id);
                    await Task.WhenAll(itemsTask, medsTask);

                    return (profile.Id, Items: itemsTask.Result.ToList(), Meds: medsTask.Result.ToList(), HasError: false);
                }
                catch
                {
                    return (profile.Id, Items: new List<HomePharmacyItemDto>(), Meds: new List<UserMedicationDto>(), HasError: true);
                }
            });

            var results = await Task.WhenAll(loadTasks);

            foreach (var result in results)
            {
                _itemsByProfile[result.Id] = result.Items;
                _medicationsByProfile[result.Id] = result.Meds;
                hasLoadError |= result.HasError;
            }

            if (hasLoadError)
            {
                _errorMessage = "Koduapteegi laadimine ebaonnestus.";
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private int ResolveDefaultProfileId()
    {
        if (RequestedProfileId is int requestedProfileId && _profiles.Any(profile => profile.Id == requestedProfileId))
        {
            return requestedProfileId;
        }

        if (AuthService.CurrentUser?.DefaultProfileId is int defaultProfileId &&
            _profiles.Any(profile => profile.Id == defaultProfileId))
        {
            return defaultProfileId;
        }

        return _profiles.FirstOrDefault()?.Id ?? 0;
    }

    private async Task SelectProfileAsync(int profileId)
    {
        if (_selectedProfileId == profileId)
        {
            return;
        }

        _selectedProfileId = profileId;
        _showSchedule = false;

        if (!_itemsByProfile.ContainsKey(profileId) || !_medicationsByProfile.ContainsKey(profileId))
        {
            await LoadProfileItemsAsync(profileId);
        }
    }

    private async Task LoadProfileItemsAsync(int profileId)
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var itemsTask = HomePharmacyService.GetByProfileIdAsync(profileId);
            var medsTask = MedicationService.GetScheduleAsync(profileId);

            await Task.WhenAll(itemsTask, medsTask);

            _itemsByProfile[profileId] = itemsTask.Result.ToList();
            _medicationsByProfile[profileId] = medsTask.Result.ToList();
        }
        catch
        {
            _itemsByProfile[profileId] = [];
            _medicationsByProfile[profileId] = [];
            _errorMessage = "Koduapteegi laadimine ebaonnestus.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private int GetProfileCount(int profileId)
    {
        return _itemsByProfile.TryGetValue(profileId, out var items)
            ? items.Count(item => item.Quantity > 0)
            : 0;
    }

    private static string BuildExpirationLabel(DateOnly expiresOn)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var daysLeft = expiresOn.DayNumber - today.DayNumber;

        if (daysLeft >= 0 && daysLeft < 30)
        {
            return $"Aegub: {expiresOn:dd.MM.yyyy} (aegub {daysLeft} päeva pärast)";
        }

        return $"Aegub: {expiresOn:dd.MM.yyyy}";
    }

    private async Task OpenAddPageAsync()
    {
        var scanResult = await ScannerFlowService.ScanAsync();

        if (scanResult.Status == BarcodeScanStatus.Success && !string.IsNullOrWhiteSpace(scanResult.Barcode))
        {
            var route = $"/home-pharmacy/save-medication/{Uri.EscapeDataString(scanResult.Barcode)}";
            if (_selectedProfileId > 0)
            {
                route += $"?profileId={_selectedProfileId}";
            }
            if (scanResult.ExpirationDate is DateOnly expirationDate)
            {
                route += route.Contains('?')
                    ? $"&exp={Uri.EscapeDataString(expirationDate.ToString("yyyy-MM-dd"))}"
                    : $"?exp={Uri.EscapeDataString(expirationDate.ToString("yyyy-MM-dd"))}";
            }
            if (!string.IsNullOrWhiteSpace(scanResult.BatchNumber))
            {
                route += route.Contains('?')
                    ? $"&lot={Uri.EscapeDataString(scanResult.BatchNumber)}"
                    : $"?lot={Uri.EscapeDataString(scanResult.BatchNumber)}";
            }

            Navigation.NavigateTo(route);
            return;
        }

        if (scanResult.Status == BarcodeScanStatus.ManualSearch)
        {
            if (_selectedProfileId > 0)
            {
                Navigation.NavigateTo($"/home-pharmacy/search?profileId={_selectedProfileId}");
                return;
            }

            Navigation.NavigateTo("/home-pharmacy/search");
        }
    }

    private void OpenDetails(int itemId)
    {
        Navigation.NavigateTo($"/home-pharmacy/details/{itemId}");
    }

    private void OpenScheduledMedicationDetails(UserMedicationDto medication)
    {
        if (_selectedProfileId == 0 || !_itemsByProfile.TryGetValue(_selectedProfileId, out var items))
        {
            return;
        }

        var matchingItem = items.FirstOrDefault(item => item.MedicationId == medication.MedicationId);
        if (matchingItem is not null)
        {
            OpenDetails(matchingItem.Id);
        }
    }

    private void ToggleScheduleView()
    {
        _showSchedule = !_showSchedule;
    }

    private string FormatSchedule(UserMedicationDto med)
    {
        var unitSuffix = med.ScheduleUnit switch
        {
            MedicationScheduleUnit.Day => "päevas",
            MedicationScheduleUnit.Week => "nädalas",
            MedicationScheduleUnit.Month => "kuus",
            _ => ""
        };

        return $"{med.FrequencyPerDay} korda {unitSuffix}";
    }

    private static string BuildShelfLifeLabel(DateOnly? expiresOn)
    {
        return expiresOn is DateOnly date
            ? $"Säilimisaeg: {date:dd.MM.yyyy}"
            : "Säilimisaeg puudub";
    }
}
