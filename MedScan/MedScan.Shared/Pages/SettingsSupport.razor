@page "/settings/support"
@using MedScan.Shared.Services
@inject IAuthService AuthService
@inject IExternalNavigationService ExternalNavigationService
@inject NavigationManager Navigation

<PageTitle>Abi ja tugi</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else
{
    <div class="support-page">
        <div class="support-content">
            <div class="medicine-header">
                <button class="back-link" @onclick="GoBack">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                    Tagasi
                </button>
                <h1>Abi ja tugi</h1>
                <span class="header-spacer"></span>
            </div>

            <div class="support-card">
                <div class="contact-section">
                    <div class="text">
                        <h3>Kontakt</h3>
                        <p>medscan.loputoo@gmail.com</p>
                    </div>
                </div>

                <div class="button-section">
                    <button class="email-btn primary-action" @onclick="OpenEmailAsync">
                        Ava e-post
                    </button>
                </div>

                <div class="divider"></div>
                <div class="faq-section">
                    <div class="text">
                        <h3>KKK</h3>
                        <p>Hetkel küsimused puuduvad.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .support-page {
        width: 100vw;
        position: relative;
        left: 50%;
        margin-left: -50vw;
        margin-top: -1.1rem;
        min-height: 100vh;
        background: var(--ms-bg);
        padding-bottom: calc(max(20px, env(safe-area-inset-bottom)) + 84px);
        box-sizing: border-box;
    }

    .support-content {
        max-width: 560px;
        margin: 0 auto;
        padding: 0 16px;
    }

    .medicine-header {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 8px;
        padding: calc(max(20px, env(safe-area-inset-top)) + 18px) 0 14px 0;
        background: var(--ms-bg);
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .medicine-header h1 {
        margin: 0;
        font-size: 22px;
        letter-spacing: -0.02em;
        color: var(--ms-text);
        font-weight: 800;
        text-align: center;
    }

    .header-spacer {
        width: 56px;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        border: none;
        background: transparent;
        color: var(--ms-accent);
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        padding: 10px 0;
    }

    .back-link svg {
        margin-right: 8px;
    }

    .support-card {
        background: var(--ms-surface);
        border-radius: 15px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        overflow: hidden;
        padding-bottom: 20px;
    }

    .contact-section,
    .faq-section {
        padding: 20px 20px 10px 20px;
    }

    .button-section {
        padding: 0 20px 20px 20px;
    }

    .text h3 {
        margin: 0;
        font-size: 18px;
        font-weight: 700;
        color: var(--ms-text);
        margin-bottom: 4px;
    }

    .text p {
        margin: 0;
        font-size: 15px;
        color: var(--ms-text-muted);
    }

    .divider {
        height: 1px;
        background: var(--ms-divider);
        margin: 10px 20px;
    }

    .primary-action {
        width: 100%;
        border-radius: 14px;
        padding: 12px 16px;
        font-size: 18px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        cursor: pointer;
        border: none;
        background: #1d735c;
        color: #fff;
    }
</style>

@code {
    private bool _isReady;
    private const string SupportEmail = "medscan.loputoo@gmail.com";

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
    }

    private async Task OpenEmailAsync()
    {
        await ExternalNavigationService.OpenEmailAsync(SupportEmail, "MediScan abi");
    }

    private void GoBack() => Navigation.NavigateTo("/settings");
}
