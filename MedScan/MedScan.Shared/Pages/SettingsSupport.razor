@page "/settings/support"
@using MedScan.Shared.Services
@inject IAuthService AuthService
@inject IExternalNavigationService ExternalNavigationService
@inject NavigationManager Navigation

<PageTitle>Abi ja tugi</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else
{
    <div class="support-page">
        <div class="support-content">
            <button class="back-link" @onclick="GoBack">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Seaded
            </button>

            <h1 class="page-title">Abi ja tugi</h1>

            <div class="support-card">
                <div class="row">
                    <div class="text">
                        <h3>Kontakt</h3>
                        <p>medscan.loputoo@gmail.com</p>
                    </div>
                    <button class="email-btn" @onclick="OpenEmailAsync">
                        Ava e-post
                    </button>
                </div>
                <div class="divider"></div>
                <div class="row">
                    <div class="text">
                        <h3>KKK</h3>
                        <p>Hetkel küsimused puuduvad.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .support-page {
        width: 100vw;
        position: relative;
        left: 50%;
        margin-left: -50vw;
        margin-top: -1.1rem;
        min-height: 100vh;
        background: var(--ms-bg);
        padding-top: calc(max(20px, env(safe-area-inset-top)) + 18px);
        padding-bottom: calc(max(20px, env(safe-area-inset-bottom)) + 84px);
        padding-left: max(20px, env(safe-area-inset-left));
        padding-right: max(20px, env(safe-area-inset-right));
        box-sizing: border-box;
    }

    .support-content {
        max-width: 560px;
        margin: 0 auto;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        border: none;
        background: transparent;
        color: var(--ms-accent);
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        padding: 10px 0;
        margin-bottom: 12px;
        margin-top: 16px;
    }

    .back-link svg {
        margin-right: 8px;
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: var(--ms-text);
        margin: 0 0 18px 0;
    }

    .support-card {
        background: var(--ms-surface);
        border-radius: 15px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        overflow: hidden;
    }

    .row {
        padding: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

    .text h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 700;
        color: var(--ms-text);
    }

    .text p {
        margin: 3px 0 0;
        font-size: 14px;
        color: var(--ms-text-muted);
    }

    .divider {
        height: 1px;
        background: var(--ms-divider);
        margin: 0 16px;
    }

    .email-btn {
        border: none;
        border-radius: 10px;
        padding: 10px 12px;
        background: var(--ms-accent);
        color: #fff;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        white-space: nowrap;
    }
</style>

@code {
    private bool _isReady;
    private const string SupportEmail = "medscan.loputoo@gmail.com";

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
    }

    private async Task OpenEmailAsync()
    {
        await ExternalNavigationService.OpenEmailAsync(SupportEmail, "MediScan abi");
    }

    private void GoBack() => Navigation.NavigateTo("/settings");
}
