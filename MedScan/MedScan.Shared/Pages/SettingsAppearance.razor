@page "/settings/appearance"
@using MedScan.Shared.Services
@inject IAuthService AuthService
@inject IThemeService ThemeService
@inject NavigationManager Navigation

<PageTitle>Välimus</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else
{
    <div class="settings-subpage">
        <div class="settings-subpage-content">
            <div class="medicine-header">
                <button class="back-link" @onclick="GoBack">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                    Tagasi
                </button>
                <h1>Välimus</h1>
                <span class="header-spacer"></span>
            </div>

            <div class="settings-card">
                <div class="settings-item">
                    <div class="item-text">
                        <h3>Teema</h3>
                        <p>Hele teema</p>
                    </div>
                    <label class="toggle-switch" aria-label="Teema">
                        <input type="checkbox"
                               checked="@_darkModeEnabled"
                               disabled
                               @onchange="OnThemeToggleChanged" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
        </div>
    </div>
}



@code {
    private bool _isReady;
    private bool _darkModeEnabled;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await ThemeService.InitializeAsync();
        _darkModeEnabled = ThemeService.IsDarkMode;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnThemeToggleChanged(ChangeEventArgs args)
    {
        _darkModeEnabled = false;
        await ThemeService.SetDarkModeAsync(false);
    }

    private void GoBack() => Navigation.NavigateTo("/settings");
}
