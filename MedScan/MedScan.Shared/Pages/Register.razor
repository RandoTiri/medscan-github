@page "/register"
@layout MedScan.Shared.Layout.AuthLayout
@using MedScan.Shared.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Registreeru</PageTitle>

<div class="auth-form">
    <h1>Loo kasutaja</h1>
    <p class="auth-subtitle">Tee endale MedScan konto.</p>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="auth-error">@ErrorMessage</div>
    }

    <div class="form-group">
        <label for="fullname">Nimi</label>
        <input id="fullname" @bind="FullName" class="form-input" disabled="@IsBusy" />
    </div>

    <div class="form-group">
        <label for="email">Email</label>
        <input id="email" @bind="Email" class="form-input" disabled="@IsBusy" />
    </div>

    <div class="form-group">
        <label for="password">Parool</label>
        <input id="password" type="password" @bind="Password" class="form-input" disabled="@IsBusy" />
    </div>

    <button class="auth-button" @onclick="HandleRegister" disabled="@IsBusy">
        @(IsBusy ? "Loob kasutajat..." : "Registreeru")
    </button>

    <div class="auth-footer">
        <span>Juba on konto?</span>
        <button class="link-button" @onclick="GoToLogin" disabled="@IsBusy">Tagasi loginisse</button>
    </div>
</div>

@code {
    private string FullName = string.Empty;
    private string Email = string.Empty;
    private string Password = string.Empty;
    private string ErrorMessage = string.Empty;
    private bool IsBusy;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();

        if (AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/");
        }
    }

    private async Task HandleRegister()
    {
        if (IsBusy)
        {
            return;
        }

        IsBusy = true;
        ErrorMessage = string.Empty;

        try
        {
            var result = await AuthService.RegisterAsync(FullName, Email, Password);

            if (result.Success)
            {
                Navigation.NavigateTo("/");
                return;
            }

            ErrorMessage = result.ErrorMessage;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.ToString();
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }
}
