@page "/register"
@layout MedScan.Shared.Layout.AuthLayout
@using MedScan.Shared.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Registreeru</PageTitle>

<style>
    .login-container {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        display: flex;
        flex-direction: column;

        width: 100%;
        min-height: 100vh;
        background-color: #fff;
        max-width: 450px;
        margin: 0 auto;
        color: #1c3d4f;
        box-sizing: border-box;

        padding-top: 0;
        padding-bottom: calc(max(20px, env(safe-area-inset-bottom)) + 20px);
        padding-left: max(0px, env(safe-area-inset-left));
        padding-right: max(0px, env(safe-area-inset-right));
    }
    .header-section {
        background: linear-gradient(180deg, #ecf7f4 0%, #fff 100%);
        padding: calc(max(20px, env(safe-area-inset-top)) + 40px) 20px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    .logo-container {
        background-color: #267863;
        width: 80px;
        height: 80px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }
    .brand-name {
        font-size: 28px;
        font-weight: 700;
        margin: 0 0 10px;
        color: #0b2b40;
    }
    .brand-subtitle {
        font-size: 14px;
        color: #648191;
        margin: 0;
    }
    .form-section {
        padding: 20px 30px;
        display: flex;
        flex-direction: column;
    }
    .auth-input-group {
        margin-bottom: 20px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        width: 100%;
        box-sizing: border-box;
    }
    .auth-input-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 8px;
        color: #1c3d4f;
        text-align: left;
        width: 100%;
    }
    .input-wrapper {
        display: flex;
        align-items: center;
        border: 2px solid #d4dfe5;
        border-radius: 16px;
        overflow: hidden;
        padding: 0 15px;
        background: #fff;
        width: 100%;
        box-sizing: border-box;
        transition: all 0.2s ease;
    }
    .input-wrapper:focus-within {
        border-color: #267863;
        box-shadow: 0 0 0 4px rgba(38, 120, 99, 0.1);
    }
    .input-wrapper input {
        border: none;
        outline: none;
        padding: 15px 10px;
        width: 100%;
        font-size: 14px;
        color: #1c3d4f;
        background: transparent;
    }
    .input-wrapper input::placeholder {
        color: #a0b6c2;
    }
    .input-icon {
        color: #a0b6c2;
        display: flex;
        flex-shrink: 0;
    }
    .input-action {
        color: #a0b6c2;
        cursor: pointer;
        display: flex;
        flex-shrink: 0;
        padding: 5px;
    }
    .input-action:hover {
        color: #267863;
    }
    .btn-primary {
        background-color: #267863;
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 16px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 4px 10px rgba(38, 120, 99, 0.2);
        width: 100%;
        transition: all 0.1s ease;
    }
    .btn-primary:active {
        transform: scale(0.98);
        background-color: #1e604f;
    }
    .btn-primary:disabled {
        opacity: 0.7;
        transform: none;
    }
    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 25px 0;
        color: #a0b6c2;
        font-size: 14px;
    }
    .divider::before, .divider::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid #e1e9ed;
    }
    .divider span {
        padding: 0 15px;
    }
    .btn-secondary {
        background-color: #fff;
        color: #267863;
        border: 2px solid #267863;
        border-radius: 12px;
        padding: 14px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        width: 100%;
        transition: all 0.1s ease;
    }
    .btn-secondary:active {
        transform: scale(0.98);
        background-color: #f0f7f5;
    }
    .btn-secondary:disabled {
        opacity: 0.7;
        transform: none;
    }
    .success-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-top: 50px;
        padding: 20px;
    }
    .success-icon {
        color: #267863;
        margin-bottom: 20px;
    }
    .success-message {
        font-size: 18px;
        font-weight: bold;
        color: #2e7d32;
        margin-bottom: 30px;
    }
    .auth-error {
        color: #e53935;
        background: #ffebee;
        padding: 10px;
        border-radius: 8px;
        margin: 0 30px 10px;
        font-size: 14px;
        text-align: center;
    }
    .empty-space {
        height: 20px;
    }
</style>

<div class="login-container">
    @if (RegistrationSuccessful)
    {
        <div class="success-container">
            <div class="success-icon">
                <svg viewBox="0 0 24 24" width="80" height="80" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
            </div>
            <div class="success-message">Olete edukalt kasutaja loonud!</div>
            <button class="btn-primary" @onclick="GoToLogin">Logi sisse</button>
        </div>
    }
    else
    {
        <div class="header-section">
            <div class="logo-container">
                <svg viewBox="0 0 24 24" width="40" height="40" stroke="white" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"></path>
                    <path d="m8.5 8.5 7 7"></path>
                </svg>
            </div>
            <h1 class="brand-name">Loo kasutaja</h1>
            <p class="brand-subtitle">Loo endale MedScan konto.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="auth-error">@ErrorMessage</div>
        }

        <div class="form-section">
            <div class="auth-input-group">
                <label for="fullname">Nimi</label>
                <div class="input-wrapper">
                    <div class="input-icon">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </div>
                    <input id="fullname" type="text" placeholder="Sinu Nimi" @bind="FullName" disabled="@IsBusy" />
                </div>
            </div>

            <div class="auth-input-group">
                <label for="email">E-mail</label>
                <div class="input-wrapper">
                    <div class="input-icon">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                    </div>
                    <input id="email" type="email" placeholder="sinuemail@gmail.com" @bind="Email" disabled="@IsBusy" />
                </div>
            </div>

            <div class="auth-input-group">
                <label for="password">Parool</label>
                <div class="input-wrapper">
                    <div class="input-icon">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </div>
                    <input id="password" type="@PasswordInputType" placeholder="••••••••" @bind="Password" disabled="@IsBusy" />
                    <div class="input-action" @onclick="TogglePasswordVisibility">
                        @if (ShowPassword)
                        {
                            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        }
                    </div>
                </div>
            </div>
            
            <div class="empty-space"></div>

            <button class="btn-primary" @onclick="HandleRegister" disabled="@IsBusy">
                @(IsBusy ? "Loob kasutajat..." : "Registreeru")
            </button>

            <div class="divider">
                <span>Juba on konto?</span>
            </div>

            <button class="btn-secondary" @onclick="GoToLogin" disabled="@IsBusy">
                Tagasi sisselogimislehele
            </button>
        </div>
    }
</div>

@code {
    private string FullName = string.Empty;
    private string Email = string.Empty;
    private string Password = string.Empty;
    private string ErrorMessage = string.Empty;
    private bool IsBusy;
    private bool ShowPassword = false;
    private string PasswordInputType => ShowPassword ? "text" : "password";
    private bool RegistrationSuccessful = false;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();

        if (AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/");
        }
    }

    private async Task HandleRegister()
    {
        if (IsBusy)
        {
            return;
        }

        IsBusy = true;
        ErrorMessage = string.Empty;
        RegistrationSuccessful = false;

        try
        {
            var result = await AuthService.RegisterAsync(FullName, Email, Password);

            if (result.Success)
            {
                RegistrationSuccessful = true;
                return;
            }

            ErrorMessage = result.ErrorMessage;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.ToString();
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private void TogglePasswordVisibility()
    {
        ShowPassword = !ShowPassword;
    }
}

