@page "/"
@implements IDisposable
@using MedScan.Shared.DTOs.Medication
@using MedScan.Shared.Models
@using MedScan.Shared.Models.Enums
@using MedScan.Shared.Services
@inject IAuthService AuthService
@inject IProfileService ProfileService
@inject IMedicationService MedicationService
@inject IHomePharmacyService HomePharmacyService
@inject IMedicationStatusEvents MedicationStatusEvents
@inject IScannerFlowService ScannerFlowService
@inject NavigationManager Navigation

<PageTitle>Avaleht</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else
{
    <div class="mobile-container">
        <header class="header-section">
            <div class="header-top">
                <div class="header-date">@DateTime.Now.ToString("dddd, d. MMMM", new System.Globalization.CultureInfo("et-EE"))</div>
                <div class="header-icons">
                    <span class="notification-icon" title="Meeldetuletused">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                        </svg>
                    </span>
                    <span class="user-initials">@GetInitials()</span>
                </div>
            </div>

            <h1 class="greeting">Tere, @(AuthService.CurrentUser?.FullName ?? "Kasutaja")!</h1>

            <div class="stats-card">
                <div class="stat-item">
                    <span class="stat-number">@_doneCount</span>
                    <span class="stat-label">Tehtud</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-number stat-number-warning">@_pendingCount</span>
                    <span class="stat-label">Ootel</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-number">@_totalCount</span>
                    <span class="stat-label">Kokku</span>
                </div>
            </div>
        </header>

        <main class="main-content">
            <div class="scan-card" @onclick="StartScannerAsync">
                <div class="scan-icon-wrapper">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 7V4h3"></path>
                        <path d="M4 17v3h3"></path>
                        <path d="M20 7V4h-3"></path>
                        <path d="M20 17v3h-3"></path>
                        <line x1="8" y1="12" x2="16" y2="12"></line>
                    </svg>
                </div>
                <div class="scan-text">
                    <h3>Skaneeri ravim</h3>
                    <p>Skan triipkoodi infole</p>
                </div>
                <div class="scan-arrow">›</div>
            </div>

            <div class="section-header">
                <h2>Minu tänane raviskeem</h2>
                <a href="javascript:void(0)" @onclick="OpenMyMedicines">Kõik</a>
            </div>

            @if (_myMedicationCards.Count == 0)
            {
                <div class="empty-card">Täna pole veel ravimeid lisatud.</div>
            }
            else
            {
                @foreach (var card in _myMedicationCards)
                {
                    <button type="button" class="med-card @card.StatusCss" @onclick="() => OpenDoseModal(card)">
                        <div class="med-icon">
                            @if (card.Status == DoseStatusEnum.Done)
                            {
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                            }
                            else if (card.Status == DoseStatusEnum.Missed || card.Status == DoseStatusEnum.Skipped)
                            {
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 8v5"></path><path d="M12 16h.01"></path></svg>
                            }
                            else
                            {
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
                            }
                        </div>
                        <div class="med-info">
                            <h3>@card.Name</h3>
                            <p>@card.ScheduleText</p>
                        </div>
                        <div class="med-status @card.StatusBadgeCss">@card.StatusLabel</div>
                    </button>
                }
            }

            <div class="section-header">
                <h2>Perekond</h2>
            </div>

            @if (_familyMedicationCards.Count == 0)
            {
                <div class="empty-card">Hooldatavate ravimeid täna ei leitud.</div>
            }
            else
            {
                @foreach (var card in _familyMedicationCards)
                {
                    <button type="button" class="med-card @card.StatusCss" @onclick="() => OpenDoseModal(card)">
                        <div class="med-icon">
                            @if (card.Status == DoseStatusEnum.Done)
                            {
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                            }
                            else if (card.Status == DoseStatusEnum.Missed || card.Status == DoseStatusEnum.Skipped)
                            {
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 8v5"></path><path d="M12 16h.01"></path></svg>
                            }
                            else
                            {
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
                            }
                        </div>
                        <div class="med-info">
                            <h3>@card.ProfileName · @card.Name</h3>
                            <p>@card.ScheduleText</p>
                        </div>
                        <div class="med-status @card.StatusBadgeCss">@card.StatusLabel</div>
                    </button>
                }
            }
        </main>

        @if (_selectedDoseCard is not null)
        {
            <div class="dose-modal-backdrop" @onclick="CloseDoseModal"></div>
            <section class="dose-modal" role="dialog" aria-modal="true" aria-label="Ravimi staatus">
                <h3>@_selectedDoseCard.Name</h3>
                <p class="dose-modal-time">Annuse aeg: @_selectedDoseCard.ScheduledTime.ToString("HH:mm")</p>

                @if (!string.IsNullOrWhiteSpace(_modalErrorMessage))
                {
                    <div class="error-box">@_modalErrorMessage</div>
                }

                @if (_showEarlyDoneConfirmation && _earlyDoneMinutesRemaining > 0)
                {
                    <div class="confirm-box">
                        Kas oled kindel, et võtad ravimi praegu? Õige ajani on @FormatRemainingTime(_earlyDoneMinutesRemaining) veel aega.
                        <div class="confirm-box-actions">
                            <button type="button" class="confirm-yes" disabled="@_isUpdatingDose" @onclick="ConfirmEarlyDoneAsync">Jah</button>
                            <button type="button" class="confirm-no" disabled="@_isUpdatingDose" @onclick="CancelEarlyDoneConfirmation">Ei</button>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(_modalInfoMessage))
                {
                    <div class="success-box">@_modalInfoMessage</div>
                }

                @if (!_showEarlyDoneConfirmation)
                {
                    <div class="dose-modal-actions">
                        <button type="button" class="status-btn @GetModalButtonCss(DoseStatusEnum.Done)" disabled="@_isUpdatingDose" @onclick="() => UpdateDoseStatusFromModalAsync(DoseStatusEnum.Done)">Tehtud</button>
                        <button type="button" class="status-btn @GetModalButtonCss(DoseStatusEnum.Missed)" disabled="@_isUpdatingDose" @onclick="() => UpdateDoseStatusFromModalAsync(DoseStatusEnum.Missed)">Tegemata</button>
                    </div>
                }

                <button type="button" class="dose-modal-close" @onclick="CloseDoseModal">Sulge</button>
            </section>
        }
    </div>
}

<style>
    .mobile-container {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: var(--ms-bg);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        width: 100vw;
        position: relative;
        left: 50%;
        margin-left: -50vw;
        margin-top: -1.1rem;
        padding-bottom: calc(max(24px, env(safe-area-inset-bottom)) + 80px);
        padding-left: max(0px, env(safe-area-inset-left));
        padding-right: max(0px, env(safe-area-inset-right));
        box-sizing: border-box;
    }

    .header-section {
        background-color: var(--ms-primary-card-bg);
        color: white;
        padding: 20px;
        padding-top: calc(max(20px, env(safe-area-inset-top)) + 20px);
        border-bottom-left-radius: 20px;
        border-bottom-right-radius: 20px;
    }

