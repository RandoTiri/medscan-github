@page "/"
@implements IDisposable
@using MedScan.Shared.DTOs.Medication
@using MedScan.Shared.Models
@using MedScan.Shared.Models.Enums
@using MedScan.Shared.Services
@inject IAuthService AuthService
@inject IProfileService ProfileService
@inject IMedicationService MedicationService
@inject IHomePharmacyService HomePharmacyService
@inject IMedicationStatusEvents MedicationStatusEvents
@inject IScannerFlowService ScannerFlowService
@inject INotificationInboxService NotificationInboxService
@inject NavigationManager Navigation

<PageTitle>Avaleht</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else
{
    <div class="mobile-container">
        <header class="header-section">
            <div class="header-top">
                <div class="header-date">@DateTime.Now.ToString("dddd, d. MMMM", new System.Globalization.CultureInfo("et-EE"))</div>
                <div class="header-icons">
                    <button type="button" class="notification-icon" title="Teavitused" @onclick="OpenNotificationCenterAsync">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                        </svg>
                        @if (_hasUnrespondedNotifications)
                        {
                            <span class="notification-dot"></span>
                        }
                    </button>
                    <button type="button" class="user-initials" title="Minu profiil" @onclick="OpenMyMainProfileSettings">
                        @GetInitials()
                    </button>
                </div>
            </div>

            <h1 class="greeting">Tere, @(AuthService.CurrentUser?.FullName ?? "Kasutaja")!</h1>

            <div class="stats-card">
                <div class="stat-item">
                    <span class="stat-number">@_doneCount</span>
                    <span class="stat-label">Võetud</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-number stat-number-warning">@_pendingCount</span>
                    <span class="stat-label">Ootel</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-number">@_totalCount</span>
                    <span class="stat-label">Kokku</span>
                </div>
            </div>
        </header>

        <main class="main-content">
            <div class="scan-card" @onclick="StartScannerAsync">
                <div class="scan-icon-wrapper">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 7V4h3"></path>
                        <path d="M4 17v3h3"></path>
                        <path d="M20 7V4h-3"></path>
                        <path d="M20 17v3h-3"></path>
                        <line x1="8" y1="12" x2="16" y2="12"></line>
                    </svg>
                </div>
                <div class="scan-text">
                    <h3>Skaneeri ravim</h3>
                </div>
                <div class="scan-arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a0b6c2" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                </div>
            </div>

            <div class="section-header">
                <h2>Minu tänane raviskeem</h2>
                <a href="javascript:void(0)" @onclick="OpenMyMedicines">Kõik</a>
            </div>

            @if (_myMedicationCards.Count == 0)
            {
                <div class="empty-card">Täna pole veel ravimeid lisatud.</div>
            }
            else
            {
                @foreach (var card in _myMedicationCards)
                {
                    <button type="button" class="med-card @card.StatusCss" @onclick="() => OpenDoseModal(card)">
                        <div class="status-box @card.StatusCss">
                            <div class="med-icon">
                                @if (card.Status == DoseStatusEnum.Done)
                                {
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                                }
                                else if (card.Status == DoseStatusEnum.Missed || card.Status == DoseStatusEnum.Skipped)
                                {
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 8v5"></path><path d="M12 16h.01"></path></svg>
                                }
                                else
                                {
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
                                }
                            </div>
                            <div class="status-label">@card.StatusLabel</div>
                        </div>
                        <div class="med-info">
                            <h3>@card.Name</h3>
                            @if (!string.IsNullOrWhiteSpace(card.Note))
                            {
                                <p class="med-note">💬 @card.Note</p>
                            }
                            <div class="time-chip-row">
                                @foreach (var slot in card.TimeSlots)
                                {
                                    <span class="time-chip @card.StatusCss">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="12" cy="12" r="9"></circle>
                                            <path d="M12 7v5l3 2"></path>
                                        </svg>
                                        @slot.ToString("HH:mm")
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="dose-card-arrow">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 18 15 12 9 6"></polyline>
                            </svg>
                        </div>
                    </button>
                }
            }

            <div class="section-header">
                <h2>Hooldatavad</h2>
            </div>

            @if (_familyMedicationCards.Count == 0)
            {
                <div class="empty-card">Hooldatavate ravimeid täna ei leitud.</div>
            }
            else
            {
                @foreach (var card in _familyMedicationCards)
                {
                    <button type="button" class="family-dose-card @card.StatusCss" @onclick="() => OpenDoseModal(card)">
                        <div class="status-box @card.StatusCss">
                            <div class="med-icon">
                                @if (card.Status == DoseStatusEnum.Done)
                                {
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                                }
                                else if (card.Status == DoseStatusEnum.Missed || card.Status == DoseStatusEnum.Skipped)
                                {
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 8v5"></path><path d="M12 16h.01"></path></svg>
                                }
                                else
                                {
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
                                }
                            </div>
                            <div class="status-label">@card.StatusLabel</div>
                        </div>
                        <div class="family-dose-info">
                            <h3>@card.ProfileName</h3>
                            <p class="family-med-name">@card.Name</p>
                            @if (!string.IsNullOrWhiteSpace(card.Note))
                            {
                                <p class="family-note">💬 @card.Note</p>
                            }
                            <div class="time-chip-row">
                                @foreach (var slot in card.TimeSlots)
                                {
                                    <span class="time-chip @card.StatusCss">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="12" cy="12" r="9"></circle>
                                            <path d="M12 7v5l3 2"></path>
                                        </svg>
                                        @slot.ToString("HH:mm")
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="dose-card-arrow">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 18 15 12 9 6"></polyline>
                            </svg>
                        </div>
                    </button>
                }
            }
        </main>

        @if (_selectedDoseCard is not null)
        {
            <div class="dose-modal-backdrop" @onclick="CloseDoseModal"></div>
            <section class="dose-modal" role="dialog" aria-modal="true" aria-label="Ravimi staatus">
                <h3>@_selectedDoseCard.Name</h3>
                <p class="dose-modal-time">Annuse aeg: @_selectedDoseCard.ScheduledTime.ToString("HH:mm")</p>

                @if (!string.IsNullOrWhiteSpace(_modalErrorMessage))
                {
                    <div class="error-box">@_modalErrorMessage</div>
                }

                @if (_showEarlyDoneConfirmation && _earlyDoneMinutesRemaining > 0)
                {
                    <div class="confirm-box">
                        Kas oled kindel, et võtad ravimi praegu? Õige ajani on @FormatRemainingTime(_earlyDoneMinutesRemaining) veel aega.
                        <div class="confirm-box-actions">
                            <button type="button" class="confirm-yes" disabled="@_isUpdatingDose" @onclick="ConfirmEarlyDoneAsync">Jah</button>
                            <button type="button" class="confirm-no" disabled="@_isUpdatingDose" @onclick="CancelEarlyDoneConfirmation">Ei</button>
                        </div>
                    </div>
                }

                @if (_showLastUnitConfirmation)
                {
                    <div class="confirm-box">
                        <strong>See viimane ravim, pärast tehtud märkimist kustub ravim sinu raviskeemist ning ravimite nimekirjast.</strong> Kui jätkad ravimi võtmist, siis skänneri uus karp ja lisa see oma raviskeemi.
                        <div class="confirm-box-actions">
                            <button type="button" class="confirm-yes" disabled="@_isUpdatingDose" @onclick="ConfirmLastUnitDoneAsync">Jah</button>
                            <button type="button" class="confirm-no" disabled="@_isUpdatingDose" @onclick="CancelLastUnitConfirmation">Ei</button>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(_modalInfoMessage))
                {
                    <div class="success-box">@_modalInfoMessage</div>
                }

                @if (!_showEarlyDoneConfirmation && !_showLastUnitConfirmation && string.IsNullOrWhiteSpace(_modalInfoMessage))
                {
                    <div class="dose-modal-actions">
                        <button type="button" class="status-btn status-btn-done @GetModalButtonCss(DoseStatusEnum.Done)" disabled="@_isUpdatingDose" @onclick="() => UpdateDoseStatusFromModalAsync(DoseStatusEnum.Done)">Võetud</button>
                        <button type="button" class="status-btn status-btn-missed @GetModalButtonCss(DoseStatusEnum.Missed)" disabled="@_isUpdatingDose" @onclick="() => UpdateDoseStatusFromModalAsync(DoseStatusEnum.Missed)">Võtmata</button>
                    </div>
                }

                <button type="button" class="dose-modal-close" @onclick="CloseDoseModal">Sulge</button>
            </section>
        }

        @if (_isNotificationCenterOpen)
        {
            <div class="dose-modal-backdrop" @onclick="CloseNotificationCenter"></div>
            <section class="notification-center-modal" role="dialog" aria-modal="true" aria-label="Teavitused">
                <div class="notification-center-header">
                    <h3>Teavitused</h3>
                    <button type="button" class="notification-center-close" @onclick="CloseNotificationCenter">Sulge</button>
                </div>

                @if (_notificationItems.Count == 0)
                {
                    <p class="notification-empty">Varasemaid teavitusi pole.</p>
                }
                else
                {
                    <div class="notification-list">
                        @foreach (var item in _notificationItems)
                        {
                            <article class="notification-item @(item.IsResponded ? "responded" : "pending")">
                                <div class="notification-item-top">
                                    <strong>@(string.IsNullOrWhiteSpace(item.Title) ? "MedScan" : item.Title)</strong>
                                    <span>@item.OccurredAt.ToString("dd.MM")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                {
                                    <p>@item.Description</p>
                                }
                                <div class="notification-time-row">
                                    <span class="notification-time-chip @GetNotificationTimeChipCss(item)">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="12" cy="12" r="9"></circle>
                                            <path d="M12 7v5l3 2"></path>
                                        </svg>
                                        @item.OccurredAt.ToString("HH:mm")
                                    </span>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        }
    </div>
}



@code {
    private bool _isReady;

    private int _doneCount;
    private int _pendingCount;
    private int _totalCount;
    private bool _isUpdatingDose;
    private string? _modalErrorMessage;
    private string? _modalInfoMessage;
    private SelectedDoseCard? _selectedDoseCard;
    private bool _showEarlyDoneConfirmation;
    private bool _showLastUnitConfirmation;
    private int _earlyDoneMinutesRemaining;
    private bool _isNotificationCenterOpen;
    private bool _hasUnrespondedNotifications;
    private List<NotificationInboxItem> _notificationItems = [];

    private readonly List<HomeMedicationCard> _myMedicationCards = [];
    private readonly List<FamilyMedicationCard> _familyMedicationCards = [];

    protected override async Task OnInitializedAsync()
    {
        MedicationStatusEvents.Changed += OnMedicationStatusChanged;
        NotificationInboxService.Changed += OnNotificationInboxChanged;
        await AuthService.InitializeAsync();

        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await NotificationInboxService.InitializeAsync();
        await RefreshNotificationBadgeAsync();
        await LoadHomeDataAsync();
        _isReady = true;
    }

    private async Task LoadHomeDataAsync()
    {
        var profiles = await ProfileService.GetMyProfilesAsync();
        var mainProfile = ResolveMainProfile(profiles);

        var allMedications = new List<(ProfileSummary Profile, UserMedicationDto Medication, int RemainingQuantity)>();

        foreach (var profile in profiles)
        {
            var schedule = await MedicationService.GetScheduleAsync(profile.Id);
            var homePharmacyItems = await HomePharmacyService.GetByProfileIdAsync(profile.Id);
            var quantitiesByMedicationId = homePharmacyItems
                .GroupBy(item => item.MedicationId)
                .ToDictionary(group => group.Key, group => group.Sum(item => item.Quantity));
            var allowedMedicationIds = homePharmacyItems
                .Where(item => item.Quantity > 0)
                .Select(item => item.MedicationId)
                .ToHashSet();

            allMedications.AddRange(schedule
                .Where(medication => allowedMedicationIds.Contains(medication.MedicationId))
                .Select(medication => (profile, medication, quantitiesByMedicationId.TryGetValue(medication.MedicationId, out var quantity) ? quantity : 0)));
        }

        var allTodayDoses = allMedications
            .Where(tuple => tuple.Medication.IsActive)
            .SelectMany(tuple => tuple.Medication.TodayDoses);

        _totalCount = allTodayDoses.Count();
        _doneCount = allTodayDoses.Count(dose => dose.Status == DoseStatusEnum.Done);
        _pendingCount = _totalCount - _doneCount;

        _myMedicationCards.Clear();
        _myMedicationCards.AddRange(allMedications
            .Where(tuple => mainProfile is not null && tuple.Profile.Id == mainProfile.Id)
            .Where(tuple => tuple.Medication.IsActive)
            .SelectMany(tuple => BuildHomeMedicationCards(tuple.Medication, tuple.RemainingQuantity))
            .OrderBy(card => card.NextTimeSortKey)
            .ThenBy(card => card.Name));

        _familyMedicationCards.Clear();
        _familyMedicationCards.AddRange(allMedications
            .Where(tuple => tuple.Profile.Type.Equals("Patsient", StringComparison.OrdinalIgnoreCase))
            .Where(tuple => tuple.Medication.IsActive)
            .SelectMany(tuple => BuildFamilyMedicationCards(tuple.Profile, tuple.Medication, tuple.RemainingQuantity))
            .OrderBy(card => card.NextTimeSortKey)
            .ThenBy(card => card.ProfileName)
            .ThenBy(card => card.Name)
            .ThenBy(card => card.ScheduledTime));
    }

    private static ProfileSummary? ResolveMainProfile(IReadOnlyList<ProfileSummary> profiles)
    {
        return profiles.FirstOrDefault(p => p.Type.Equals("Ise", StringComparison.OrdinalIgnoreCase))
               ?? profiles.FirstOrDefault();
    }

    private static IEnumerable<HomeMedicationCard> BuildHomeMedicationCards(UserMedicationDto medication, int remainingQuantity)
    {
        var note = NormalizeNote(medication.Notes);
        var todayDoses = medication.TodayDoses
            .OrderBy(d => d.ScheduledTime)
            .ToList();

        if (todayDoses.Count > 0)
        {
            foreach (var dose in todayDoses)
            {
                yield return new HomeMedicationCard(
                    UserMedicationId: medication.Id,
                    Name: BuildMedicationDisplayName(medication),
                    Note: note,
                    ScheduledTime: dose.ScheduledTime,
                    TimeSlots: [dose.ScheduledTime],
                    RemainingQuantity: remainingQuantity,
                    Status: dose.Status,
                    StatusLabel: dose.Status switch
                    {
                        DoseStatusEnum.Done => "Võetud",
                        DoseStatusEnum.Missed => "Võtmata",
                        DoseStatusEnum.Skipped => "Võtmata",
                        _ => "Ootel"
                    },
                    StatusCss: dose.Status switch
                    {
                        DoseStatusEnum.Done => "status-done",
                        DoseStatusEnum.Missed => "status-missed",
                        DoseStatusEnum.Skipped => "status-missed",
                        _ => "status-pending"
                    },
                    StatusBadgeCss: dose.Status switch
                    {
                        DoseStatusEnum.Done => "badge-done",
                        DoseStatusEnum.Missed => "badge-missed",
                        DoseStatusEnum.Skipped => "badge-missed",
                        _ => "badge-pending"
                    },
                    NextTimeSortKey: dose.ScheduledTime.ToTimeSpan()
                );
            }

            yield break;
        }

        if (medication.ScheduleUnit != MedicationScheduleUnit.Day)
        {
            yield break;
        }

        foreach (var fallbackTime in medication.ScheduledTimes.OrderBy(t => t))
        {
            yield return new HomeMedicationCard(
                UserMedicationId: medication.Id,
                Name: BuildMedicationDisplayName(medication),
                Note: note,
                ScheduledTime: fallbackTime,
                TimeSlots: [fallbackTime],
                RemainingQuantity: remainingQuantity,
                Status: DoseStatusEnum.Pending,
                StatusLabel: "Ootel",
                StatusCss: "status-pending",
                StatusBadgeCss: "badge-pending",
                NextTimeSortKey: fallbackTime.ToTimeSpan()
            );
        }
    }

    private static IEnumerable<FamilyMedicationCard> BuildFamilyMedicationCards(ProfileSummary profile, UserMedicationDto medication, int remainingQuantity)
    {
        var note = NormalizeNote(medication.Notes);
        var todayDoses = medication.TodayDoses
            .OrderBy(dose => dose.ScheduledTime)
            .ToList();

        if (todayDoses.Count > 0)
        {
            foreach (var dose in todayDoses)
            {
                yield return new FamilyMedicationCard(
                    UserMedicationId: medication.Id,
                    ProfileName: profile.Name,
                    Name: BuildMedicationDisplayName(medication),
                    Note: note,
                    ScheduledTime: dose.ScheduledTime,
                    TimeSlots: [dose.ScheduledTime],
                    RemainingQuantity: remainingQuantity,
                    Status: dose.Status,
                    StatusLabel: dose.Status switch
                    {
                        DoseStatusEnum.Done => "Võetud",
                        DoseStatusEnum.Missed => "Võtmata",
                        DoseStatusEnum.Skipped => "Võtmata",
                        _ => "Ootel"
                    },
                    StatusCss: dose.Status switch
                    {
                        DoseStatusEnum.Done => "status-done",
                        DoseStatusEnum.Missed => "status-missed",
                        DoseStatusEnum.Skipped => "status-missed",
                        _ => "status-pending"
                    },
                    StatusBadgeCss: dose.Status switch
                    {
                        DoseStatusEnum.Done => "badge-done",
                        DoseStatusEnum.Missed => "badge-missed",
                        DoseStatusEnum.Skipped => "badge-missed",
                        _ => "badge-pending"
                    },
                    NextTimeSortKey: dose.ScheduledTime.ToTimeSpan()
                );
            }

            yield break;
        }

        if (medication.ScheduleUnit != MedicationScheduleUnit.Day)
        {
            yield break;
        }

        foreach (var fallbackTime in medication.ScheduledTimes.OrderBy(t => t))
        {
            yield return new FamilyMedicationCard(
                UserMedicationId: medication.Id,
                ProfileName: profile.Name,
                Name: BuildMedicationDisplayName(medication),
                Note: note,
                ScheduledTime: fallbackTime,
                TimeSlots: [fallbackTime],
                RemainingQuantity: remainingQuantity,
                Status: DoseStatusEnum.Pending,
                StatusLabel: "Ootel",
                StatusCss: "status-pending",
                StatusBadgeCss: "badge-pending",
                NextTimeSortKey: fallbackTime.ToTimeSpan()
            );
        }
    }

    private static string BuildMedicationDisplayName(UserMedicationDto medication)
    {
        if (string.IsNullOrWhiteSpace(medication.Strength) || medication.MedicationName.Contains(medication.Strength, StringComparison.OrdinalIgnoreCase))
        {
            return medication.MedicationName;
        }

        return $"{medication.MedicationName} {medication.Strength}";
    }

    private static string? NormalizeNote(string? note)
    {
        return string.IsNullOrWhiteSpace(note) ? null : note.Trim();
    }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "--";
        }

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
        {
            return parts[0][..1].ToUpperInvariant();
        }

        return (parts[0][..1] + parts[^1][..1]).ToUpperInvariant();
    }

    private string GetInitials()
    {
        return GetInitials(AuthService.CurrentUser?.FullName);
    }

    private async Task StartScannerAsync()
    {
        var scanResult = await ScannerFlowService.ScanAsync();

        if (scanResult.Status == BarcodeScanStatus.Success && !string.IsNullOrWhiteSpace(scanResult.Barcode))
        {
            var route = $"/home-pharmacy/save-medication/{Uri.EscapeDataString(scanResult.Barcode)}";
            if (scanResult.ExpirationDate is DateOnly expirationDate)
            {
                route += $"?exp={Uri.EscapeDataString(expirationDate.ToString("yyyy-MM-dd"))}";
            }
            if (!string.IsNullOrWhiteSpace(scanResult.BatchNumber))
            {
                route += route.Contains('?')
                    ? $"&lot={Uri.EscapeDataString(scanResult.BatchNumber)}"
                    : $"?lot={Uri.EscapeDataString(scanResult.BatchNumber)}";
            }

            Navigation.NavigateTo(route);
        }
        else if (scanResult.Status == BarcodeScanStatus.ManualSearch)
        {
            Navigation.NavigateTo("/home-pharmacy/search");
        }
    }

    private void OpenMyMedicines()
    {
        Navigation.NavigateTo("/home-pharmacy");
    }

    private void OpenMyMainProfileSettings()
    {
        var defaultProfileId = AuthService.CurrentUser?.DefaultProfileId;
        if (defaultProfileId.HasValue)
        {
            Navigation.NavigateTo($"/settings/main-profile/{defaultProfileId.Value}");
            return;
        }

        Navigation.NavigateTo("/settings");
    }

    private async Task OpenNotificationCenterAsync()
    {
        _isNotificationCenterOpen = true;
        await LoadNotificationItemsAsync();
        await RefreshNotificationBadgeAsync();
    }

    private void CloseNotificationCenter()
    {
        _isNotificationCenterOpen = false;
    }

    private async Task LoadNotificationItemsAsync()
    {
        _notificationItems = (await NotificationInboxService.GetHistoryAsync()).ToList();
    }

    private async Task RefreshNotificationBadgeAsync()
    {
        _hasUnrespondedNotifications = await NotificationInboxService.HasUnrespondedAsync();
    }

    private static string GetNotificationTimeChipCss(NotificationInboxItem item)
    {
        return item.IsResponded && string.Equals(item.ResponseLabel, "Võetud", StringComparison.OrdinalIgnoreCase)
            ? "done"
            : string.Empty;
    }

    private void OpenDoseModal(HomeMedicationCard card)
    {
        _selectedDoseCard = new SelectedDoseCard(card.UserMedicationId, card.Name, card.ScheduledTime, card.Status, card.RemainingQuantity);
        _modalErrorMessage = null;
        _modalInfoMessage = null;
        _showEarlyDoneConfirmation = false;
        _showLastUnitConfirmation = false;
        _earlyDoneMinutesRemaining = 0;
    }

    private void OpenDoseModal(FamilyMedicationCard card)
    {
        _selectedDoseCard = new SelectedDoseCard(card.UserMedicationId, $"{card.ProfileName} · {card.Name}", card.ScheduledTime, card.Status, card.RemainingQuantity);
        _modalErrorMessage = null;
        _modalInfoMessage = null;
        _showEarlyDoneConfirmation = false;
        _showLastUnitConfirmation = false;
        _earlyDoneMinutesRemaining = 0;
    }

    private void CloseDoseModal()
    {
        _selectedDoseCard = null;
        _modalErrorMessage = null;
        _modalInfoMessage = null;
        _showEarlyDoneConfirmation = false;
        _showLastUnitConfirmation = false;
        _earlyDoneMinutesRemaining = 0;
    }

    private async Task UpdateDoseStatusFromModalAsync(DoseStatusEnum newStatus)
    {
        if (_selectedDoseCard is null || _isUpdatingDose)
        {
            return;
        }

        _isUpdatingDose = true;
        _modalErrorMessage = null;
        _modalInfoMessage = null;
        try
        {
            if (newStatus == DoseStatusEnum.Done)
            {
                var minutesUntilDose = GetRemainingMinutesUntilDose(_selectedDoseCard.ScheduledTime);
                if (minutesUntilDose > 0 && !_showEarlyDoneConfirmation)
                {
                    _showEarlyDoneConfirmation = true;
                    _earlyDoneMinutesRemaining = minutesUntilDose;
                    return;
                }

                if (!_showLastUnitConfirmation && _selectedDoseCard.RemainingQuantity == 1)
                {
                    _showLastUnitConfirmation = true;
                    return;
                }
            }

            var effectiveStatus = newStatus;
            if (newStatus == DoseStatusEnum.Missed && GetRemainingMinutesUntilDose(_selectedDoseCard.ScheduledTime) > 0)
            {
                effectiveStatus = DoseStatusEnum.Pending;
            }

            var result = await MedicationService.UpdateStatusAsync(_selectedDoseCard.UserMedicationId, new UpdateMedicationStatusDto
            {
                ScheduledTime = _selectedDoseCard.ScheduledTime,
                Status = effectiveStatus
            });

            if (result is null)
            {
                _modalErrorMessage = "Staatuse uuendamine ebaonnestus.";
                return;
            }

            if (!string.IsNullOrWhiteSpace(result.StockWarning))
            {
                _modalInfoMessage = result.StockWarning;
            }

            _selectedDoseCard = _selectedDoseCard with { Status = effectiveStatus };

            _showEarlyDoneConfirmation = false;
            _showLastUnitConfirmation = false;
            _earlyDoneMinutesRemaining = 0;
            if (string.IsNullOrWhiteSpace(result.StockWarning))
            {
                CloseDoseModal();
            }
        }
        catch
        {
            _modalErrorMessage = "Staatuse uuendamine ebaonnestus.";
        }
        finally
        {
            _isUpdatingDose = false;
        }
    }

    private string GetModalButtonCss(DoseStatusEnum targetStatus)
    {
        if (_selectedDoseCard is null)
        {
            return string.Empty;
        }

        if (targetStatus == DoseStatusEnum.Missed && (_selectedDoseCard.Status == DoseStatusEnum.Missed || _selectedDoseCard.Status == DoseStatusEnum.Skipped))
        {
            return "active";
        }

        return _selectedDoseCard.Status == targetStatus ? "active" : string.Empty;
    }

    private void OnMedicationStatusChanged(MedicationStatusChangedEvent payload)
    {
        _ = HandleMedicationStatusChangedAsync(payload);
    }

    private async Task HandleMedicationStatusChangedAsync(MedicationStatusChangedEvent payload)
    {
        await InvokeAsync(async () =>
        {
            await LoadHomeDataAsync();
            await RefreshNotificationBadgeAsync();
            StateHasChanged();
        });
    }

    private void OnNotificationInboxChanged()
    {
        _ = HandleNotificationInboxChangedAsync();
    }

    private async Task HandleNotificationInboxChangedAsync()
    {
        await InvokeAsync(async () =>
        {
            await RefreshNotificationBadgeAsync();

            if (_isNotificationCenterOpen)
            {
                await LoadNotificationItemsAsync();
            }

            StateHasChanged();
        });
    }

    private async Task ConfirmEarlyDoneAsync()
    {
        if (_selectedDoseCard is null)
        {
            return;
        }

        await UpdateDoseStatusFromModalAsync(DoseStatusEnum.Done);
    }

    private async Task ConfirmLastUnitDoneAsync()
    {
        if (_selectedDoseCard is null)
        {
            return;
        }

        await UpdateDoseStatusFromModalAsync(DoseStatusEnum.Done);
    }

    private void CancelEarlyDoneConfirmation()
    {
        _showEarlyDoneConfirmation = false;
        _showLastUnitConfirmation = false;
        _earlyDoneMinutesRemaining = 0;
    }

    private void CancelLastUnitConfirmation()
    {
        _showLastUnitConfirmation = false;
    }

    private static int GetRemainingMinutesUntilDose(TimeOnly scheduledTime)
    {
        var now = DateTime.Now;
        var scheduledAt = now.Date + scheduledTime.ToTimeSpan();
        var remaining = scheduledAt - now;
        if (remaining <= TimeSpan.Zero)
        {
            return 0;
        }

        return (int)Math.Ceiling(remaining.TotalMinutes);
    }

    private static string FormatRemainingTime(int minutes)
    {
        if (minutes <= 60)
        {
            return $"{minutes} min";
        }

        var hours = minutes / 60;
        var remainderMinutes = minutes % 60;
        if (remainderMinutes == 0)
        {
            return $"{hours}h";
        }

        return $"{hours}h ja {remainderMinutes} min";
    }

    public void Dispose()
    {
        MedicationStatusEvents.Changed -= OnMedicationStatusChanged;
        NotificationInboxService.Changed -= OnNotificationInboxChanged;
    }

