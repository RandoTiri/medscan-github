    }

    private void OpenDoseModal(FamilyMedicationCard card)
    {
        _selectedDoseCard = new SelectedDoseCard(card.UserMedicationId, $"{card.ProfileName} · {card.Name}", card.ScheduledTime, card.Status);
        _modalErrorMessage = null;
        _modalInfoMessage = null;
        _showEarlyDoneConfirmation = false;
        _earlyDoneMinutesRemaining = 0;
    }

    private void CloseDoseModal()
    {
        _selectedDoseCard = null;
        _modalErrorMessage = null;
        _modalInfoMessage = null;
        _showEarlyDoneConfirmation = false;
        _earlyDoneMinutesRemaining = 0;
    }

    private async Task UpdateDoseStatusFromModalAsync(DoseStatusEnum newStatus)
    {
        if (_selectedDoseCard is null || _isUpdatingDose)
        {
            return;
        }

        _isUpdatingDose = true;
        _modalErrorMessage = null;
        _modalInfoMessage = null;
        try
        {
            if (newStatus == DoseStatusEnum.Done)
            {
                var minutesUntilDose = GetRemainingMinutesUntilDose(_selectedDoseCard.ScheduledTime);
                if (minutesUntilDose > 0 && !_showEarlyDoneConfirmation)
                {
                    _showEarlyDoneConfirmation = true;
                    _earlyDoneMinutesRemaining = minutesUntilDose;
                    return;
                }
            }

            var effectiveStatus = newStatus;
            if (newStatus == DoseStatusEnum.Missed && GetRemainingMinutesUntilDose(_selectedDoseCard.ScheduledTime) > 0)
            {
                effectiveStatus = DoseStatusEnum.Pending;
            }

            var result = await MedicationService.UpdateStatusAsync(_selectedDoseCard.UserMedicationId, new UpdateMedicationStatusDto
            {
                ScheduledTime = _selectedDoseCard.ScheduledTime,
                Status = effectiveStatus
            });

            if (result is null)
            {
                _modalErrorMessage = "Staatuse uuendamine ebaonnestus.";
                return;
            }

            _showEarlyDoneConfirmation = false;
            _earlyDoneMinutesRemaining = 0;
            CloseDoseModal();
        }
        catch
        {
            _modalErrorMessage = "Staatuse uuendamine ebaonnestus.";
        }
        finally
        {
            _isUpdatingDose = false;
        }
    }

    private string GetModalButtonCss(DoseStatusEnum targetStatus)
    {
        if (_selectedDoseCard is null)
        {
            return string.Empty;
        }

        return _selectedDoseCard.Status == targetStatus ? "active" : string.Empty;
    }

