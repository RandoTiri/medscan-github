@page "/mymedicine"
@using MedScan.Shared.DTOs.Medication
@using MedScan.Shared.Models
@using MedScan.Shared.Models.Enums
@using MedScan.Shared.Services
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject IProfileService ProfileService
@inject IMedicationService MedicationService

<PageTitle>Minu ravimid</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else
{
    <div class="medicine-screen">
        <div class="medicine-header">
            <h1>Minu ravimid</h1>
            <button class="add-med-btn" @onclick="OpenScanner">+ Lisa</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="error-box">@_errorMessage</div>
        }

        <div class="profiles-row">
            @foreach (var profile in _profiles)
            {
                var active = profile.Id == _selectedProfileId;
                <button class="profile-chip @(active ? "active" : null)" @onclick="() => SelectProfileAsync(profile.Id)">
                    <span>@profile.Name</span>
                    <span class="count-badge">@GetProfileCount(profile.Id)</span>
                </button>
            }
        </div>

        @if (_isLoadingMedications)
        {
            <div class="empty-state">Laen ravimeid...</div>
        }
        else if (_selectedMedications.Count == 0)
        {
            <div class="empty-state">Selle profiili raviplaan on tühi.</div>
        }
        else
        {
            <div class="medicine-cards">
                @foreach (var medicine in _selectedMedications)
                {
                    var status = BuildStatusView(medicine);
                    var showMenu = _statusMenuMedicationId == medicine.Id;

                    <article class="medicine-card">
                        <div class="left-icon @status.IconClass">@status.Icon</div>

                        <div class="card-content">
                            <div class="top-line">
                                <h2>@BuildTitle(medicine)</h2>
                                <div class="right-controls">
                                    <span class="status-pill @status.PillClass">@status.Label</span>
                                    <button class="menu-btn" @onclick="() => ToggleStatusMenu(medicine.Id)">⋮</button>
                                </div>
                            </div>

                            <p class="meta-line">@medicine.FrequencyPerDay x päevas · @FormatTimes(medicine.ScheduledTimes)</p>

                            @if (!string.IsNullOrWhiteSpace(medicine.Notes))
                            {
                                <p class="note-line">💬 @medicine.Notes</p>
                            }

                            <div class="times-line">
                                @foreach (var time in medicine.ScheduledTimes.OrderBy(t => t))
                                {
                                    <span class="time-pill">🕒 @time.ToString("HH:mm")</span>
                                }
                            </div>

                            @if (showMenu)
                            {
                                <div class="status-actions">
                                    <button class="action done" @onclick="() => SetStatusAsync(medicine, DoseStatusEnum.Done)">Tehtud</button>
                                    <button class="action pending" @onclick="() => SetStatusAsync(medicine, DoseStatusEnum.Pending)">Ootel</button>
                                    <button class="action missed" @onclick="() => SetStatusAsync(medicine, DoseStatusEnum.Missed)">Tegemata</button>
                                </div>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </div>
}

<style>
