    .icon-done {
        background: #d6eddf;
        color: #2f6f58;
    }

    .icon-pending {
        background: #f4eccd;
        color: #98601f;
    }

    .icon-missed {
        background: #f9dfe2;
        color: #aa3f4c;
    }

    .card-content {
        display: grid;
        gap: 6px;
    }

    .top-line {
        display: flex;
        justify-content: space-between;
        gap: 8px;
    }

    .top-line h2 {
        margin: 0;
        color: #132340;
        font-size: 44px;
        line-height: 1.08;
