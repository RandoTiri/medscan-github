</style>

@code {
    [SupplyParameterFromQuery(Name = "profileId")]
    public int? RequestedProfileId { get; set; }

    private bool _isReady;
    private bool _isLoadingMedications;
    private string? _errorMessage;
    private int _selectedProfileId;
    private int? _statusMenuMedicationId;

    private readonly List<ProfileSummary> _profiles = [];
    private readonly Dictionary<int, List<UserMedicationDto>> _medicationsByProfile = [];

    private List<UserMedicationDto> _selectedMedications =>
        _selectedProfileId != 0 && _medicationsByProfile.TryGetValue(_selectedProfileId, out var medications)
            ? medications
            : [];

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _errorMessage = null;

        try
        {
            var profiles = await ProfileService.GetMyProfilesAsync();
            _profiles.Clear();
            _profiles.AddRange(profiles.OrderBy(p => p.Id));

            _selectedProfileId = ResolveDefaultProfileId();
            if (_selectedProfileId != 0)
            {
                await LoadProfileMedicationsAsync(_selectedProfileId);
            }
        }
        catch
        {
            _errorMessage = "Ravimite laadimine ebaõnnestus.";
        }
    }

    private int ResolveDefaultProfileId()
    {
        if (RequestedProfileId is int requestedProfileId && _profiles.Any(profile => profile.Id == requestedProfileId))
        {
            return requestedProfileId;
        }

        if (AuthService.CurrentUser?.DefaultProfileId is int defaultProfileId &&
            _profiles.Any(profile => profile.Id == defaultProfileId))
        {
            return defaultProfileId;
        }

        return _profiles.FirstOrDefault()?.Id ?? 0;
    }

    private async Task SelectProfileAsync(int profileId)
    {
        if (_selectedProfileId == profileId)
        {
            return;
        }

        _selectedProfileId = profileId;
        _statusMenuMedicationId = null;

        if (!_medicationsByProfile.ContainsKey(profileId))
        {
            await LoadProfileMedicationsAsync(profileId);
        }
    }

    private async Task LoadProfileMedicationsAsync(int profileId)
    {
        _isLoadingMedications = true;
        _errorMessage = null;

        try
        {
            var raw = await MedicationService.GetScheduleAsync(profileId);
            var cleaned = raw
                .Where(m => m.IsActive)
                .GroupBy(m => m.Id)
                .Select(g => g.First())
                .OrderBy(m => m.ScheduledTimes.DefaultIfEmpty(TimeOnly.MaxValue).Min())
                .ThenBy(m => m.MedicationName)
                .ToList();

            _medicationsByProfile[profileId] = cleaned;
        }
        catch
        {
            _medicationsByProfile[profileId] = [];
            _errorMessage = "Ravimite laadimine ebaõnnestus.";
        }
        finally
        {
            _isLoadingMedications = false;
        }
    }

    private int GetProfileCount(int profileId)
    {
        return _medicationsByProfile.TryGetValue(profileId, out var meds) ? meds.Count : 0;
    }

    private static string BuildTitle(UserMedicationDto medication)
    {
        var name = medication.MedicationName?.Trim() ?? string.Empty;
        var strength = medication.Strength?.Trim();

        if (string.IsNullOrWhiteSpace(strength))
        {
            return name;
        }

        return name.Contains(strength, StringComparison.OrdinalIgnoreCase)
            ? name
            : $"{name} {strength}";
    }

    private static string FormatTimes(IEnumerable<TimeOnly> times)
    {
        var values = times.OrderBy(t => t).Select(t => t.ToString("HH:mm")).ToList();
        return values.Count == 0 ? "-" : string.Join(", ", values);
    }

    private StatusView BuildStatusView(UserMedicationDto medication)
    {
        if (medication.LatestDoseStatus == DoseStatusEnum.Done)
        {
            return new StatusView("✓ Tehtud", "✓", "icon-done", "pill-done");
        }

        if (medication.LatestDoseStatus == DoseStatusEnum.Missed || medication.LatestDoseStatus == DoseStatusEnum.Skipped)
        {
            return new StatusView("! Tegemata", "!", "icon-missed", "pill-missed");
        }

        return new StatusView("🕒 Ootel", "🕒", "icon-pending", "pill-pending");
    }

    private void ToggleStatusMenu(int medicationId)
    {
        _statusMenuMedicationId = _statusMenuMedicationId == medicationId ? null : medicationId;
    }

    private async Task SetStatusAsync(UserMedicationDto medicine, DoseStatusEnum status)
    {
        var scheduled = medicine.ScheduledTimes.OrderBy(t => t).FirstOrDefault();
        var updated = await MedicationService.UpdateStatusAsync(medicine.Id, new UpdateMedicationStatusDto
        {
            ScheduledTime = scheduled,
            Status = status
        });

        if (updated is null)
        {
            _errorMessage = "Staatuse uuendamine ebaõnnestus.";
            return;
        }

        if (_medicationsByProfile.TryGetValue(medicine.ProfileId, out var list))
        {
            var index = list.FindIndex(x => x.Id == medicine.Id);
            if (index >= 0)
            {
                list[index] = updated;
            }
        }

        _statusMenuMedicationId = null;
    }

    private void OpenScanner() => Navigation.NavigateTo("/scanner");

    private sealed record StatusView(string Label, string Icon, string IconClass, string PillClass);
}

