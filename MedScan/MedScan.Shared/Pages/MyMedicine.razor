        color: #fff;
    }

    .medicine-cards {
        display: grid;
        gap: 12px;
    }

    .medicine-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 18px rgba(30, 55, 45, 0.08);
