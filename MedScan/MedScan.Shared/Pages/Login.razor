@page "/login"
@layout MedScan.Shared.Layout.AuthLayout
@using MedScan.Shared.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Logi sisse</PageTitle>

<div class="auth-form">
    <h1>Logi sisse</h1>
    <p class="auth-subtitle">Sisene MedScan rakendusse.</p>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="auth-error">@ErrorMessage</div>
    }

    <div class="form-group">
        <label for="email">Email</label>
        <input id="email" @bind="Email" class="form-input" disabled="@IsBusy" />
    </div>

    <div class="form-group">
        <label for="password">Parool</label>
        <input id="password" type="password" @bind="Password" class="form-input" disabled="@IsBusy" />
    </div>

    <button class="auth-button" @onclick="HandleLogin" disabled="@IsBusy">
        @(IsBusy ? "Logib sisse..." : "Logi sisse")
    </button>

    <div class="auth-footer">
        <span>Pole veel kasutajat?</span>
        <button class="link-button" @onclick="GoToRegister" disabled="@IsBusy">Loo kasutaja</button>
    </div>
</div>

@code {
    private string Email = string.Empty;
    private string Password = string.Empty;
    private string ErrorMessage = string.Empty;
    private bool IsBusy;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();

        if (AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/");
        }
    }

    private async Task HandleLogin()
    {
        if (IsBusy)
        {
            return;
        }

        IsBusy = true;
        ErrorMessage = string.Empty;

        try
        {
            var result = await AuthService.LoginAsync(Email, Password);

            if (result.Success)
            {
                Navigation.NavigateTo("/");
                return;
            }

            ErrorMessage = result.ErrorMessage;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Tehniline viga: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }


    private void GoToRegister()
    {
        Navigation.NavigateTo("/register");
    }
}
