@page "/login"
@layout MedScan.Shared.Layout.AuthLayout
@using MedScan.Shared.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Logi sisse</PageTitle>

<div class="auth-form">
    <h1>Logi sisse</h1>
    <p class="auth-subtitle">Sisene MedScan rakendusse.</p>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="auth-error">@ErrorMessage</div>
    }

    <div class="form-group">
        <label for="email">Email</label>
        <input id="email" @bind="Email" class="form-input" />
    </div>

    <div class="form-group">
        <label for="password">Parool</label>
        <input id="password" type="password" @bind="Password" class="form-input" />
    </div>

    <button class="auth-button" @onclick="HandleLogin">Logi sisse</button>

    <div class="auth-footer">
        <span>Pole veel kasutajat?</span>
        <button class="link-button" @onclick="GoToRegister">Loo kasutaja</button>
    </div>
</div>

@code {
    private string Email = string.Empty;
    private string Password = string.Empty;
    private string ErrorMessage = string.Empty;

    protected override void OnInitialized()
    {
        if (AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/");
        }
    }

    private void HandleLogin()
    {
        ErrorMessage = string.Empty;

        var success = AuthService.Login(Email, Password);

        if (success)
        {
            Navigation.NavigateTo("/");
            return;
        }

        if (!AuthService.HasRegisteredUser())
        {
            ErrorMessage = "Ühtegi kasutajat pole veel loodud.";
            return;
        }

        ErrorMessage = "Vale email või parool.";
    }

    private void GoToRegister()
    {
        Navigation.NavigateTo("/register");
    }
}