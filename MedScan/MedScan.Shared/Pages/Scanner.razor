@page "/scanner"
@using MedScan.Shared.Models
@using MedScan.Shared.Services
@inject AuthService AuthService
@inject IScannerFlowService ScannerFlowService
@inject NavigationManager Navigation

<PageTitle>Skanner</PageTitle>

@if (!_isReady)
{
    <p><em>Laen...</em></p>
}
else
{
    <div class="scanner-page">
        <h1>Ravimi skaneerimine</h1>
        <p>Vajuta nupule ja suuna kaamera ravimi triipkoodile.</p>

        <button class="btn btn-primary" @onclick="StartScanAsync" disabled="@_isScanning">
            @(_isScanning ? "Skannin..." : "Skaneeri ravim")
        </button>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <p class="scanner-message">@_message</p>
        }

        @if (_showRetryActions)
        {
            <div class="scanner-actions">
                <button class="btn btn-outline-primary" @onclick="StartScanAsync" disabled="@_isScanning">
                    Skaneeri uuesti
                </button>
                <button class="btn btn-outline-secondary" @onclick="OpenManualSearch">
                    Kasitsi otsimine
                </button>
            </div>
        }

        @if (_showOpenSettings)
        {
            <div class="scanner-actions">
                <button class="btn btn-outline-secondary" @onclick="OpenSettingsAsync">
                    Ava seaded
                </button>
            </div>
        }
    </div>
}

@code {
    private bool _isReady;
    private bool _isScanning;
    private bool _showRetryActions;
    private bool _showOpenSettings;
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();

        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
    }

    private async Task StartScanAsync()
    {
        if (_isScanning)
        {
            return;
        }

        _isScanning = true;
        _showRetryActions = false;
        _showOpenSettings = false;
        _message = null;

        try
        {
            var scanResult = await ScannerFlowService.ScanAsync();

            switch (scanResult.Status)
            {
                case BarcodeScanStatus.Success when !string.IsNullOrWhiteSpace(scanResult.Barcode):
                    Navigation.NavigateTo($"/scanner/result/{Uri.EscapeDataString(scanResult.Barcode)}");
                    return;

                case BarcodeScanStatus.PermissionDenied:
                    _message = "Kaameraoiguse puudumisel ei saa triipkoodi skannida.";
                    _showOpenSettings = scanResult.CanOpenSettings;
                    break;

                case BarcodeScanStatus.NotDetected:
                    _message = "Kaamera ei tuvastanud ravimit.";
                    _showRetryActions = true;
                    break;

                case BarcodeScanStatus.Canceled:
                    _message = "Skannimine katkestati.";
                    break;

                default:
                    _message = scanResult.Message ?? "Skannimine ebaonnestus.";
                    _showRetryActions = true;
                    break;
            }
        }
        catch
        {
            _message = "Skanneri avamine ebaonnestus.";
            _showRetryActions = true;
        }
        finally
        {
            _isScanning = false;
        }
    }

    private Task OpenSettingsAsync() => ScannerFlowService.OpenAppSettingsAsync();

    private void OpenManualSearch() => Navigation.NavigateTo("/scanner/search");
}
