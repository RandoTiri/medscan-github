@page "/update-password-success"
@layout MedScan.Shared.Layout.AuthLayout
@inject NavigationManager Navigation

<PageTitle>MedScan - Parool uuendatud</PageTitle>

<style>
    .success-page-container {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;

        width: 100%;
        min-height: 100vh;
        background-color: var(--ms-surface);
        max-width: 450px;
        margin: 0 auto;
        color: #1c3d4f;
        box-sizing: border-box;

        padding: 20px 16px;
    }

    .success-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        width: 100%;
    }

    .success-icon {
        color: #267863;
        margin-bottom: 20px;
    }

    .success-message {
        font-size: 18px;
        font-weight: bold;
        color: #2e7d32;
        margin-bottom: 30px;
    }

    .btn-primary {
        background-color: #267863;
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 16px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 4px 10px rgba(38, 120, 99, 0.2);
        width: 100%;
        transition: all 0.1s ease;
    }

    .btn-primary:active {
        transform: scale(0.98);
        background-color: #1e604f;
    }
</style>

<div class="success-page-container">
    <div class="success-container">
        <div class="success-icon">
            <svg viewBox="0 0 24 24" width="80" height="80" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
        </div>
        <div class="success-message">Olete edukalt parooli muutnud!</div>
        <button class="btn-primary" @onclick="GoToLogin">Logi sisse</button>
    </div>
</div>

@code {
    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }
}