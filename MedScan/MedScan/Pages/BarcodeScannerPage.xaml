<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="MedScan.Pages.BarcodeScannerPage"
             Title="Skanner"
             NavigationPage.HasNavigationBar="False">

    <Grid BackgroundColor="#1E232B">
        <zxing:CameraBarcodeReaderView x:Name="CameraView" />

        <!-- Overlay frame and content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top Row: Close and Flashlight Buttons -->
            <Grid Grid.Row="0" VerticalOptions="Start" Margin="20,40,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Close Button -->
                <Border Grid.Column="0"
                        WidthRequest="40" HeightRequest="40"
                        BackgroundColor="#4D4D4D"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 20"
                        Padding="0"
                        Opacity="0.7">
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="Scale" Value="1" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="PointerOver" />
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="CancelClicked" />
                    </Border.GestureRecognizers>
                    <Path Data="M6,6 L18,18 M18,6 L6,18" 
                          Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round" Fill="Transparent"
                          HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="20" HeightRequest="20" Aspect="Uniform"/>
                </Border>

                <!-- Flashlight Button -->
                <Border Grid.Column="2"
                        WidthRequest="40" HeightRequest="40"
                        BackgroundColor="#4D4D4D"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 20"
                        Padding="0"
                        Opacity="0.7">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="ToggleTorchClicked" />
                    </Border.GestureRecognizers>
                    <Path Data="M7,2 H17 V6 L15,9 V20 A2,2 0 0 1 13,22 H11 A2,2 0 0 1 9,20 V9 L7,6 V2 Z M7,6 H17 M12,12 V15"
                          Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                          HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="20" HeightRequest="22" Aspect="Uniform" />
                </Border>
            </Grid>

            <!-- Center Row: Scanning Frame & Text -->
            <StackLayout Grid.Row="1" VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
                <Grid WidthRequest="250" HeightRequest="200" IsClippedToBounds="True">
                    <BoxView WidthRequest="24" HeightRequest="2" Color="#258d6b" HorizontalOptions="Start" VerticalOptions="Start" CornerRadius="1" />
                    <BoxView WidthRequest="2" HeightRequest="24" Color="#258d6b" HorizontalOptions="Start" VerticalOptions="Start" CornerRadius="1" />

                    <BoxView WidthRequest="24" HeightRequest="2" Color="#258d6b" HorizontalOptions="End" VerticalOptions="Start" CornerRadius="1" />
                    <BoxView WidthRequest="2" HeightRequest="24" Color="#258d6b" HorizontalOptions="End" VerticalOptions="Start" CornerRadius="1" />

                    <BoxView WidthRequest="24" HeightRequest="2" Color="#258d6b" HorizontalOptions="Start" VerticalOptions="End" CornerRadius="1" />
                    <BoxView WidthRequest="2" HeightRequest="24" Color="#258d6b" HorizontalOptions="Start" VerticalOptions="End" CornerRadius="1" />

                    <BoxView WidthRequest="24" HeightRequest="2" Color="#258d6b" HorizontalOptions="End" VerticalOptions="End" CornerRadius="1" />
                    <BoxView WidthRequest="2" HeightRequest="24" Color="#258d6b" HorizontalOptions="End" VerticalOptions="End" CornerRadius="1" />

                    <BoxView x:Name="ScanLine" HeightRequest="2" Color="#258d6b" VerticalOptions="Start" HorizontalOptions="Fill" Margin="10,0"/>
                </Grid>

                <Label Text="Suuna kood raami sisse" TextColor="White" HorizontalOptions="Center" FontSize="14" />
            </StackLayout>

            <!-- Bottom Row: Manual Search Button -->
            <Grid Grid.Row="2" VerticalOptions="End" HorizontalOptions="Center" Margin="0,0,0,40">
                <Border BackgroundColor="Transparent"
                        Stroke="#6b7280"
                        StrokeShape="RoundRectangle 25"
                        Padding="20,10">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="ManualSearchClicked" />
                    </Border.GestureRecognizers>
                    <StackLayout Orientation="Horizontal" Spacing="10">
                        <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" 
                              Fill="White" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="20" HeightRequest="20" Aspect="Uniform"/>
                        <Label Text="Käsitsi otsimine" TextColor="White" VerticalOptions="Center" FontSize="14" />
                    </StackLayout>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="AlertOverlay"
              IsVisible="False"
              BackgroundColor="#73000000"
              InputTransparent="False">
            <Border HorizontalOptions="Center"
                    VerticalOptions="Center"
                    MaximumWidthRequest="340"
                    Margin="24"
                    Padding="16"
                    BackgroundColor="White"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 18">
                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="AlertTitleLabel"
                               Text="Viga"
                               TextColor="#1A4A3C"
                               FontSize="16"
                               FontAttributes="Bold" />
                        <Label x:Name="AlertMessageLabel"
                               TextColor="#1A4A3C"
                               FontSize="14"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Button x:Name="AlertPrimaryButton"
                                Grid.Column="0"
                                Text="Skaneeri uuesti"
                                Clicked="AlertPrimaryClicked"
                                BackgroundColor="#1F7A60"
                                TextColor="White"
                                FontSize="18"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                Padding="16,12" />
                        <Button x:Name="AlertSecondaryButton"
                                Grid.Column="1"
                                Text="Käsitsi otsimine"
                                Clicked="AlertSecondaryClicked"
                                BackgroundColor="White"
                                TextColor="#258D6B"
                                BorderColor="#258D6B"
                                BorderWidth="1"
                                FontSize="18"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                Padding="16,12" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
